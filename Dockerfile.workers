# Dockerfile for background workers
FROM node:22.12-alpine AS deps
RUN apk add --no-cache libc6-compat
WORKDIR /app

# Install pnpm
RUN npm install -g pnpm@8.9.0

# Copy package files for all workspace packages
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY packages/workers/package.json ./packages/workers/
COPY packages/utils/package.json ./packages/utils/
COPY packages/clients/db/package.json ./packages/clients/db/
COPY packages/clients/openai/package.json ./packages/clients/openai/
COPY packages/schemas/package.json ./packages/schemas/
COPY packages/data-orchestration/package.json ./packages/data-orchestration/

# Install dependencies
RUN pnpm install --frozen-lockfile

# Stage 2: Builder
FROM node:22.12-alpine AS builder
WORKDIR /app

# Install pnpm
RUN npm install -g pnpm@8.9.0

# Copy dependencies
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/packages ./packages

# Copy source code
COPY packages/workers ./packages/workers
COPY packages/utils ./packages/utils
COPY packages/clients/db ./packages/clients/db
COPY packages/clients/openai ./packages/clients/openai
COPY packages/schemas ./packages/schemas
COPY packages/data-orchestration ./packages/data-orchestration
COPY tsconfig.base.json ./tsconfig.base.json

# Generate Prisma client
RUN cd packages/clients/db && pnpm prisma generate

# Build workspace dependencies (fail the build if any package fails to compile)
RUN cd packages/utils && pnpm build
RUN cd packages/schemas && pnpm build
RUN cd packages/clients/db && pnpm build
RUN cd packages/data-orchestration && pnpm build

# Build workers (produces dist/index.js)
RUN cd packages/workers && pnpm build

# Stage 3: Runner
FROM node:22.12-alpine AS runner
WORKDIR /app

ENV NODE_ENV production
ENV NODE_OPTIONS="--max-old-space-size=4096"

# Install pnpm for workspace resolution
RUN npm install -g pnpm@8.9.0

# Create non-root user
RUN addgroup --system --gid 1001 workers
RUN adduser --system --uid 1001 worker

# Copy built output and dependencies
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/packages/workers/dist ./packages/workers/dist
COPY --from=builder /app/packages/workers/package.json ./packages/workers/package.json
COPY --from=builder /app/packages/workers/node_modules ./packages/workers/node_modules
COPY --from=builder /app/packages/utils/dist ./packages/utils/dist
COPY --from=builder /app/packages/utils/package.json ./packages/utils/package.json
COPY --from=builder /app/packages/schemas/dist ./packages/schemas/dist
COPY --from=builder /app/packages/schemas/package.json ./packages/schemas/package.json
COPY --from=builder /app/packages/clients/db ./packages/clients/db
COPY --from=builder /app/packages/clients/openai ./packages/clients/openai
COPY --from=builder /app/packages/data-orchestration/dist ./packages/data-orchestration/dist
COPY --from=builder /app/packages/data-orchestration/package.json ./packages/data-orchestration/package.json

USER worker

WORKDIR /app/packages/workers

CMD ["node", "dist/index.js"]
