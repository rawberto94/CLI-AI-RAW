{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "noImplicitOverride": true,
    "baseUrl": ".",
    "paths": {
      "utils": ["./packages/utils/src"],
      "utils/*": ["./packages/utils/src/*"],
      "schemas": ["./packages/schemas/src"],
      "schemas/*": ["./packages/schemas/src/*"],
      "clients-db": ["./packages/clients/db/src"],
      "clients-db/*": ["./packages/clients/db/src/*"],
      "clients-openai": ["./packages/clients/openai/src"],
      "clients-openai/*": ["./packages/clients/openai/src/*"],
      "clients-rag": ["./packages/clients/rag/src"],
      "clients-rag/*": ["./packages/clients/rag/src/*"],
      "agents": ["./packages/agents/src"],
      "agents/*": ["./packages/agents/src/*"],
      "data-orchestration": ["./packages/data-orchestration/src"],
      "data-orchestration/*": ["./packages/data-orchestration/src/*"],
      "@/apps/*": ["./apps/*"],
      "@/core": ["./apps/core"],
      "@/core/*": ["./apps/core/*"],
      "@/packages/*": ["./packages/*"],
      "@/packages/clients/*": ["./packages/clients/*"],
      "@/packages/clients/db": ["./packages/clients/db"],
      "@/packages/clients/db/*": ["./packages/clients/db/*"],
      "@/*": ["./apps/web/*"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    ".next",
    "out",
    "apps/web",
    "apps/sharepoint-app_disabled",
    "infra/seed",
    "src/components/ui"
  ]
}
