{
  "name": "contract-intelligence",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/clients/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:local": "concurrently -k -n api,web,workers -c green,cyan,magenta 'cd apps/api && DEMO_API_KEY=demo-board-2025 pnpm dev' 'cd apps/web && pnpm dev' 'cd apps/workers && pnpm dev'",
    "dev:codespaces": "concurrently -k -n api,web,workers -c green,cyan,magenta 'cd apps/api && DATABASE_URL=postgresql://postgres:postgres@postgres:5432/contract_intelligence REDIS_URL=redis://redis:6379 DEMO_API_KEY=demo-board-2025 pnpm dev' 'cd apps/web && NEXT_PUBLIC_API_URL=http://localhost:3001 pnpm dev' 'cd apps/workers && DATABASE_URL=postgresql://postgres:postgres@postgres:5432/contract_intelligence REDIS_URL=redis://redis:6379 pnpm dev'",
    "predev": "docker compose -f infra/docker-compose.yml up -d || true",
    "postinstall": "turbo run build --filter=utils --filter=schemas --filter=clients-*",
    "clean": "turbo run clean && rimraf node_modules/.cache",
    "setup:infra": "docker compose -f infra/docker-compose.yml up -d",
    "kill-ports": "lsof -ti :3001 | xargs kill -9 2>/dev/null || true; lsof -ti :3002 | xargs kill -9 2>/dev/null || true",
    "db:push": "pnpm --filter clients-db db:push",
    "db:seed": "pnpm --filter infra seed",
    "launch": "node ./scripts/launch.mjs",
    "launch:setup": "node ./scripts/launch.mjs setup",
    "launch:env": "node ./scripts/launch.mjs env",
    "launch:api": "node ./scripts/launch.mjs api",
    "launch:web": "node ./scripts/launch.mjs web",
    "launch:workers": "node ./scripts/launch.mjs workers",
    "launch:both": "node ./scripts/launch.mjs both",
    "launch:health": "node ./scripts/launch.mjs health",
    "launch:stop": "node ./scripts/launch.mjs stop",
    "launch:start": "node ./scripts/launch.mjs start",
    "launch:start:api": "node ./scripts/launch.mjs start api",
    "launch:start:web": "node ./scripts/launch.mjs start web",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "type-check": "turbo run type-check",
    "type-check:backend": "tsc --noEmit -p tsconfig.base.json",
    "type-check:web": "tsc --noEmit -p apps/web/tsconfig.json",
    "type-check:web:strict": "tsc --noEmit -p apps/web/tsconfig.strict.json",
    "type-check:web:strict:core": "tsc --noEmit -p apps/web/tsconfig.strict-core.json",
    "type-check:web:strict:phase2": "tsc --noEmit -p apps/web/tsconfig.strict-phase2.json",
    "type-check:web:strict:full": "tsc --noEmit -p apps/web/tsconfig.strict.json",
    "knip": "knip",
    "knip:production": "knip --production",
    "deadcode": "pnpm knip",
    "lhci": "lhci",
    "lighthouse": "pnpm lhci autorun",
    "perf:analyze": "pnpm --filter web build:analyze",
    "security:audit": "pnpm audit --audit-level moderate",
    "type-check:strict": "pnpm run type-check:backend && pnpm run type-check:web",
    "smoke": "node ./scripts/smoke-test.mjs ${API_URL:-http://localhost:3001}",
    "batch:upload": "node ./scripts/batch-upload.mjs",
    "audit": "pnpm audit --audit-level moderate",
    "audit:fix": "pnpm audit --fix",
    "outdated": "pnpm outdated --recursive"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@lhci/cli": "^0.15.1",
    "@next/eslint-plugin-next": "^15.5.3",
    "@types/node": "^22.9.3",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "concurrently": "^9.1.2",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9.35.0",
    "eslint-config-next": "15.1.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.2.0",
    "knip": "^5.63.1",
    "lighthouse": "^12.8.2",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@10.16.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "pgvector": "^0.1.8"
  },
  "pnpm": {
    "overrides": {
      "react": "19.0.0",
      "react-dom": "19.0.0",
      "@types/react": "19.1.13",
      "@types/react-dom": "19.1.5"
    }
  }
}
