{
  "name": "next-gen-contract-intelligence",
  "version": "2.0.0",
  "packageManager": "pnpm@8.9.0",
  "description": "Next-Generation Contract Intelligence System with Advanced Integration",
  "type": "module",
  "prisma": {
    "schema": "packages/clients/db/schema.prisma"
  },
  "scripts": {
    "dev": "(cd packages/workers && pnpm dev &) && cd apps/web && npm run dev",
    "dev:lite": "cd apps/web && npm run dev",
    "dev:web": "cd apps/web && npm run dev",
    "dev:all": "bash scripts/start-all.sh",
    "stop:all": "bash scripts/stop-all.sh",
    "build": "cd apps/web && npm run build",
    "build:clients": "bash scripts/build-clients.sh",
    "start": "cd apps/web && npm run start",
    "websocket": "cd apps/web && npx ts-node --transpile-only server/start-websocket.ts",
    "workers": "cd packages/workers && pnpm dev",
    "workers:build": "cd packages/workers && pnpm build",
    "workers:start": "cd packages/workers && pnpm start",
    "api": "cd packages/data-orchestration && node api-server.js",
    "test": "bash scripts/start-test-services.sh && cd apps/web && pnpm test:headless",
    "test:e2e": "cd apps/web && pnpm test:e2e",
    "test:e2e:ui": "cd apps/web && pnpm test:e2e:ui",
    "test:rag-integration": "tsx scripts/test-rag-integration.ts",
    "services": "bash .devcontainer/start-services.sh",
    "services:test": "bash scripts/start-test-services.sh",
    "setup": "bash .devcontainer/setup.sh",
    "verify": "bash scripts/verify-production-readiness.sh",
    "typecheck": "pnpm typecheck:web && pnpm typecheck:workers",
    "typecheck:web": "pnpm -C apps/web exec tsc --noEmit --pretty false",
    "typecheck:workers": "pnpm -C packages/workers run typecheck",
    "db:migrate": "npx prisma migrate deploy --schema packages/clients/db/schema.prisma",
    "db:generate": "npx prisma generate --schema packages/clients/db/schema.prisma",
    "db:studio": "npx prisma studio --schema packages/clients/db/schema.prisma",
    "db:push": "npx prisma db push --schema packages/clients/db/schema.prisma",
    "db:seed": "npx prisma db seed --schema packages/clients/db/schema.prisma"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "@types/jspdf": "^2.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "express-ws": "^5.0.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.0.0",
    "langsmith": "^0.3.78",
    "mammoth": "^1.5.1",
    "multer": "^2.0.2",
    "node-cron": "^3.0.2",
    "pdf-parse": "^1.1.1",
    "pgvector": "^0.1.8",
    "pptxgenjs": "^4.0.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "dotenv-cli": "^10.0.0",
    "nodemon": "^3.0.0",
    "turbo": "^2.7.2"
  },
  "pnpm": {
    "overrides": {
      "zod": "3.23.8",
      "zod-to-json-schema": "3.23.5"
    },
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "@sentry/cli",
      "@vercel/speed-insights",
      "aws-sdk",
      "bcrypt",
      "core-js",
      "es5-ext",
      "esbuild",
      "fsevents",
      "keytar",
      "msgpackr-extract",
      "node-sass",
      "prisma",
      "protobufjs",
      "puppeteer",
      "sharp",
      "tesseract.js",
      "unrs-resolver"
    ]
  }
}
