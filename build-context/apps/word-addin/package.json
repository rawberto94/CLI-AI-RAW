{
  "name": "@contigo/word-addin",
  "version": "1.0.0",
  "description": "ConTigo Contract Generation Add-in for Microsoft Word",
  "private": true,
  "main": "src/taskpane/index.tsx",
  "scripts": {
    "dev": "webpack serve --mode development --open word",
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "start": "webpack serve --mode development",
    "lint": "eslint src/**/*.{ts,tsx}",
    "typecheck": "tsc --noEmit",
    "sideload": "office-addin-dev-certs install && office-addin-debugging start manifest.xml"
  },
  "dependencies": {
    "@fluentui/react": "^8.117.0",
    "@fluentui/react-components": "^9.46.0",
    "@microsoft/office-js": "^1.1.89",
    "@tanstack/react-query": "^5.17.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/office-js": "^1.0.380",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "copy-webpack-plugin": "^12.0.0",
    "css-loader": "^6.9.0",
    "html-webpack-plugin": "^5.6.0",
    "office-addin-debugging": "^5.0.0",
    "office-addin-dev-certs": "^1.12.0",
    "style-loader": "^3.3.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^4.15.0"
  }
}
