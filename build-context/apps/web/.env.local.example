# Database Connection Pool Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/dbname?connection_limit=20&pool_timeout=20&connect_timeout=10"

# Increase connection pool size and add timeouts
# connection_limit: Maximum number of connections (default: unlimited, recommended: 10-50)
# pool_timeout: Maximum time (seconds) to wait for a connection from the pool
# connect_timeout: Maximum time (seconds) to wait for connection establishment

# For production, use environment-specific values:
# Development: connection_limit=20
# Testing: connection_limit=10 (fewer connections for stability)
# Production: connection_limit=50 (higher for scale)
