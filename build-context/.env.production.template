# Environment Variables Template

# ======================
# DATABASE
# ======================
POSTGRES_DB=contract_intelligence
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<GENERATE_SECURE_PASSWORD>
DATABASE_URL=postgresql://postgres:<PASSWORD>@postgres:5432/contract_intelligence

# ======================
# REDIS
# ======================
REDIS_HOST=redis
REDIS_PORT=6379

# ======================
# MINIO / S3 STORAGE
# ======================
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ROOT_USER=<GENERATE_SECURE_USERNAME>
MINIO_ROOT_PASSWORD=<GENERATE_SECURE_PASSWORD>
S3_ACCESS_KEY=<MINIO_ROOT_USER>
S3_SECRET_KEY=<MINIO_ROOT_PASSWORD>
S3_BUCKET=contracts
MINIO_USE_SSL=false

# ======================
# NEXTAUTH
# ======================
AUTH_SECRET=<GENERATE_WITH_OPENSSL_RAND_BASE64_32>
NEXTAUTH_URL=https://your-production-domain.com

# ======================
# OPENAI
# ======================
OPENAI_API_KEY=sk-...

# ======================
# FEATURES
# ======================
RAG_INTEGRATION_ENABLED=true

# ======================
# DEPLOYMENT
# ======================
NODE_ENV=production
LOG_LEVEL=info

# Container images (for production deployment)
WEB_IMAGE=ghcr.io/yourorg/cli-ai-raw/web:latest
WORKERS_IMAGE=ghcr.io/yourorg/cli-ai-raw/workers:latest
VERSION=latest

# Worker scaling
WORKER_REPLICAS=2

# ======================
# OPTIONAL: MONITORING
# ======================
# SENTRY_DSN=https://...
# DATADOG_API_KEY=...

# ======================
# OPTIONAL: NGINX SSL
# ======================
# SSL_CERT_PATH=/etc/letsencrypt/live/your-domain.com/fullchain.pem
# SSL_KEY_PATH=/etc/letsencrypt/live/your-domain.com/privkey.pem

# ======================
# HOW TO GENERATE SECRETS
# ======================
# AUTH_SECRET: openssl rand -base64 32
# POSTGRES_PASSWORD: openssl rand -base64 24
# MINIO_ROOT_USER: openssl rand -hex 10
# MINIO_ROOT_PASSWORD: openssl rand -base64 30
