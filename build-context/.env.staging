# ============================================
# Staging Environment Configuration
# ============================================
# This file contains staging-specific configuration
# Copy values from here to your actual .env file for staging deployment

# ============================================
# Environment
# ============================================
NODE_ENV=staging
LOG_LEVEL=debug

# ============================================
# Database Configuration
# ============================================
DATABASE_URL="postgresql://postgres:staging_password@localhost:5433/contract_intelligence_staging?connection_limit=10&pool_timeout=20"

# ============================================
# Redis Configuration
# ============================================
REDIS_URL="redis://localhost:6380"

# ============================================
# S3/MinIO Configuration
# ============================================
S3_ENDPOINT=http://localhost:9002
S3_BUCKET=contracts-staging
AWS_ACCESS_KEY_ID=staging_minio
AWS_SECRET_ACCESS_KEY=staging_minio_secret

# ============================================
# Application Configuration
# ============================================
PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# ============================================
# AI Service Configuration
# ============================================
OPENAI_API_KEY=sk-your-staging-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
ANALYSIS_USE_LLM=true
RAG_ENABLED=true

# ============================================
# Security Configuration
# ============================================
JWT_SECRET=staging-jwt-secret-change-in-production
SESSION_SECRET=staging-session-secret-change-in-production

# ============================================
# Feature Flags
# ============================================
ENABLE_AI_FEATURES=true
ENABLE_HEALTH_CHECKS=true
ENABLE_MONITORING=true
ENABLE_PERFORMANCE_TRACKING=true
ENABLE_TENANT_WARNINGS=true

# ============================================
# Monitoring & Observability
# ============================================
# SENTRY_DSN=https://your-staging-sentry-dsn@sentry.io/project-id
# APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-staging-key

# ============================================
# Performance Configuration
# ============================================
SLOW_QUERY_THRESHOLD=1000
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RESET_TIMEOUT=60000

# ============================================
# RAG Integration Configuration
# ============================================
RAG_INTEGRATION_ENABLED=true
RAG_AUTO_INDEX=true
RAG_MAX_RETRIES=3
RAG_RETRY_DELAY_MS=5000
RAG_TIMEOUT_MS=30000
RAG_FAIL_SILENTLY=true
# CHROMA_URL removed — ChromaDB deprecated Q2 2024; vector search uses pgvector natively

# ============================================
# Unified Orchestration Configuration
# ============================================
ENABLE_ANALYTICAL_SYNC=true
ENABLE_RATE_CARD_SYNC=true
ENABLE_DATA_STANDARDIZATION=true
ENABLE_SAVINGS_DETECTION=true
ENABLE_TAXONOMY_ENRICHMENT=true
ENABLE_WORKFLOW_AUTOMATION=true
ENABLE_INTELLIGENCE_ENGINE=true

# ============================================
# File Storage Configuration
# ============================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600

# ============================================
# Development Configuration
# ============================================
PRETTY_LOGS=true
ENABLE_QUERY_LOGGING=true
