# ==============================================
# Production Environment Configuration
# Contract Intelligence Platform
# ==============================================
# Copy this file to .env and fill in your values

# ==============================================
# Application URLs
# ==============================================
NEXTAUTH_URL=https://your-domain.com
CORS_ORIGIN=https://your-domain.com

# ==============================================
# Database Configuration
# ==============================================
POSTGRES_DB=contracts
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-here
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?connection_limit=20&pool_timeout=30

# ==============================================
# Redis Configuration
# ==============================================
REDIS_URL=redis://redis:6379

# ==============================================
# MinIO Object Storage
# ==============================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your-minio-password-here
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=contracts

# ==============================================
# Security Secrets (GENERATE THESE!)
# Use: openssl rand -hex 32
# ==============================================
NEXTAUTH_SECRET=generate-with-openssl-rand-hex-32
ENCRYPTION_KEY=generate-with-openssl-rand-hex-32
API_KEY_SALT=generate-with-openssl-rand-hex-16
JWT_SECRET=generate-with-openssl-rand-hex-32
SESSION_SECRET=generate-with-openssl-rand-hex-32

# ==============================================
# AI Services
# ==============================================
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4

# ==============================================
# WebSocket Configuration
# ==============================================
WEBSOCKET_PORT=3001
WEBSOCKET_URL=wss://your-domain.com/ws

# ==============================================
# OAuth Providers (as needed)
# ==============================================
# DocuSign
DOCUSIGN_CLIENT_ID=
DOCUSIGN_CLIENT_SECRET=

# SAP Ariba
SAP_ARIBA_CLIENT_ID=
SAP_ARIBA_CLIENT_SECRET=

# Coupa
COUPA_CLIENT_ID=
COUPA_CLIENT_SECRET=
COUPA_INSTANCE=

# Adobe Sign
ADOBE_SIGN_CLIENT_ID=
ADOBE_SIGN_CLIENT_SECRET=

# HelloSign
HELLOSIGN_CLIENT_ID=
HELLOSIGN_CLIENT_SECRET=

# ==============================================
# Feature Flags
# ==============================================
ENABLE_AI_FEATURES=true
ENABLE_HEALTH_CHECKS=true
RAG_INTEGRATION_ENABLED=true
RAG_AUTO_INDEX=true

# ==============================================
# Rate Limiting
# ==============================================
RATE_LIMIT_API=100
RATE_LIMIT_AUTH=5
RATE_LIMIT_UPLOAD=10
RATE_LIMIT_AI=20

# ==============================================
# Monitoring (Optional)
# ==============================================
# SENTRY_DSN=https://your-sentry-dsn
# LOG_LEVEL=info
