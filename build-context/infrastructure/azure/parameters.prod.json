{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environment": {
      "value": "prod"
    },
    "location": {
      "value": "switzerlandnorth"
    },
    "postgresPassword": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/<SUBSCRIPTION_ID>/resourceGroups/rg-contigo-prod/providers/Microsoft.KeyVault/vaults/kv-contigo-prod"
        },
        "secretName": "postgres-password"
      }
    },
    "adminEmail": {
      "value": "admin@contigo.ch"
    }
  }
}
