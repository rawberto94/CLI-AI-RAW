# =============================================================================
# Swiss Data Protection Compliant Environment Configuration
# =============================================================================
# This template configures the application for Swiss FADP (nDSG) compliance.
# All cloud services MUST be hosted in Switzerland or approved EU regions.
# 
# APPROVED REGIONS:
# - Azure: switzerlandnorth (Zürich) - RECOMMENDED
# - GCP: europe-west6 (Zürich) - RECOMMENDED
# - AWS: eu-central-1 (Frankfurt) - Acceptable
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
NODE_ENV=production
APP_NAME=Contract Management System
APP_URL=https://your-domain.ch
APP_LOCALE=de-CH

# Swiss Data Residency
DATA_REGION=CH
ENABLE_DATA_RESIDENCY_CHECK=true
BLOCK_NON_COMPLIANT_REGIONS=true

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# IMPORTANT: Must be hosted in Switzerland or approved EU region
# -----------------------------------------------------------------------------
# Azure Database for PostgreSQL (Switzerland North)
DATABASE_URL=postgresql://user:password@psql-contracts-ch.postgres.database.azure.com:5432/contracts?sslmode=require

# Database SSL (REQUIRED for Swiss FADP)
DATABASE_SSL=require
DATABASE_SSL_CERT_PATH=/etc/ssl/certs/ca-certificates.crt

# Connection Pool
DATABASE_POOL_SIZE=20
DATABASE_CONNECTION_TIMEOUT=10000

# -----------------------------------------------------------------------------
# Redis Cache Configuration
# IMPORTANT: Must be hosted in Switzerland or approved EU region
# -----------------------------------------------------------------------------
# Azure Cache for Redis (Switzerland North)
REDIS_URL=rediss://redis-contracts-ch.redis.cache.windows.net:6380
REDIS_PASSWORD=your-redis-password
REDIS_TLS=true

# -----------------------------------------------------------------------------
# Object Storage Configuration
# IMPORTANT: Must be hosted in Switzerland or approved EU region
# -----------------------------------------------------------------------------
# Azure Blob Storage (Switzerland North)
STORAGE_PROVIDER=azure
AZURE_STORAGE_ACCOUNT=stcontractsch
AZURE_STORAGE_KEY=your-storage-key
AZURE_STORAGE_CONTAINER=contracts

# OR AWS S3 (Frankfurt - closest to Switzerland)
# S3_REGION=eu-central-1
# S3_BUCKET=contracts-ch-prod
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_ENCRYPTION=AES256

# -----------------------------------------------------------------------------
# Authentication & Security
# -----------------------------------------------------------------------------
# Session Security
SESSION_SECRET=generate-a-secure-64-char-secret-key
SESSION_TIMEOUT_MINUTES=30
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=strict

# JWT Configuration
JWT_SECRET=generate-a-secure-64-char-jwt-secret
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Multi-Factor Authentication (RECOMMENDED for Swiss compliance)
MFA_REQUIRED=true
MFA_ISSUER=ContractManagement

# Password Policy
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SYMBOLS=true

# -----------------------------------------------------------------------------
# Encryption Configuration
# REQUIRED: Swiss FADP mandates encryption at rest and in transit
# -----------------------------------------------------------------------------
ENCRYPTION_ENABLED=true
ENCRYPTION_ALGORITHM=AES-256-GCM
ENCRYPTION_KEY=your-32-byte-encryption-key-hex
ENCRYPTION_KEY_ROTATION_DAYS=90

# -----------------------------------------------------------------------------
# Audit & Logging
# REQUIRED: Swiss FADP requires comprehensive audit trails
# -----------------------------------------------------------------------------
AUDIT_LOGGING_ENABLED=true
AUDIT_LOG_LEVEL=info
AUDIT_RETENTION_DAYS=365
SENSITIVE_DATA_MASKING=true

# Log Storage (must be in approved region)
LOG_STORAGE_PROVIDER=azure
LOG_STORAGE_CONTAINER=audit-logs

# -----------------------------------------------------------------------------
# AI Services Configuration
# IMPORTANT: Consider data privacy when using AI services
# -----------------------------------------------------------------------------
# OpenAI (data may be processed outside Switzerland - NOT RECOMMENDED)
# OPENAI_API_KEY=your-openai-api-key

# RECOMMENDED: Azure OpenAI with Swiss data residency (Switzerland North)
# This ensures all AI processing stays within Switzerland
AZURE_OPENAI_ENDPOINT=https://aoai-contracts-switzerlandnorth.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4

# Anthropic (data processed in US/EU - use only if Azure unavailable)
# ANTHROPIC_API_KEY=your-anthropic-api-key

# -----------------------------------------------------------------------------
# LLM OCR Enhancement (Swiss Data Protection Compliant)
# -----------------------------------------------------------------------------
# These settings control the hybrid LLM spell correction feature
# Data residency: CH = Switzerland only, EU = EU regions, ANY = no restriction
OCR_LLM_DATA_RESIDENCY=CH
OCR_LLM_ANONYMIZE_PII=true
OCR_LLM_AUDIT_LOGGING=true
OCR_LLM_BLOCK_NON_COMPLIANT=true

# -----------------------------------------------------------------------------
# Document Processing — Azure Document Intelligence v4.0
# -----------------------------------------------------------------------------
# OCR Provider (azure, openai, mistral, tesseract)
OCR_PROVIDER=azure

# Document Intelligence — Switzerland North (primary)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://di-contracts-ch.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-di-key

# Document Intelligence — EU (secondary, for non-Swiss EU clients)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT_EU=https://di-contracts-eu.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY_EU=your-di-eu-key

# DI v4.0 default model: layout | read | contract | invoice
# 'layout' provides text + tables + key-value pairs + structural analysis
AZURE_DI_DEFAULT_MODEL=layout

# DI v4.0 add-on features (comma-separated): keyValuePairs,queryFields
AZURE_DI_FEATURES=keyValuePairs

# PDF Generation
PDF_GENERATION_SERVICE=internal

# -----------------------------------------------------------------------------
# Email Configuration (Transactional)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.your-email-provider.ch
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM=noreply@your-domain.ch

# -----------------------------------------------------------------------------
# Webhook & Integration Settings
# -----------------------------------------------------------------------------
WEBHOOK_SECRET=generate-a-secure-webhook-secret
WEBHOOK_TIMEOUT_MS=30000

# -----------------------------------------------------------------------------
# Rate Limiting & Security
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ALLOWED_ORIGINS=https://your-domain.ch

# -----------------------------------------------------------------------------
# Monitoring & Observability
# -----------------------------------------------------------------------------
# Application Insights (Azure)
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=xxx;IngestionEndpoint=https://switzerlandnorth-0.in.applicationinsights.azure.com/

# Health Check
HEALTH_CHECK_PATH=/api/health
HEALTH_CHECK_TIMEOUT=5000

# -----------------------------------------------------------------------------
# Feature Flags (MVP Stage)
# Disable features that aren't needed for MVP to reduce costs
# -----------------------------------------------------------------------------
FEATURE_AI_ANALYSIS=true
FEATURE_BULK_OPERATIONS=true
FEATURE_TEAM_COLLABORATION=false
FEATURE_ADVANCED_ANALYTICS=false
FEATURE_CUSTOM_WORKFLOWS=false
FEATURE_API_INTEGRATIONS=false

# -----------------------------------------------------------------------------
# Cost Optimization (MVP Stage)
# -----------------------------------------------------------------------------
# Use smaller instance sizes for MVP
KUBERNETES_NODE_SIZE=Standard_D2s_v3
KUBERNETES_MIN_NODES=2
KUBERNETES_MAX_NODES=4

# Database sizing for MVP
DATABASE_SKU=GP_Gen5_2
DATABASE_STORAGE_GB=128

# Disable expensive services not needed for MVP
ENABLE_CDN=false
ENABLE_WAF=false
ENABLE_PREMIUM_STORAGE=false

# -----------------------------------------------------------------------------
# Compliance & Legal
# -----------------------------------------------------------------------------
# Data Protection Officer Contact
DPO_EMAIL=datenschutz@your-domain.ch
DPO_NAME=Your DPO Name

# Legal Entity
LEGAL_ENTITY_NAME=Your Company AG
LEGAL_ENTITY_ADDRESS=Your Address, Zürich, Switzerland
LEGAL_ENTITY_UID=CHE-xxx.xxx.xxx

# Terms & Privacy Policy URLs
TERMS_URL=https://your-domain.ch/agb
PRIVACY_POLICY_URL=https://your-domain.ch/datenschutz

# =============================================================================
# IMPORTANT REMINDERS FOR SWISS COMPLIANCE:
# =============================================================================
# 1. Ensure all cloud resources are in approved regions
# 2. Enable SSL/TLS for all connections
# 3. Enable encryption at rest for all storage
# 4. Configure audit logging
# 5. Sign DPA with cloud provider
# 6. Maintain data processing register
# 7. Implement data subject rights (export, deletion)
# 8. Regular security assessments
# =============================================================================
