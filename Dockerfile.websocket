# Dockerfile for WebSocket Server
FROM node:22.12-alpine AS base

# Install dependencies only when needed
FROM base AS deps
RUN apk add --no-cache libc6-compat
WORKDIR /app

# Install pnpm (match version in package.json packageManager field)
RUN npm install -g pnpm@8.9.0

# Copy package files
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/web/package.json ./apps/web/
COPY packages/clients/db/package.json ./packages/clients/db/

# Install dependencies
RUN pnpm install --frozen-lockfile

# Build stage
FROM base AS builder
WORKDIR /app

RUN npm install -g pnpm@8.9.0

COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules
COPY . .

# Build TypeScript (fail on errors to prevent shipping broken code)
WORKDIR /app/apps/web
RUN pnpm exec tsc --project tsconfig.json --outDir dist --declaration false

# Production stage
FROM base AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV WEBSOCKET_PORT=3001
ENV NODE_OPTIONS="--max-old-space-size=1024"

# Create non-root user
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 websocket

# Copy necessary files
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules
COPY --from=builder /app/apps/web/server ./apps/web/server
COPY --from=builder /app/apps/web/package.json ./apps/web/

USER websocket

EXPOSE 3001

WORKDIR /app/apps/web

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:3001/health || exit 1

# Start WebSocket server
CMD ["node", "--experimental-specifier-resolution=node", "--loader", "ts-node/esm", "server/start-websocket.ts"]
