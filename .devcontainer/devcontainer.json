{
  "name": "Contigo",

  "image": "mcr.microsoft.com/devcontainers/base:bullseye",

  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20",
      "pnpmVersion": "9"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        },
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "files.eol": "\n"
      },
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "prisma.prisma",
        "GitHub.copilot",
        "GitHub.copilot-chat"
      ]
    }
  },

  "forwardPorts": [3005, 5432, 6379, 7474, 7687, 9000, 9001],

  "portsAttributes": {
    "3005": { "label": "App", "onAutoForward": "openBrowser" },
    "5432": { "label": "Postgres" },
    "6379": { "label": "Redis" },
    "7474": { "label": "Neo4j Browser" },
    "7687": { "label": "Neo4j Bolt" },
    "9000": { "label": "MinIO API" },
    "9001": { "label": "MinIO Console" }
  },

  "remoteEnv": {
    "PNPM_HOME": "/home/vscode/.local/share/pnpm",
    "PATH": "/home/vscode/.local/share/pnpm:$PATH",
    "NODE_OPTIONS": "--max-old-space-size=8192"
  },

  "postCreateCommand": "corepack enable && pnpm install",

  "postStartCommand": "docker compose up -d",

  "remoteUser": "vscode",
  "updateRemoteUserUID": true
}
