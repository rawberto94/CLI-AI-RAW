# ============================================
# CONTRACT INTELLIGENCE PLATFORM
# Production Environment Configuration
# ============================================
# Copy this file to .env and update with your values
# Last Updated: 2024
# Version: 2.0.0

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=production
LOG_LEVEL=info
HOSTNAME=0.0.0.0
PORT=3000

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL connection string with connection pooling
# Format: postgresql://user:password@host:port/database?connection_limit=10&pool_timeout=20
DATABASE_URL=postgresql://postgres:password@localhost:5432/contract_intelligence?connection_limit=10&pool_timeout=20

# ============================================
# REDIS CONFIGURATION
# ============================================
# Redis for caching and event bus
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# AI SERVICE CONFIGURATION
# ============================================
# OpenAI API key for AI-powered features
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI model selection
OPENAI_MODEL=gpt-4o-mini

# ============================================
# RAG SYSTEM CONFIGURATION
# ============================================
# Enable/disable RAG integration
RAG_INTEGRATION_ENABLED=true

# Auto-index contracts on upload
RAG_AUTO_INDEX=true

# Maximum retry attempts for failed indexing
RAG_MAX_RETRIES=3

# Delay between retries (milliseconds)
RAG_RETRY_DELAY_MS=5000

# Timeout for RAG operations (milliseconds)
RAG_TIMEOUT_MS=30000

# Fail silently without breaking upload flow
RAG_FAIL_SILENTLY=true

# ============================================
# VECTOR DATABASE CONFIGURATION (Chroma)
# ============================================
# Chroma DB URL for vector storage
CHROMA_URL=http://localhost:8000

# ============================================
# UNIFIED ORCHESTRATION CONFIGURATION
# ============================================
# Enable/disable individual integrations

# Analytical Intelligence Sync
ENABLE_ANALYTICAL_SYNC=true

# Rate Card Benchmarking Sync
ENABLE_RATE_CARD_SYNC=true

# Data Standardization
ENABLE_DATA_STANDARDIZATION=true

# Savings Detection
ENABLE_SAVINGS_DETECTION=true

# Taxonomy Enrichment
ENABLE_TAXONOMY_ENRICHMENT=true

# Workflow Automation
ENABLE_WORKFLOW_AUTOMATION=true

# Intelligence Engine
ENABLE_INTELLIGENCE_ENGINE=true

# ============================================
# FILE STORAGE CONFIGURATION
# ============================================
# Upload directory for contract files
UPLOAD_DIR=./uploads

# Artifact storage threshold (bytes) - files larger than this go to cloud storage
ARTIFACT_STORAGE_THRESHOLD=10485760

# Enable compression for artifacts
ARTIFACT_COMPRESSION=true

# ============================================
# CLOUD STORAGE CONFIGURATION (Optional)
# ============================================
# AWS S3 Configuration
AWS_S3_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Azure Blob Storage Configuration
AZURE_STORAGE_CONNECTION_STRING=
AZURE_CONTAINER_NAME=artifacts

# ============================================
# APPLICATION URLS
# ============================================
# Public URL for the application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API base URL
API_BASE_URL=http://localhost:3000

# Web URL
WEB_URL=http://localhost:3000

# ============================================
# TENANT CONFIGURATION
# ============================================
# Default tenant ID for testing
TENANT_ID=demo

# ============================================
# SECURITY CONFIGURATION
# ============================================
# JWT secret for authentication (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Session secret
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
# SMTP configuration for email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourcompany.com

# ============================================
# MONITORING & OBSERVABILITY
# ============================================
# Enable performance monitoring
ENABLE_PERFORMANCE_MONITORING=true

# Enable error tracking
ENABLE_ERROR_TRACKING=true

# Sentry DSN (optional)
SENTRY_DSN=

# ============================================
# FEATURE FLAGS
# ============================================
# Enable experimental features
ENABLE_EXPERIMENTAL_FEATURES=false

# Enable debug mode
DEBUG_MODE=false

# Enable verbose logging
VERBOSE_LOGGING=false

# ============================================
# RATE LIMITING
# ============================================
# API rate limit (requests per minute)
API_RATE_LIMIT=100

# Upload rate limit (uploads per hour)
UPLOAD_RATE_LIMIT=50

# ============================================
# PROCESSING CONFIGURATION
# ============================================
# Maximum file size for uploads (bytes)
MAX_FILE_SIZE=104857600

# Maximum concurrent processing jobs
MAX_CONCURRENT_JOBS=5

# Job timeout (milliseconds)
JOB_TIMEOUT=300000

# ============================================
# CACHE CONFIGURATION
# ============================================
# Cache TTL (seconds)
CACHE_TTL=3600

# Enable cache
ENABLE_CACHE=true

# ============================================
# WEBHOOK CONFIGURATION (Optional)
# ============================================
# Webhook URL for notifications
WEBHOOK_URL=

# Webhook secret for verification
WEBHOOK_SECRET=

# ============================================
# ANALYTICS CONFIGURATION
# ============================================
# Enable analytics tracking
ENABLE_ANALYTICS=true

# Google Analytics ID (optional)
GA_TRACKING_ID=

# ============================================
# BACKUP CONFIGURATION
# ============================================
# Enable automatic backups
ENABLE_AUTO_BACKUP=true

# Backup schedule (cron format)
BACKUP_SCHEDULE=0 2 * * *

# Backup retention days
BACKUP_RETENTION_DAYS=30

# ============================================
# DEVELOPMENT ONLY
# ============================================
# These should NOT be set in production

# Skip environment validation (NEVER use in production)
# SKIP_ENV_VALIDATION=false

# Enable hot reload
# HOT_RELOAD=true

# ============================================
# CODESPACES / DEV CONTAINER DETECTION
# ============================================
# These are automatically set by GitHub Codespaces
# CODESPACES=
# CODESPACE_NAME=
# GITHUB_CODESPACES_PORT_FORWARDING_DOMAIN=
# DEVCONTAINER=

# ============================================
# TESTING CONFIGURATION
# ============================================
# Test database URL (only for testing)
# TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/contract_intelligence_test

# Test tenant ID
# TEST_TENANT_ID=test-tenant

# ============================================
# NOTES
# ============================================
# 1. Never commit this file with real credentials
# 2. Use strong, unique passwords for production
# 3. Rotate secrets regularly
# 4. Use environment-specific values
# 5. Enable all security features in production
# 6. Monitor logs for suspicious activity
# 7. Keep backups in a secure location
# 8. Test disaster recovery procedures

# ============================================
# REQUIRED VARIABLES
# ============================================
# The following variables MUST be set:
# - DATABASE_URL
# - OPENAI_API_KEY
# - JWT_SECRET
# - SESSION_SECRET

# ============================================
# OPTIONAL VARIABLES
# ============================================
# The following variables are optional but recommended:
# - REDIS_URL (for caching and events)
# - CHROMA_URL (for RAG system)
# - AWS_S3_BUCKET (for cloud storage)
# - SMTP_* (for email notifications)
# - SENTRY_DSN (for error tracking)

# ============================================
# QUICK START
# ============================================
# 1. Copy this file: cp .env.production.example .env
# 2. Update DATABASE_URL with your PostgreSQL connection
# 3. Add your OPENAI_API_KEY
# 4. Generate strong secrets for JWT_SECRET and SESSION_SECRET
# 5. Configure Redis and Chroma DB URLs
# 6. Review and enable desired features
# 7. Test with: npm run dev
# 8. Deploy to production

# ============================================
# SUPPORT
# ============================================
# For help with configuration:
# - See README.md
# - See SETUP.md
# - See documentation in /docs
# - Contact: support@yourcompany.com
