#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Prevent committing secrets
echo "🔍 Checking for secrets..."

# Check for API keys patterns
if git diff --cached --name-only | xargs grep -l -E "(sk-[a-zA-Z0-9]{20,}|sk-proj-[a-zA-Z0-9]{20,}|sk-ant-[a-zA-Z0-9]{20,}|AKIA[0-9A-Z]{16})" 2>/dev/null; then
  echo "❌ ERROR: Potential API key detected in staged files!"
  echo "Please remove the API key and use environment variables instead."
  exit 1
fi

# Check for common secret patterns in specific file types
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E "\.(ts|tsx|js|jsx|json|env|yaml|yml)$" || true)

if [ -n "$STAGED_FILES" ]; then
  for FILE in $STAGED_FILES; do
    # Skip node_modules and build directories
    if echo "$FILE" | grep -qE "node_modules|dist|build|\.next"; then
      continue
    fi
    
    # Check for hardcoded secrets
    if git show ":$FILE" 2>/dev/null | grep -E "(OPENAI_API_KEY|ANTHROPIC_API_KEY|AWS_SECRET|DATABASE_URL).*=.*['\"][^'\"]{10,}['\"]" | grep -v "process\.env\|env\(" > /dev/null 2>&1; then
      echo "❌ ERROR: Potential hardcoded secret in $FILE"
      echo "Please use environment variables instead."
      exit 1
    fi
  done
fi

echo "✅ No secrets detected"

# Run linting on staged files (optional - comment out if too slow)
# pnpm lint-staged
