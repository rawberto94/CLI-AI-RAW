{
  "name": "@repo/workers",
  "version": "1.0.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "build:bundle": "tsup",
    "dev": "NODE_OPTIONS=\"--max-old-space-size=8192\" tsx watch src/index.ts",
    "start": "NODE_OPTIONS=\"--max-old-space-size=8192\" tsx src/index.ts",
    "start:bundle": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.701.0",
    "@mistralai/mistralai": "^1.10.0",
    "bullmq": "^4.18.3",
    "clients-db": "workspace:*",
    "data-orchestration": "workspace:*",
    "dotenv": "^16.3.1",
    "ioredis": "^5.3.2",
    "openai": "^4.10.0",
    "pino": "^8.15.1",
    "pino-pretty": "^13.1.1",
    "utils": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@types/pdf-parse": "^1.1.5",
    "tsup": "^8.5.1",
    "tsx": "^4.7.0",
    "typescript": "^5.2.2"
  }
}
