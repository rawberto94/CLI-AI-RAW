{
  "name": "@repo/agents",
  "version": "0.1.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./autonomous-orchestrator": {
      "types": "./dist/autonomous-orchestrator.d.ts",
