{
  "name": "data-orchestration",
  "version": "1.0.0",
  "description": "Unified data orchestration layer for Contract Intelligence Platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@langchain/community": "^0.0.25",
    "@langchain/openai": "^0.0.19",
    "@prisma/client": "^5.22.0",
    "chromadb": "^1.7.3",
    "clients-db": "workspace:*",
    "clients-storage": "workspace:*",
    "ioredis": "^5.3.0",
    "langchain": "^0.1.0",
    "pino": "^8.21.0",
    "pino-pretty": "^13.1.2",
    "redis": "^4.6.0",
    "schemas": "workspace:*",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "default": "./dist/services/index.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "default": "./dist/events/index.js"
    }
  }
}
