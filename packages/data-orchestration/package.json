{
  "name": "@repo/data-orchestration",
  "version": "1.0.0",
  "description": "Unified data orchestration layer for Contract Intelligence Platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc || true",
    "dev": "tsc --watch",
    "start": "node api-server.js",
    "api": "node api-server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@langchain/community": "0.2.33",
    "@langchain/core": "^0.2.31",
    "@langchain/openai": "^0.2.8",
    "@prisma/client": "^5.22.0",
    "@upstash/redis": "^1.35.6",
    "chromadb": "^1.7.3",
    "clients-db": "workspace:*",
    "clients-storage": "workspace:*",
    "date-fns": "^4.1.0",
    "ioredis": "^5.3.0",
    "langchain": "^0.2.17",
    "langsmith": "^0.3.78",
    "openai": "^4.10.0",
    "pgvector": "^0.1.8",
    "pino": "^8.21.0",
    "pino-pretty": "^13.1.2",
    "redis": "^4.6.0",
    "schemas": "workspace:*",
    "uuid": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "default": "./dist/services/index.js"
    },
    "./services/knowledge-graph.service": {
      "types": "./dist/services/knowledge-graph.service.d.ts",
      "default": "./dist/services/knowledge-graph.service.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "default": "./dist/events/index.js"
    }
  }
}
