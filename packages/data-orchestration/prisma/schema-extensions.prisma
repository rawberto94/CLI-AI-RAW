// Essential Database Schema Extensions for Taxonomy & Metadata
// Add these to your main Prisma schema

model TaxonomyCategory {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  parentId    String?
  level       Int      @default(0)
  path        String   // e.g., "legal/contracts/service-agreements"
  color       String   @default("#3B82F6")
  icon        String   @default("folder")
  isActive    Boolean  @default(true)
  
  // Usage tracking
  contractCount Int      @default(0)
  lastUsed      DateTime?
  
  // Audit fields
  createdBy   String
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  parent      TaxonomyCategory? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    TaxonomyCategory[] @relation("CategoryHierarchy")
  contracts   ContractMetadata[]
  
  @@map("taxonomy_categories")
  @@index([tenantId, isActive])
  @@index([tenantId, parentId])
  @@index([path])
}

model TaxonomyTag {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  categoryId  String?
  color       String
  type        TagType  @default(CUSTOM)
  
  // Usage tracking
  contractCount Int      @default(0)
  lastUsed      DateTime?
  trending      Boolean  @default(false)
  
  // Metadata
  aliases     String[] // Alternative names
  relatedTags String[] // Related tag IDs
  
  // Audit fields
  createdBy   String
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isActive    Boolean  @default(true)
  
  // Relations
  category    TaxonomyCategory? @relation(fields: [categoryId], references: [id])
  
  @@map("taxonomy_tags")
  @@index([tenantId, isActive])
  @@index([tenantId, type])
  @@index([name])
}

model MetadataField {
  id           String      @id @default(cuid())
  tenantId     String
  name         String      // Field identifier
  label        String      // Display name
  description  String?
  type         FieldType
  required     Boolean     @default(false)
  category     FieldCategory @default(CUSTOM)
  displayOrder Int         @default(999)
  
  // Validation rules (stored as JSON)
  validation   Json?       // { min, max, pattern, options }
  defaultValue Json?
  
  // Usage tracking
  usageCount   Int         @default(0)
  
  // Audit fields
  createdBy    String
  updatedBy    String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  isActive     Boolean     @default(true)
  
  @@map("metadata_fields")
  @@index([tenantId, isActive])
  @@index([tenantId, category])
  @@unique([tenantId, name])
}

model ContractMetadata {
  id         String   @id @default(cuid())
  contractId String   @unique
  tenantId   String
  
  // Taxonomy
  categoryId String?
  tags       String[] // Tag names for simplicity
  
  // System fields (core contract info)
  systemFields Json    @default("{}")
  
  // Custom fields (user-defined)
  customFields Json    @default("{}")
  
  // Audit fields
  lastUpdated DateTime @default(now())
  updatedBy   String
  createdAt   DateTime @default(now())
  
  // Relations
  contract    Contract         @relation(fields: [contractId], references: [id], onDelete: Cascade)
  category    TaxonomyCategory? @relation(fields: [categoryId], references: [id])
  
  @@map("contract_metadata")
  @@index([tenantId])
  @@index([categoryId])
  @@index([tags])
}

model ContractSearchIndex {
  id         String   @id @default(cuid())
  contractId String   @unique
  tenantId   String
  
  // Searchable content
  content    String   @db.Text
  
  // Metadata for faceted search
  metadata   Json     @default("{}")
  
  // Search vectors (for future semantic search)
  vectors    Json?
  
  // Indexing info
  lastIndexed DateTime @default(now())
  version     String   @default("1.0")
  
  // Relations
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  
  @@map("contract_search_index")
  @@index([tenantId])
  @@index([lastIndexed])
}

// Enums
enum TagType {
  SYSTEM
  CUSTOM
  AUTO_GENERATED
}

enum FieldType {
  TEXT
  NUMBER
  DATE
  SELECT
  MULTI_SELECT
  BOOLEAN
  CURRENCY
  DURATION
}

enum FieldCategory {
  BASIC
  FINANCIAL
  LEGAL
  OPERATIONAL
  CUSTOM
}

// Add to existing Contract model
model Contract {
  // ... existing fields ...
  
  // New relations
  metadata    ContractMetadata?
  searchIndex ContractSearchIndex?
}