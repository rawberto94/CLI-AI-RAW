{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "module": "ESNext",
    "target": "ES2020",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": false,
    "noUncheckedIndexedAccess": false,
    "declaration": true,
    "incremental": false,
    "composite": false
  },
  "include": ["index.ts"],
  "exclude": ["dist", "node_modules", "test"]
}
