  @@index([alertType])
  @@index([severity])
  @@index([status])
  @@index([scheduledFor])
  @@index([tenantId, status])
  @@index([tenantId, alertType])
  @@index([acknowledgedAt])
  @@map("expiration_alerts")
}

model RenewalHistory {
