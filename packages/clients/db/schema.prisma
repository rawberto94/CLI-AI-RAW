/// Contract Draft - Stores in-progress contract generation drafts
model ContractDraft {
  id               String  @id @default(cuid())
  tenantId         String
  templateId       String?
  playbookId       String? @map("playbook_id")
  title            String
  type             String  @default("MSA") // MSA, SOW, NDA, AMENDMENT, RENEWAL
  sourceType       String  @default("NEW") // NEW, TEMPLATE, RENEWAL, AMENDMENT
  sourceContractId String? // For renewals/amendments, reference to original contract

  // Draft content
  content   String? @db.Text
  clauses   Json    @default("[]")
  variables Json    @default("{}")
  structure Json    @default("{}")

  // Status tracking
  status   String    @default("DRAFT") // DRAFT, IN_REVIEW, PENDING_APPROVAL, APPROVED, REJECTED, FINALIZED
  version  Int       @default(1)
  isLocked Boolean   @default(false)
  lockedBy String?
  lockedAt DateTime?

  // Financial details
  estimatedValue    Decimal?  @db.Decimal(15, 2)
  currency          String    @default("USD")
  proposedStartDate DateTime?
  proposedEndDate   DateTime?

  // Parties
  externalParties Json @default("[]") // Array of { name, role, contact }

  // AI Generation metadata
  aiPrompt         String? @db.Text
  aiModel          String?
  generationParams Json?   @default("{}")

  // Workflow
  currentStep       String?
  completionPercent Int     @default(0)
  approvalWorkflow  Json?   @default("[]")

  // Audit
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template       ContractTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  playbook       Playbook?         @relation(fields: [playbookId], references: [id], onDelete: SetNull)
  sourceContract Contract?         @relation("DraftSourceContract", fields: [sourceContractId], references: [id], onDelete: SetNull)
  createdByUser  User?             @relation("DraftCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  // Relations to sub-resources
  comments DraftComment[]
  versions DraftVersion[]

  @@index([tenantId])
  @@index([templateId])
  @@index([playbookId])
  @@index([status])
  @@index([type])
  @@index([sourceType])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([createdAt(sort: Desc)])
  @@map("contract_drafts")
}

/// Draft Comment - Collaborative comments on contract drafts
model DraftComment {
  id       String @id @default(cuid())
  draftId  String
  tenantId String
  userId   String

  content   String  @db.Text
  resolved  Boolean @default(false)
