  parent  DraftComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies DraftComment[] @relation("CommentReplies")

  @@index([draftId])
  @@index([tenantId])
  @@index([userId])
  @@index([parentId])
  @@index([draftId, resolved])
  @@map("draft_comments")
