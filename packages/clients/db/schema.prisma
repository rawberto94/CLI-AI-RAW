// Note: This project uses Prisma 5.x. The datasource URL uses env() which is the
// standard approach for Prisma 5.x. Prisma 7+ requires different configuration.
// If using VS Code Prisma extension with Prisma 7 defaults, you can ignore the warning
// or pin to Prisma 6 mode in extension settings.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Tenant {
  id                      String                   @id @default(cuid())
  name                    String                   @unique
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  slug                    String                   @unique
  status                  TenantStatus             @default(ACTIVE)
  auditLogs               AuditLog[]
  contracts               Contract[]
  templates               ContractTemplate[]
  metrics                 Metric[]
  configuration           TenantConfig?
  subscription            TenantSubscription?
  usage                   TenantUsage?
  users                   User[]
  invitations             TeamInvitation[]
  contractDrafts          ContractDraft[]
  chatConversations       ChatConversation[]
  obligationNotifications ObligationNotification[]
  obligations             Obligation[]
  apiTokens               ApiToken[]

  @@index([status])
  @@index([createdAt])
}

// Team invitation for multi-tenant user onboarding
model TeamInvitation {
  id         String           @id @default(cuid())
  tenantId   String
  email      String
  role       String           @default("member")
  token      String           @unique
  status     InvitationStatus @default(PENDING)
  invitedBy  String?
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([email])
  @@index([tenantId])
  @@index([status])
  @@index([expiresAt])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model TenantConfig {
  id                 String   @id @default(cuid())
  tenantId           String   @unique
  aiModels           Json     @default("{}")
  aiCostBudget       Decimal? @db.Decimal(10, 2)
  aiCostAlerts       Boolean  @default(true)
  securitySettings   Json     @default("{}")
  integrations       Json     @default("{}")
  workflowSettings   Json     @default("{}")
  // AI Extraction Configuration
  extractionSettings Json     @default("{\"contractTypeConfidenceThreshold\": 0.75, \"autoApplyContractType\": true, \"gapFillingCompletenessThreshold\": 0.85, \"alwaysRunGapFilling\": false, \"aggressiveGapFilling\": true, \"ocrProvider\": \"openai\", \"preferredModel\": \"gpt-4o-mini\"}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// Tenant-level custom settings storage (for data connections, preferences, etc.)
model TenantSettings {
  id           String   @id @default(cuid())
  tenantId     String
  customFields Json?    @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
}

// IP Allowlist for tenant security
model IpAllowlist {
  id          String    @id @default(cuid())
  tenantId    String
  ipAddress   String // IP address or CIDR range
  description String?
  isActive    Boolean   @default(true)
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  expiresAt   DateTime?

  @@unique([tenantId, ipAddress])
  @@index([tenantId])
  @@index([isActive])
  @@map("ip_allowlist")
}

// Tenant Security Settings
model TenantSecuritySettings {
  id                     String   @id @default(cuid())
  tenantId               String   @unique
  mfaRequired            Boolean  @default(false)
  sessionTimeout         Int      @default(480) // minutes
  passwordPolicy         Json     @default("{\"minLength\": 8, \"requireUppercase\": true, \"requireLowercase\": true, \"requireNumbers\": true, \"requireSpecialChars\": false}")
  ipAllowlistEnabled     Boolean  @default(false)
  allowedLoginMethods    String[] @default(["email", "google"])
  maxFailedLoginAttempts Int      @default(5)
  lockoutDuration        Int      @default(15) // minutes
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("tenant_security_settings")
}

model TenantSubscription {
  id           String             @id @default(cuid())
  tenantId     String             @unique
  plan         SubscriptionPlan
  status       SubscriptionStatus
  startDate    DateTime
  endDate      DateTime?
  billingCycle BillingCycle
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([endDate])
}

model TenantUsage {
  id                   String   @id @default(cuid())
  tenantId             String   @unique
  contractsProcessed   Int      @default(0)
  aiTokensUsed         BigInt   @default(0)
  storageUsed          BigInt   @default(0)
  apiCallsCount        Int      @default(0)
  monthlyContractLimit Int?
  monthlyTokenLimit    BigInt?
  monthlyStorageLimit  BigInt?
  monthlyApiLimit      Int?
  resetDate            DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([resetDate])
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  avatar        String?
  emailVerified Boolean    @default(false)
  firstName     String?
  lastLoginAt   DateTime?
  lastName      String?
  passwordHash  String? // Nullable for SSO-only users
  status        UserStatus @default(ACTIVE)
  tenantId      String
  role          String     @default("user") // Added for auth compatibility

  // MFA fields
  mfaEnabled            Boolean   @default(false)
  mfaSecret             String? // Encrypted TOTP secret
  mfaBackupCodes        String[]  @default([]) // Hashed backup codes
  mfaPendingSecret      String? // Temporary secret during setup
  mfaPendingBackupCodes String[]  @default([]) // Temporary codes during setup
  mfaEnabledAt          DateTime?

  auditLogs           AuditLog[]
  tenant              Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roles               UserRole[]
  sessions            UserSession[]
  preferences         UserPreferences?
  onboardingAnalytics OnboardingAnalytics[]
  backgroundJobs      BackgroundJob[]
  helpAnalytics       HelpAnalytics[]
  widgetAnalytics     WidgetAnalytics[]
  rateCardSegments    RateCardSegment[]
  uploadedVersions    ContractVersion[]     @relation("VersionUploader")
  createdDrafts       ContractDraft[]       @relation("DraftCreator")
  chatConversations   ChatConversation[]
  departments         UserDepartment[]
  groupMemberships    UserGroupMember[]
  contractAccess      ContractUserAccess[]
  assignedObligations Obligation[]          @relation("ObligationAssignee")
  calendarSyncTokens  CalendarSyncToken[]
  accounts            Account[]
  authSessions        Session[]

  // OCR Review relations
  ocrReviewsAssigned OcrReviewItem[] @relation("OcrReviewAssignee")
  ocrReviewsCreated  OcrReviewItem[] @relation("OcrReviewCreator")

  // Draft collaboration
  draftComments DraftComment[] @relation("DraftCommentAuthor")
  draftVersions DraftVersion[] @relation("DraftVersionAuthor")

  @@index([email])
  @@index([tenantId])
  @@index([status])
}

// NextAuth PrismaAdapter required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  createdAt   DateTime         @default(now())
  description String?
  isSystem    Boolean          @default(false)
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  users       UserRole[]
}

model Permission {
  id         String           @id @default(cuid())
  action     String
  subject    String
  conditions Json?
  roles      RolePermission[]

  @@unique([action, subject])
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  assignedBy String?
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  assignedAt   DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserSession {
  id            String    @id @default(cuid())
  userId        String
  token         String    @unique
  sessionToken  String?   @unique // Alternative session identifier
  refreshToken  String?   @unique
  expiresAt     DateTime
  ipAddress     String?
  userAgent     String?
  location      String? // Geographic location
  deviceType    String? // desktop, mobile, tablet
  lastActive    DateTime  @default(now())
  revokedAt     DateTime?
  revokedReason String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([sessionToken])
  @@index([userId])
  @@index([expiresAt])
  @@index([lastActive])
}

model Contract {
  id          String   @id @default(cuid())
  tenantId    String
  storagePath String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  checksum    String?
  mimeType    String   @map("contentType")

  // Legacy contract type (deprecated - use contractCategoryId)
  contractType String?

  // New Taxonomy Classification
  contractCategoryId String? // References contract_categories.id from taxonomy
  contractSubtype    String? // Specific subtype from taxonomy
  documentRole       String? // Document role from taxonomy
  classificationConf Float? // Classification confidence 0-1
  classificationMeta Json?     @default("{}") // Classification metadata, alternatives, reasoning
  classifiedAt       DateTime?

  effectiveDate  DateTime?
  expirationDate DateTime?
  fileName       String    @map("filename")
  jurisdiction   String?
  lastAnalyzedAt DateTime?
  originalName   String?
  processedAt    DateTime?
  searchMetadata Json?     @default("{}")
  metadata       Json?     @default("{}") // General metadata storage
  aiMetadata     Json?     @default("{}") // AI-generated metadata

  // Contract Tags (from taxonomy dimensions)
  pricingModels   Json?                    @default("[]") // Array of pricing_model values
  deliveryModels  Json?                    @default("[]") // Array of delivery_model values
  dataProfiles    Json?                    @default("[]") // Array of data_profile values
  riskFlags       Json?                    @default("[]") // Array of risk_flag values
  fileSize        BigInt                   @map("size")
  storageProvider String?                  @default("local")
  uploadedBy      String?
  status          ContractStatus           @default(PROCESSING)
  uploadedAt      DateTime                 @default(now())
  rawText         String?
  startDate       DateTime?
  endDate         DateTime?
  totalValue      Decimal?                 @db.Decimal(15, 2)
  currency        String?
  clientId        String?
  supplierId      String?
  category        String?
  clientName      String?
  contractTitle   String?
  description     String?
  keywords        Json?
  lastViewedAt    DateTime?
  lastViewedBy    String?
  searchableText  String?
  supplierName    String?
  tags            Json?                    @default("[]")
  textVector      Unsupported("tsvector")?
  viewCount       Int                      @default(0)

  // Soft Delete Support
  deletedAt DateTime?
  deletedBy String?
  isDeleted Boolean   @default(false)

  // Procurement Classification
  procurementCategoryId String?
  categoryL1            String?
  categoryL2            String?
  spendType             String? @default("INDIRECT")

  // Financial Breakdown
  annualValue      Decimal? @db.Decimal(15, 2)
  monthlyValue     Decimal? @db.Decimal(15, 2)
  paymentTerms     String? // Net30, Net60, Net90, etc.
  paymentFrequency String? // MONTHLY, QUARTERLY, ANNUALLY, ONE_TIME
  billingCycle     String? // ADVANCE, ARREARS

  // Renewal & Expiration Tracking
  renewalTerms        Json? // { periods: 2, duration: 12, noticeDays: 90 }
  terminationClause   String?   @db.Text
  noticePeriodDays    Int?
  autoRenewalEnabled  Boolean   @default(false)
  renewalStatus       String?   @default("PENDING") // PENDING, UPCOMING, INITIATED, IN_PROGRESS, COMPLETED, DECLINED, EXPIRED
  renewalInitiatedAt  DateTime?
  renewalInitiatedBy  String?
  renewalCompletedAt  DateTime?
  renewalNotes        String?   @db.Text
  expirationAlertSent Boolean   @default(false)
  expirationAlertAt   DateTime?

  // Expiration Status (computed/tracked)
  isExpired       Boolean   @default(false)
  expiredAt       DateTime?
  daysUntilExpiry Int? // Cached for performance, updated by job
  expirationRisk  String?   @default("LOW") // LOW, MEDIUM, HIGH, CRITICAL, EXPIRED

  // Source Tracking
  importSource   String? // UPLOAD, GOOGLE_DRIVE, SHAREPOINT, EMAIL, API, OCR
  externalId     String? // ID from source system
  externalUrl    String? // Link to source document
  sourceMetadata Json? // Source-specific data
  importedAt     DateTime?
  lastSyncedAt   DateTime?

  // OCR Provider Tracking
  ocrProvider    String? // openai, azure-ch, azure-di-layout, azure-di-contract, azure-di-invoice, mistral, tesseract
  ocrModel       String? // e.g. prebuilt-layout, prebuilt-contract, prebuilt-invoice, gpt-4o
  ocrProcessedAt DateTime? // When OCR was last run

  // Contract Hierarchy (Parent-Child Relationships)
  parentContractId String? // Reference to parent contract (e.g., MSA for a SoW)
  parentContract   Contract?  @relation("ContractHierarchy", fields: [parentContractId], references: [id])
  childContracts   Contract[] @relation("ContractHierarchy")

  // Relationship metadata
  relationshipType String? // SOW_UNDER_MSA, AMENDMENT, ADDENDUM, RENEWAL, CHANGE_ORDER
  relationshipNote String?   @db.Text
  linkedAt         DateTime? // When the link was established

  // Signature & Document Classification
  signatureStatus               String?   @default("unknown") // signed, partially_signed, unsigned, unknown
  signatureDate                 DateTime? // Date of final execution
  signatureRequiredFlag         Boolean   @default(false) // Flag for contracts needing signature attention
  documentClassification        String?   @default("contract") // contract, purchase_order, invoice, quote, proposal, etc.
  documentClassificationConf    Float? // Classification confidence 0-1
  documentClassificationWarning String? // Warning message if not a proper contract

  artifacts           Artifact[]
  clauses             Clause[]
  client              Party?                   @relation("ClientContracts", fields: [clientId], references: [id])
  supplier            Party?                   @relation("SupplierContracts", fields: [supplierId], references: [id])
  tenant              Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  procurementCategory ProcurementCategory?     @relation("ContractProcurementCategory", fields: [procurementCategoryId], references: [id])
  contractArtifacts   ContractArtifact[]
  contractEmbeddings  ContractEmbedding[]
  contractMetadata    ContractMetadata?
  versions            ContractVersion[]
  sourceRelationships ContractRelationship[]   @relation("SourceRelationships")
  targetRelationships ContractRelationship[]   @relation("TargetRelationships")
  alerts              ContractAlert[]
  embeddings          Embedding[]
  financialAnalysis   FinancialAnalysis[]
  overviewAnalysis    OverviewAnalysis[]
  processingJobs      ProcessingJob[]
  runs                Run[]
  templateAnalysis    TemplateAnalysis[]
  costSavings         CostSavingsOpportunity[]
  rateCardEntries     RateCardEntry[]
  workflowExecutions  WorkflowExecution[]
  signatureRequests   SignatureRequest[]
  legalReviews        LegalReview[]
  sourcedDrafts       ContractDraft[]          @relation("DraftSourceContract")
  obligations         Obligation[]

  // Extraction corrections relation
  extractionCorrections ExtractionCorrection[]

  // Synced files relation (for pull model integrations)
  syncedFiles SyncedFile[]

  // Access control relations
  userAccess         ContractUserAccess[]
  groupAccess        ContractGroupAccess[]
  collaboratorAccess CollaboratorContractAccess[]

  // OCR Review relation
  ocrReviewItems OcrReviewItem[]

  @@index([tenantId])
  @@index([status])
  @@index([contractType]) // Legacy index
  @@index([contractCategoryId]) // New taxonomy index
  @@index([documentRole])
  @@index([createdAt])
  @@index([startDate, endDate])
  @@index([clientId])
  @@index([supplierId])
  @@index([clientName])
  @@index([supplierName])
  @@index([category])
  @@index([procurementCategoryId])
  @@index([categoryL1])
  @@index([categoryL2])
  @@index([tenantId, status])
  @@index([tenantId, contractType]) // Legacy
  @@index([tenantId, contractCategoryId]) // New taxonomy
  @@index([tenantId, documentRole])
  @@index([tenantId, clientName])
  @@index([tenantId, supplierName])
  @@index([tenantId, categoryL1, categoryL2])
  // Enhanced indexes for better sorting and filtering
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, uploadedAt(sort: Desc)])
  @@index([tenantId, totalValue(sort: Desc)])
  @@index([tenantId, expirationDate])
  @@index([tenantId, effectiveDate])
  @@index([tenantId, status, createdAt(sort: Desc)])
  @@index([tenantId, contractType, createdAt(sort: Desc)]) // Legacy
  @@index([tenantId, contractCategoryId, createdAt(sort: Desc)]) // New taxonomy
  @@index([tenantId, category, createdAt(sort: Desc)])
  @@index([uploadedAt(sort: Desc)])
  @@index([totalValue(sort: Desc)])
  @@index([expirationDate])
  @@index([effectiveDate])
  @@index([viewCount(sort: Desc)])
  @@index([lastViewedAt(sort: Desc)])
  @@index([checksum])
  // Soft delete & full-text search indexes
  @@index([tenantId, isDeleted])
  @@index([tenantId, isDeleted, status])
  @@index([tenantId, isDeleted, createdAt(sort: Desc)])
  @@index([deletedAt])
  // Renewal & Expiration indexes
  @@index([renewalStatus])
  @@index([tenantId, renewalStatus])
  @@index([tenantId, isExpired])
  @@index([tenantId, expirationRisk])
  @@index([tenantId, daysUntilExpiry])
  @@index([autoRenewalEnabled])
  // Contract Hierarchy indexes
  @@index([parentContractId])
  @@index([tenantId, parentContractId])
  @@index([relationshipType])
  @@index([tenantId, relationshipType])
  @@index([renewalInitiatedAt])
  @@index([importSource])
  @@index([externalId])
  // Signature & Document Classification indexes
  @@index([signatureStatus])
  @@index([documentClassification])
  @@index([tenantId, signatureStatus])
  @@index([tenantId, documentClassification])
  @@index([tenantId, signatureStatus, documentClassification])
  // === SCALABILITY INDEXES ===
  // Multi-column composite indexes for complex dashboard queries
  @@index([tenantId, status, totalValue(sort: Desc)])
  @@index([tenantId, status, expirationDate])
  @@index([tenantId, category, status, createdAt(sort: Desc)])
  @@index([tenantId, clientName, status])
  @@index([tenantId, supplierName, status])
  // Indexes for time-series analytics
  @@index([tenantId, uploadedAt, status])
  @@index([tenantId, effectiveDate, expirationDate])
  @@index([tenantId, createdAt, totalValue])
  // Indexes for comparison queries (group comparisons)
  @@index([tenantId, clientName, category, createdAt])
  @@index([tenantId, supplierName, category, createdAt])
  @@index([tenantId, category, effectiveDate, totalValue])
  // Indexes for search performance
  @@index([tenantId, contractTitle])
  @@index([tenantId, description])
  @@index([tenantId, fileName])
}

// Extraction Corrections for AI Learning Loop
model ExtractionCorrection {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  contractId     String   @map("contract_id")
  fieldName      String   @map("field_name")
  originalValue  String?  @map("original_value") @db.Text
  correctedValue String?  @map("corrected_value") @db.Text
  confidence     Decimal? @db.Decimal(3, 2)
  wasCorrect     Boolean  @default(false) @map("was_correct")
  source         String   @default("ai") // ai, ocr, user
  feedbackType   String   @map("feedback_type") // confirmation, correction, rejection
  contractType   String?  @map("contract_type")
  documentLength Int?     @map("document_length")
  modelUsed      String?  @map("model_used")
  promptVersion  String?  @map("prompt_version")
  metadata       Json?    @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([contractId])
  @@index([fieldName])
  @@index([feedbackType])
  @@index([wasCorrect])
  @@index([contractType])
  @@index([createdAt])
  @@index([tenantId, fieldName])
  @@index([tenantId, contractType, fieldName])
  @@index([tenantId, wasCorrect])
  @@map("extraction_corrections")
}

model ContractMetadata {
  id           String   @id @default(cuid())
  contractId   String   @unique
  tenantId     String
  categoryId   String?
  tags         String[]
  systemFields Json     @default("{}")
  customFields Json     @default("{}")
  lastUpdated  DateTime @default(now())
  updatedBy    String
  createdAt    DateTime @default(now())

  // Enhanced fields for artifact repository
  artifactSummary    Json?     @default("{}")
  searchKeywords     String[]  @default([])
  relatedContracts   String[]  @default([])
  dataQualityScore   Int?      @default(0)
  indexedAt          DateTime?
  ragSyncedAt        DateTime?
  analyticsUpdatedAt DateTime?

  // Organization & Classification
  priority     Int     @default(0) // 0=normal, 1=low, 2=medium, 3=high, 4=critical
  importance   String? // low, medium, high, critical
  department   String? // Finance, Legal, HR, IT, etc.
  projectCode  String? // For project association
  costCenter   String? // For financial tracking
  businessUnit String? // For organizational structure

  // Lifecycle tracking
  renewalReminder DateTime?
  reviewDate      DateTime?
  archiveDate     DateTime?
  retentionPeriod Int? // Days to retain after expiration

  // Compliance & Audit
  complianceStatus String?   @default("pending") // pending, compliant, non-compliant, needs-review
  lastAuditDate    DateTime?
  nextAuditDate    DateTime?
  auditNotes       String?

  // Analytics
  riskScore       Int? @default(0) // 0-100
  valueScore      Int? @default(0) // 0-100 importance/value score
  complexityScore Int? @default(0) // 0-100
  accessCount     Int  @default(0)

  // Renewal Tracking (extended)
  renewalPriority      String?   @default("NORMAL") // LOW, NORMAL, HIGH, CRITICAL
  renewalOwner         String? // User ID responsible for renewal
  renewalDeadline      DateTime? // Internal deadline before contract expires
  renewalChecklistDone Boolean   @default(false)
  renewalChecklist     Json?     @default("[]") // { item: string, done: boolean, doneAt: DateTime }[]
  lastRenewalDate      DateTime?
  renewalCount         Int       @default(0) // How many times renewed

  // Negotiation Tracking
  negotiationStatus    String? // DRAFT, IN_NEGOTIATION, PENDING_SIGNATURE, EXECUTED, TERMINATED
  negotiationStartedAt DateTime?
  negotiationRound     Int       @default(0)
  negotiationNotes     String?   @db.Text
  lastNegotiatedBy     String?
  lastNegotiatedAt     DateTime?

  // Performance Tracking
  performanceScore  Int?      @default(0) // 0-100 based on SLA compliance
  slaComplianceRate Decimal?  @db.Decimal(5, 2) // Percentage
  issueCount        Int       @default(0)
  activeIssues      Int       @default(0)
  resolvedIssues    Int       @default(0)
  lastIssueAt       DateTime?
  performanceNotes  String?   @db.Text

  // AI/RAG Metadata
  aiSummary         String?   @db.Text // Cached AI-generated summary
  aiKeyInsights     Json?     @default("[]") // Key points extracted by AI
  aiRiskFactors     Json?     @default("[]") // AI-identified risks
  aiRecommendations Json?     @default("[]") // AI suggestions
  lastAiAnalysis    DateTime?
  aiAnalysisVersion String? // Model version used
  embeddingVersion  String? // Track embedding model version
