model OutlierFlag {
  id              String @id @default(cuid())
  rateCardEntryId String @unique @map("rate_card_entry_id")
  tenantId        String @map("tenant_id")

  // Outlier Detection
  outlierType       String  @map("outlier_type") // HIGH, LOW
  deviationSigma    Decimal @map("deviation_sigma") @db.Decimal(10, 4)
  marketMean        Decimal @map("market_mean") @db.Decimal(10, 2)
  marketMedian      Decimal @map("market_median") @db.Decimal(10, 2)
  standardDeviation Decimal @map("standard_deviation") @db.Decimal(10, 2)
  severity          String // EXTREME, MODERATE, MILD

  // Review Status
  reviewStatus String    @default("PENDING") @map("review_status") // PENDING, REVIEWED, RESOLVED, DISMISSED
  reviewedBy   String?   @map("reviewed_by")
  reviewedAt   DateTime? @map("reviewed_at")
  reviewAction String?   @map("review_action")
  reviewNotes  String?   @map("review_notes")

  // Resolution
  resolvedBy String?   @map("resolved_by")
  resolvedAt DateTime? @map("resolved_at")
  resolution String?

  // Timestamps
  detectedAt DateTime @default(now()) @map("detected_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

