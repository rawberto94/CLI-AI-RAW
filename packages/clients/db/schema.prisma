}

model PushSubscription {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  userId   String @map("user_id")

  // Web Push subscription data
  endpoint       String  @unique
  p256dh         String  @map("p256dh_key") // Public key
  auth           String  @map("auth_key") // Auth secret
  expirationTime BigInt? @map("expiration_time") // Subscription expiration timestamp

  // Device info
  userAgent  String? @map("user_agent")
  deviceName String? @map("device_name")

  // Status
  isActive Boolean   @default(true) @map("is_active")
  lastUsed DateTime? @map("last_used")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([userId])
  @@index([isActive])
  @@map("push_subscriptions")
}

// ============================================
// AI Episodic Memory (Long-term conversational memory)
// ============================================

model AiMemory {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  userId   String @map("user_id")

  // Memory content
  type       String // insight, preference, fact, decision, interaction
  content    String   @db.Text
  context    String?  @db.Text
  tags       String[] @default([])
  importance Float    @default(0.5)

  // Memory metadata
  sourceConversationId String?                      @map("source_conversation_id")
  embedding            Unsupported("vector(1024)")? // For semantic retrieval

  // Timestamps
  lastAccessedAt DateTime @default(now()) @map("last_accessed_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([userId])
  @@index([type])
  @@index([importance])
  @@index([lastAccessedAt])
  @@map("ai_memories")
}

// ============================================
// Contract Analysis (Multi-modal vision analysis results)
// ============================================

model ContractAnalysis {
  id         String @id @default(cuid())
  contractId String @map("contract_id")
  tenantId   String @map("tenant_id")
  pageNumber Int    @map("page_number")

  // Extracted content
  extractedText String? @map("extracted_text") @db.Text
  tables        String? @db.Text // JSON string of extracted tables
  signatures    String? @db.Text // JSON string of detected signatures
  layout        String? @db.Text // JSON string of document layout
  entities      String? @db.Text // JSON string of extracted entities

  // Analysis metadata
  analysisType     String @default("multimodal_vision") @map("analysis_type")
  confidence       Float  @default(0.0)
  processingTimeMs Int    @default(0) @map("processing_time_ms")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([contractId, pageNumber])
  @@index([contractId])
  @@index([tenantId])
  @@index([analysisType])
  @@map("contract_analyses")
}

// ============================================
// GDPR Data Subject Rights Models
// ============================================

/// Data Export Request - Tracks GDPR data export (Right to Access) requests
model DataExportRequest {
  id       String            @id @default(cuid())
  tenantId String            @map("tenant_id")
  userId   String            @map("user_id")
  status   GdprRequestStatus @default(PENDING)
  format   String            @default("json") // json, csv

  // Options
  includeContracts Boolean @default(true) @map("include_contracts")
  includeActivity  Boolean @default(true) @map("include_activity")
  includeChats     Boolean @default(true) @map("include_chats")

  // Result
  downloadUrl String?   @map("download_url")
  expiresAt   DateTime? @map("expires_at")
  fileSize    BigInt?   @map("file_size")

  // Processing
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  error       String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("data_export_requests")
}

/// Deletion Request - Tracks GDPR account deletion (Right to Erasure) requests
model DeletionRequest {
  id       String                @id @default(cuid())
  tenantId String                @map("tenant_id")
  userId   String                @map("user_id")
  status   DeletionRequestStatus @default(PENDING)

  // Request details
  reason            String?
  confirmationToken String?   @unique @map("confirmation_token")
  scheduledFor      DateTime  @map("scheduled_for")
  gracePeriodEnds   DateTime? @map("grace_period_ends")

  // Processing
  cancelledAt  DateTime? @map("cancelled_at")
  cancelReason String?   @map("cancel_reason")
  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  error        String?

  // Audit
  deletedData Json? @map("deleted_data") // Summary of what was deleted

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([scheduledFor])
  @@index([confirmationToken])
  @@map("deletion_requests")
}

enum GdprRequestStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum DeletionRequestStatus {
  PENDING
  SCHEDULED
  PROCESSING
  COMPLETED
  CANCELLED
  FAILED
}

// ============================================================================
// AI ANALYTICS & MONITORING MODELS
// ============================================================================

/// AI Usage Log - Tracks all AI API calls for analytics
model AIUsageLog {
  id         String  @id @default(cuid())
  tenantId   String? @map("tenant_id")
  userId     String? @map("user_id")
  contractId String? @map("contract_id")

  // Request details
  model    String
  endpoint String
  feature  String

  // Token usage
  inputTokens  Int @map("input_tokens")
  outputTokens Int @map("output_tokens")
  totalTokens  Int @map("total_tokens")

  // Performance
  latencyMs Int   @map("latency_ms")
  cost      Float @default(0)

  // Status
  success   Boolean @default(true)
  errorType String? @map("error_type")

  // Metadata
  metadata String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([userId])
  @@index([model])
  @@index([endpoint])
  @@index([feature])
  @@index([createdAt])
  @@map("ai_usage_logs")
}

/// Webhook Config - Stores webhook configurations for notifications
model WebhookConfig {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  url         String
  secret      String // HMAC secret for webhook signature verification
  events      String[] // Array of event types
  isActive    Boolean  @default(true) @map("is_active")
  description String?

  // Delivery tracking
  failureCount   Int       @default(0) @map("failure_count")
  lastDeliveryAt DateTime? @map("last_delivery_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  logs WebhookLog[]

  @@index([tenantId])
  @@index([isActive])
  @@map("webhook_configs")
}

/// Webhook Log - Tracks webhook delivery attempts
model WebhookLog {
  id         String  @id @default(cuid())
  webhookId  String  @map("webhook_id")
  event      String
  success    Boolean
  statusCode Int?    @map("status_code")

  createdAt DateTime @default(now()) @map("created_at")

  webhook WebhookConfig @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([event])
  @@index([createdAt])
  @@map("webhook_logs")
}

/// Cost Threshold - Stores cost alert thresholds per tenant
model CostThreshold {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  period        String // daily, weekly, monthly
  threshold     Float
  enabled       Boolean   @default(true)
  notifyEmail   String?   @map("notify_email")
  notifyWebhook Boolean   @default(true) @map("notify_webhook")
  lastAlertAt   DateTime? @map("last_alert_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, period])
  @@index([tenantId])
  @@map("cost_thresholds")
}

/// Cost Alert - Records cost alert events
model CostAlert {
  id           String  @id @default(cuid())
  tenantId     String  @map("tenant_id")
  type         String // threshold_exceeded, unusual_spike, budget_warning
  currentCost  Float   @map("current_cost")
  threshold    Float?
  period       String
  message      String  @db.Text
  acknowledged Boolean @default(false)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([type])
  @@index([acknowledged])
  @@index([createdAt])
  @@map("cost_alerts")
}

/// A/B Test - Stores A/B test configurations
model ABTest {
  id          String  @id @default(cuid())
  tenantId    String? @map("tenant_id")
  name        String
  description String? @db.Text
  modelA      String  @map("model_a")
  modelB      String  @map("model_b")
  promptType  String  @map("prompt_type")
  active      Boolean @default(true)

  // Results
  runsCount Int @default(0) @map("runs_count")
  winsA     Int @default(0) @map("wins_a")
  winsB     Int @default(0) @map("wins_b")
  ties      Int @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  results ABTestResult[]

  @@index([tenantId])
  @@index([active])
  @@map("ab_tests")
}

/// A/B Test Result - Individual model comparison results (head-to-head A vs B)
model ABTestResult {
  id     String  @id @default(cuid())
  testId String  @map("test_id")
  userId String? @map("user_id")

  // Inputs
  prompt String @db.Text

  // Outputs
  responseA String? @map("response_a") @db.Text
  responseB String? @map("response_b") @db.Text
  latencyA  Int?    @map("latency_a")
  latencyB  Int?    @map("latency_b")
  tokensA   Int?    @map("tokens_a")
  tokensB   Int?    @map("tokens_b")

  // Rating
  winner   String? // 'a', 'b', 'tie'
  rating   Int? // 1-5 stars
  feedback String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  test ABTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([testId])
  @@index([userId])
  @@index([winner])
  @@index([createdAt])
  @@map("ab_test_comparison_results")
}

// ============================================================================
// USER MANAGEMENT - Groups, Departments, and External Collaborators
// ============================================================================

/// User Group - Organize users into teams/groups with shared permissions
model UserGroup {
  id                  String   @id @default(cuid())
  tenantId            String   @map("tenant_id")
  name                String
  description         String?  @db.Text
  color               String   @default("#8B5CF6") // Hex color for UI (violet)
  permissions         Json     @default("{}") // Group-level permissions
  departmentAccess    String[] @default([]) // Department IDs this group can access
  contractAccessLevel String   @default("assigned") // all, assigned, department, none
  isSystem            Boolean  @default(false) @map("is_system")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  createdBy           String?  @map("created_by")

  members        UserGroupMember[]
  contractAccess ContractGroupAccess[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([isSystem])
  @@map("user_groups")
}

/// User Group Member - Junction table for user-group relationships
model UserGroupMember {
  id       String   @id @default(cuid())
  groupId  String   @map("group_id")
  userId   String   @map("user_id")
  role     String   @default("member") // leader, member
  joinedAt DateTime @default(now()) @map("joined_at")
  addedBy  String?  @map("added_by")

  group UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId])
  @@index([userId])
  @@map("user_group_members")
}

/// Department - Organizational departments for access control
model Department {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  name          String
  description   String?  @db.Text
  parentId      String?  @map("parent_id") // For hierarchical departments
  contractTypes String[] @default([]) @map("contract_types") // Types this dept can access
  accessRules   Json     @default("{}") @map("access_rules") // Additional access rules
  isSystem      Boolean  @default(false) @map("is_system")
  color         String   @default("#8B5CF6") // UI display color (violet)
  icon          String   @default("folder") // UI display icon
  createdById   String?  @map("created_by_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  parent   Department?      @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children Department[]     @relation("DepartmentHierarchy")
  members  UserDepartment[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([parentId])
  @@index([isSystem])
  @@map("departments")
}

/// User Department - Junction table for user-department relationships
model UserDepartment {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  departmentId String   @map("department_id")
  isPrimary    Boolean  @default(false) @map("is_primary")
  accessLevel  String   @default("member") // admin, manager, member, viewer
  assignedAt   DateTime @default(now()) @map("assigned_at")
  assignedBy   String?  @map("assigned_by")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([userId, departmentId])
  @@index([userId])
  @@index([departmentId])
  @@map("user_departments")
}

/// Contract User Access - Per-contract user permissions
model ContractUserAccess {
  id          String    @id @default(cuid())
  contractId  String    @map("contract_id")
  userId      String    @map("user_id")
  accessLevel String    @map("access_level") // view, edit, manage, admin
  grantedAt   DateTime  @default(now()) @map("granted_at")
  grantedBy   String?   @map("granted_by")
  expiresAt   DateTime? @map("expires_at")
  notes       String?   @db.Text

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, userId])
  @@index([contractId])
  @@index([userId])
  @@index([expiresAt])
  @@map("contract_user_access")
}

/// Contract Group Access - Per-contract group permissions
model ContractGroupAccess {
  id          String    @id @default(cuid())
  contractId  String    @map("contract_id")
  groupId     String    @map("group_id")
  accessLevel String    @map("access_level") // view, edit, manage, admin
  grantedAt   DateTime  @default(now()) @map("granted_at")
  grantedBy   String?   @map("granted_by")
  expiresAt   DateTime? @map("expires_at")

  group    UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  contract Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, groupId])
  @@index([contractId])
  @@index([groupId])
  @@index([expiresAt])
  @@map("contract_group_access")
}

/// External Collaborator - External parties with limited access
model ExternalCollaborator {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  email        String
  name         String?
  organization String?
  company      String? // Alias for organization (compatibility)
  type         String    @default("client") // client, vendor, partner, consultant, auditor
  accessToken  String    @unique @map("access_token")
  status       String    @default("pending") // pending, active, expired, revoked
  permissions  Json      @default("{}") // canView, canDownload, canComment
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  lastAccessAt DateTime? @map("last_access_at")
  invitedBy    String    @map("invited_by")
  invitedAt    DateTime  @default(now()) @map("invited_at") // Alias for createdAt
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  contractAccess CollaboratorContractAccess[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([accessToken])
  @@index([status])
  @@index([expiresAt])
  @@map("external_collaborators")
}

/// Collaborator Contract Access - Links collaborators to specific contracts
model CollaboratorContractAccess {
  id             String   @id @default(cuid())
  collaboratorId String   @map("collaborator_id")
  contractId     String   @map("contract_id")
  accessLevel    String   @default("view") // view, comment, download
  grantedAt      DateTime @default(now()) @map("granted_at")

  collaborator ExternalCollaborator @relation(fields: [collaboratorId], references: [id], onDelete: Cascade)
  contract     Contract             @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([collaboratorId, contractId])
  @@index([collaboratorId])
  @@index([contractId])
  @@map("collaborator_contract_access")
}

/// OCR Review Queue Item - Documents flagged for human review
model OcrReviewItem {
  id            String @id @default(cuid())
  tenantId      String @map("tenant_id")
  contractId    String @map("contract_id")
  type          String @default("ocr_quality") // ocr_quality, handwriting, mixed_language, legal_entity, sensitive_content
  status        String @default("pending") // pending, in_progress, completed, escalated
  priority      String @default("medium") // low, medium, high, critical
  ocrConfidence Float  @map("ocr_confidence")

  // Document info
  documentName String  @map("document_name")
  documentType String? @map("document_type")

  // Low confidence regions
  lowConfidenceRegions Json? @default("[]") @map("low_confidence_regions")

  // Review tracking
  assignedTo       String?   @map("assigned_to")
  assignedAt       DateTime? @map("assigned_at")
  completedAt      DateTime? @map("completed_at")
  completedBy      String?   @map("completed_by")
  escalatedAt      DateTime? @map("escalated_at")
  escalatedBy      String?   @map("escalated_by")
  escalationReason String?   @map("escalation_reason") @db.Text

  // Corrections made
  corrections Json? @default("[]") // Array of { field, original, corrected, confidence }

  // Metadata
  notes     String?  @db.Text
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  contract      Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  assignedUser  User?    @relation("OcrReviewAssignee", fields: [assignedTo], references: [id])
  createdByUser User?    @relation("OcrReviewCreator", fields: [createdBy], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, priority])
  @@index([contractId])
  @@index([assignedTo])
  @@index([status, priority])
