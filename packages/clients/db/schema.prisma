  threeMonthLower      Decimal @map("three_month_lower") @db.Decimal(10, 2)
  threeMonthUpper      Decimal @map("three_month_upper") @db.Decimal(10, 2)

  sixMonthRate       Decimal @map("six_month_rate") @db.Decimal(10, 2)
  sixMonthConfidence Decimal @map("six_month_confidence") @db.Decimal(5, 2)
