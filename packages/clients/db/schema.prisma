// ============================================
// Contract Source Sync Models (Pull Model)
// ============================================

// Represents a configured contract source for automatic sync
model ContractSource {
  id          String                 @id @default(cuid())
  tenantId    String                 @map("tenant_id")
  name        String
  description String?
  provider    ContractSourceProvider
  status      ContractSourceStatus   @default(DISCONNECTED)
  isActive    Boolean                @default(true) @map("is_active")

  // Connection configuration (encrypted)
  credentials   Json? // Encrypted: API keys, tokens, etc.
  connectionUrl String?  @map("connection_url") // Base URL or endpoint
  syncFolder    String?  @map("sync_folder") // Remote folder/container to sync
  filePatterns  String[] @default(["*.pdf", "*.docx", "*.doc"]) @map("file_patterns")

  // OAuth tokens (for cloud providers)
  accessToken    String?   @map("access_token")
  refreshToken   String?   @map("refresh_token")
  tokenExpiresAt DateTime? @map("token_expires_at")
  scope          String?

  // Account info
  accountEmail String? @map("account_email")
  accountName  String? @map("account_name")

  // Sync configuration
  syncEnabled   Boolean  @default(true) @map("sync_enabled")
  syncInterval  Int      @default(60) @map("sync_interval") // Minutes between syncs
  syncMode      SyncMode @default(INCREMENTAL) @map("sync_mode")
  autoProcess   Boolean  @default(true) @map("auto_process") // Auto-start AI processing
  maxFileSizeMb Int      @default(50) @map("max_file_size_mb")

  // Sync state
  lastSyncAt       DateTime? @map("last_sync_at")
  lastSyncStatus   String?   @map("last_sync_status")
  lastErrorMessage String?   @map("last_error_message")
  lastErrorAt      DateTime? @map("last_error_at")
  syncCursor       String?   @map("sync_cursor") // For incremental sync (delta token, etc.)
  totalFilesSynced Int       @default(0) @map("total_files_synced")
  totalBytesSynced BigInt    @default(0) @map("total_bytes_synced")

  // Audit
  connectedAt DateTime? @map("connected_at")
  connectedBy String?   @map("connected_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  createdBy   String?   @map("created_by")

  // Relations
  syncedFiles SyncedFile[]
  sourceSyncs SourceSync[]

  @@unique([tenantId, provider, syncFolder])
  @@index([tenantId])
  @@index([provider])
  @@index([status])
  @@index([isActive])
  @@index([syncEnabled])
  @@map("contract_sources")
}

// Tracks individual files that have been synced from a source
model SyncedFile {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  sourceId String @map("source_id")

  // Remote file info
  remoteId   String  @map("remote_id") // ID in the remote system
  remotePath String  @map("remote_path") // Full path in remote system
  remoteHash String? @map("remote_hash") // Hash/ETag for change detection
  fileName   String  @map("file_name")
  mimeType   String? @map("mime_type")
  fileSize   BigInt  @map("file_size")

  // Remote timestamps
  remoteCreatedAt  DateTime? @map("remote_created_at")
  remoteModifiedAt DateTime? @map("remote_modified_at")

  // Local processing
  contractId       String?        @map("contract_id")
  processingStatus SyncFileStatus @default(PENDING) @map("processing_status")
  errorMessage     String?        @map("error_message")
  processedAt      DateTime?      @map("processed_at")

  // Sync tracking
  firstSyncedAt DateTime @default(now()) @map("first_synced_at")
  lastSyncedAt  DateTime @default(now()) @map("last_synced_at")
  syncCount     Int      @default(1) @map("sync_count")
  isDeleted     Boolean  @default(false) @map("is_deleted") // Deleted in remote

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  source   ContractSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  contract Contract?      @relation(fields: [contractId], references: [id], onDelete: SetNull)

  @@unique([sourceId, remoteId])
  @@index([tenantId])
  @@index([sourceId])
  @@index([contractId])
  @@index([processingStatus])
  @@index([remoteModifiedAt])
  @@map("synced_files")
}

// Tracks each sync run for a source
model SourceSync {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  sourceId String @map("source_id")

  status      SourceSyncStatus @default(PENDING)
  syncMode    SyncMode
  triggeredBy String?          @map("triggered_by") // SCHEDULER, MANUAL, WEBHOOK

  // Progress tracking
  filesFound       Int    @default(0) @map("files_found")
  filesProcessed   Int    @default(0) @map("files_processed")
  filesSkipped     Int    @default(0) @map("files_skipped")
  filesFailed      Int    @default(0) @map("files_failed")
  bytesTransferred BigInt @default(0) @map("bytes_transferred")

  // Timing
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  duration    Int? // Milliseconds

  // Error handling
  errorMessage String? @map("error_message")
  errorDetails Json?   @map("error_details")

  // Sync state
  syncCursor     String? @map("sync_cursor")
  nextSyncCursor String? @map("next_sync_cursor")

  createdAt DateTime @default(now()) @map("created_at")

  source ContractSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([sourceId])
  @@index([status])
  @@index([startedAt])
  @@map("source_syncs")
}

enum ContractSourceProvider {
  SHAREPOINT
  ONEDRIVE
  GOOGLE_DRIVE
  AZURE_BLOB
  AWS_S3
  SFTP
  FTP
  DROPBOX
  BOX
  SALESFORCE
  SLACK
  POSTGRES
  MYSQL
  MSSQL
  MONGODB
  CUSTOM_API
}

enum ContractSourceStatus {
  CONNECTED
  DISCONNECTED
  SYNCING
  ERROR
  AUTH_EXPIRED
}

enum SyncMode {
  FULL // Re-sync everything
  INCREMENTAL // Only new/changed files
  DELTA // Use provider's delta API if available
}

enum SyncFileStatus {
  PENDING
  DOWNLOADING
  PROCESSING
  COMPLETED
  FAILED
  SKIPPED
}

enum SourceSyncStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// ============================================
// Collaboration Models
// ============================================

model Notification {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
