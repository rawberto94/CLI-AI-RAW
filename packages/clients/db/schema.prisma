  @@index([contractId, type])
  @@index([contractId, tenantId])
  @@index([tenantId, type])
  @@index([tenantId, contractId, createdAt(sort: Desc)])
  @@index([isEdited])
  @@index([validationStatus])
  @@index([lastPropagatedAt])
  @@index([propagationStatus])
  @@index([lastEditedAt])
