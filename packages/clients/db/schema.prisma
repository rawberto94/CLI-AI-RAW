  @@unique([tenantId, name, version])
  @@index([tenantId])
  @@index([category])
  @@index([riskLevel])
  @@index([isStandard])
  @@index([isMandatory])
  @@index([tenantId, category])
  @@index([usageCount(sort: Desc)])
  @@map("clause_library")
}

// ============================================================================
// LEGAL REVIEW & PLAYBOOK MODELS
// ============================================================================

/// Legal playbook for contract review automation
model Playbook {
  id            String  @id @default(cuid())
  tenantId      String  @map("tenant_id")
  name          String
  description   String? @db.Text
  contractTypes Json    @default("[]") @map("contract_types") // MSA, NDA, SOW, etc.
  isDefault     Boolean @default(false) @map("is_default")
  isActive      Boolean @default(true) @map("is_active")
  version       Int     @default(1)

  // Risk thresholds
  criticalCountThreshold   Int @default(2) @map("critical_count_threshold")
  highRiskScoreThreshold   Int @default(70) @map("high_risk_score_threshold")
  acceptableScoreThreshold Int @default(40) @map("acceptable_score_threshold")

  // Preferred language settings (JSON map of category -> preferred text)
  preferredLanguage Json @default("{}") @map("preferred_language")

  createdBy String   @map("created_by")
  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  clauses           PlaybookClause[]
  redFlags          PlaybookRedFlag[]
  fallbackPositions PlaybookFallback[]
  drafts            ContractDraft[]
  reviews           LegalReview[]

  @@unique([tenantId, name, version])
  @@index([tenantId])
  @@index([isDefault])
  @@index([isActive])
  @@index([tenantId, isDefault])
  @@map("playbooks")
}

/// Playbook clause definitions
model PlaybookClause {
  id                  String   @id @default(cuid())
  playbookId          String   @map("playbook_id")
  category            String // liability, indemnification, termination, etc.
  name                String
  preferredText       String   @map("preferred_text") @db.Text
  minimumAcceptable   String?  @map("minimum_acceptable") @db.Text
  walkawayTriggers    Json     @default("[]") @map("walkaway_triggers") // String array
  riskLevel           String   @default("medium") @map("risk_level") // critical, high, medium, low
  notes               String?  @db.Text
  negotiationGuidance String?  @map("negotiation_guidance") @db.Text
  sortOrder           Int      @default(0) @map("sort_order")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  playbook Playbook @relation(fields: [playbookId], references: [id], onDelete: Cascade)

  @@index([playbookId])
  @@index([category])
  @@index([playbookId, category])
  @@map("playbook_clauses")
}

/// Playbook red flags for automatic detection
model PlaybookRedFlag {
  id          String   @id @default(cuid())
  playbookId  String   @map("playbook_id")
  pattern     String // Regex or text pattern
  category    String // Risk category
  severity    String   @default("medium") // critical, high, medium, low
  explanation String   @db.Text
  suggestion  String   @db.Text
  isRegex     Boolean  @default(false) @map("is_regex")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  playbook Playbook @relation(fields: [playbookId], references: [id], onDelete: Cascade)

  @@index([playbookId])
  @@index([category])
  @@map("playbook_red_flags")
}

/// Playbook fallback negotiation positions
model PlaybookFallback {
  id         String   @id @default(cuid())
  playbookId String   @map("playbook_id")
  category   String // Risk category this fallback applies to
  initial    String   @db.Text // Best position
  fallback1  String   @db.Text // First fallback
  fallback2  String?  @db.Text // Second fallback
  walkaway   String   @db.Text // Minimum acceptable / walkaway
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  playbook Playbook @relation(fields: [playbookId], references: [id], onDelete: Cascade)

  @@unique([playbookId, category])
  @@index([playbookId])
  @@map("playbook_fallbacks")
}

/// Legal review results
model LegalReview {
  id         String  @id @default(cuid())
  tenantId   String  @map("tenant_id")
  contractId String? @map("contract_id")
  playbookId String  @map("playbook_id")

  // Overall assessment
  overallRiskScore     Float   @map("overall_risk_score")
  overallRiskLevel     String  @map("overall_risk_level") // critical, high, medium, low
  recommendation       String // accept, reject, negotiate, escalate, review
  recommendationReason String? @map("recommendation_reason") @db.Text

  // Summary stats
  totalClauses      Int @default(0) @map("total_clauses")
  criticalIssues    Int @default(0) @map("critical_issues")
  highRiskClauses   Int @default(0) @map("high_risk_clauses")
  redlinesGenerated Int @default(0) @map("redlines_generated")

  // Full results stored as JSON
  clauseAssessments Json @default("[]") @map("clause_assessments")
  redlines          Json @default("[]")
  redFlagsFound     Json @default("[]") @map("red_flags_found")
  summary           Json @default("{}")

  reviewedBy String?   @map("reviewed_by")
  reviewedAt DateTime? @map("reviewed_at")
  status     String    @default("pending") // pending, in_review, approved, rejected

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  playbook Playbook  @relation(fields: [playbookId], references: [id])
  contract Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([contractId])
  @@index([playbookId])
  @@index([status])
  @@index([tenantId, status])
  @@map("legal_reviews")
}

// =============================================================================
// AGENT GOAL PERSISTENCE
// =============================================================================

/// Agent goals for persistent execution tracking
model AgentGoal {
  id       String  @id @default(cuid())
  tenantId String  @map("tenant_id")
  userId   String? @map("user_id")

  // Goal details
  type        String // Goal type (analyze_contract, cost_optimization, etc.)
  title       String // Human-readable title
  description String? @db.Text
  priority    Int     @default(5) // 1 = highest, 10 = lowest

  // Execution state
  status   AgentGoalStatus @default(PENDING)
  progress Int             @default(0) // 0-100

  // Related entities
  contractId  String?  @map("contract_id")
  artifactIds String[] @default([]) @map("artifact_ids")

  // Planning and execution
  plan        Json? // Execution plan steps
  currentStep Int   @default(0) @map("current_step")
  totalSteps  Int   @default(0) @map("total_steps")

  // Results and context
  context Json    @default("{}") // Input context
  result  Json? // Final result
  error   String? @db.Text // Error message if failed

  // Approval workflow
  requiresApproval Boolean   @default(false) @map("requires_approval")
  approvedBy       String?   @map("approved_by")
  approvedAt       DateTime? @map("approved_at")

  // Timing
  scheduledFor DateTime? @map("scheduled_for")
  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  steps    AgentGoalStep[]
  triggers AgentTrigger[]

  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([contractId])
  @@index([tenantId, status])
  @@index([scheduledFor])
  @@map("agent_goals")
}

/// Individual steps within an agent goal
model AgentGoalStep {
  id     String @id @default(cuid())
  goalId String @map("goal_id")

  // Step details
  name  String
  type  String // Action type
  order Int // Execution order

  // Execution state
  status   AgentGoalStepStatus @default(PENDING)
  progress Int                 @default(0)

  // Input/output
  input  Json?
  output Json?
  error  String? @db.Text

  // Timing
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  duration    Int? // Duration in milliseconds

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  goal AgentGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@index([status])
  @@map("agent_goal_steps")
}

/// Triggers that can start agent goals
model AgentTrigger {
  id       String  @id @default(cuid())
  tenantId String  @map("tenant_id")
  goalId   String? @map("goal_id") // Template goal to execute

  // Trigger configuration
  name     String
  type     AgentTriggerType
  isActive Boolean          @default(true) @map("is_active")

  // Schedule (for SCHEDULE type)
  cronExpression String? @map("cron_expression")

  // Event (for EVENT type)
  eventType   String? @map("event_type")
  eventFilter Json?   @map("event_filter")

  // Threshold (for THRESHOLD type)
  metric    String?
  operator  String? // gt, lt, eq, gte, lte
  threshold Float?

  // Execution tracking
  lastTriggeredAt DateTime? @map("last_triggered_at")
  triggerCount    Int       @default(0) @map("trigger_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  goal AgentGoal? @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([type])
  @@index([isActive])
  @@map("agent_triggers")
}

enum AgentGoalStatus {
  PENDING
  PLANNING
  AWAITING_APPROVAL
  EXECUTING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

enum AgentGoalStepStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

enum AgentTriggerType {
  SCHEDULE // Cron-based
  EVENT // Event-driven
  THRESHOLD // Metric-based
  MANUAL // User-initiated
}

// ============================================
// Notification Preferences & Push Subscriptions
// ============================================

model NotificationPreferences {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  userId   String @unique @map("user_id")

  // Email notifications
  emailEnabled Boolean @default(true) @map("email_enabled")
  emailDigest  String  @default("INSTANT") // INSTANT, DAILY, WEEKLY, NONE

  // Push notifications
  pushEnabled Boolean @default(true) @map("push_enabled")

  // Notification types
  contractDeadlines Boolean @default(true) @map("contract_deadlines")
  approvalRequests  Boolean @default(true) @map("approval_requests")
  commentMentions   Boolean @default(true) @map("comment_mentions")
  workflowUpdates   Boolean @default(true) @map("workflow_updates")
  systemAlerts      Boolean @default(true) @map("system_alerts")
  systemUpdates     Boolean @default(true) @map("system_updates")
  shareInvites      Boolean @default(true) @map("share_invites")

  // Quiet hours (UTC)
  quietHoursStart    String? @map("quiet_hours_start") // e.g. "22:00"
  quietHoursEnd      String? @map("quiet_hours_end") // e.g. "07:00"
  quietHoursTimezone String? @default("UTC") @map("quiet_hours_timezone")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([userId])
