  @@index([tenantId])
  @@index([categoryL1])
  @@index([categoryL2])
  @@index([spendType])
  @@index([isActive])
  @@index([tenantId, categoryL1, categoryL2])
  @@map("procurement_categories")
}

// ============================================================================
// Baseline & Target Rate Models
// ============================================================================

model RateCardBaseline {
  id                      String                  @id @default(cuid())
  tenantId                String
  
  // Baseline Identification
  baselineName            String
  baselineType            BaselineType
  description             String?
  
  // Category Association
  procurementCategoryId   String?
  categoryL1              String?
  categoryL2              String?
  
  // Role & Service Definition
  roleStandardized        String
  roleCategory            String?
  seniority               SeniorityLevel?
  lineOfService           String?
  
  // Geographic Scope
  country                 String?
  region                  String?
  isGlobal                Boolean                 @default(false)
  
  // Baseline Rate
  targetRate              Decimal                 @db.Decimal(10, 2)
  currency                String
  targetRateUSD           Decimal                 @db.Decimal(10, 2)
  rateUnit                String                  @default("daily") // daily, hourly, monthly, annual
  
  // Range & Tolerance
  minimumRate             Decimal?                @db.Decimal(10, 2)
  maximumRate             Decimal?                @db.Decimal(10, 2)
  tolerancePercentage     Decimal?                @db.Decimal(5, 2)
  
  // Baseline Source
  source                  BaselineSource
  sourceDetails           String?
  importJobId             String?
  contractId              String?                 // Reference contract if based on historical best
  
  // Validity Period
  effectiveDate           DateTime
  expiryDate              DateTime?
  isActive                Boolean                 @default(true)
  
  // Approval & Governance
  approvalStatus          ApprovalStatus          @default(PENDING)
  approvedBy              String?
  approvedAt              DateTime?
  reviewedBy              String?
  reviewedAt              DateTime?
  
  // Usage Statistics
  appliedCount            Int                     @default(0)
  savingsRealized         Decimal?                @db.Decimal(15, 2)
  lastAppliedAt           DateTime?
  
  // Metadata
  tags                    String[]                @default([])
  notes                   String?
  metadata                Json?
  
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  createdBy               String?
  updatedBy               String?
  
  // Relations
  category                ProcurementCategory?    @relation(fields: [procurementCategoryId], references: [id])
  baselineComparisons     BaselineComparison[]
  
  @@unique([tenantId, baselineName])
  @@index([tenantId])
  @@index([baselineType])
  @@index([roleStandardized])
  @@index([country])
  @@index([isActive])
  @@index([effectiveDate])
  @@index([approvalStatus])
  @@index([tenantId, roleStandardized, country])
  @@index([tenantId, categoryL1, categoryL2])
  @@map("rate_card_baselines")
}

model BaselineComparison {
  id                      String                  @id @default(cuid())
  tenantId                String
  
  // Comparison Identification
  comparisonName          String
  comparisonDate          DateTime                @default(now())
  
  // Baseline Reference
  baselineId              String
  
  // Rate Card Reference
  rateCardEntryId         String?
  
  // Or Manual Entry
  actualRate              Decimal?                @db.Decimal(10, 2)
  actualRateSource        String?
  
  // Comparison Results
  variance                Decimal                 @db.Decimal(10, 2) // Positive = over baseline, Negative = under
  variancePercentage      Decimal                 @db.Decimal(5, 2)
  isWithinTolerance       Boolean
  
  // Savings Calculation
  potentialSavings        Decimal?                @db.Decimal(10, 2)
  annualSavingsImpact     Decimal?                @db.Decimal(15, 2)
  volumeImpacted          Int?
  
  // Analysis
  riskLevel               RiskLevel               @default(MEDIUM)
  recommendation          String?
  actionRequired          Boolean                 @default(false)
  priority                Int                     @default(3)
  
  // Status Tracking
  status                  OpportunityStatus       @default(IDENTIFIED)
  assignedTo              String?
  dueDate                 DateTime?
  completedAt             DateTime?
  
  // Notes
  notes                   String?
  internalNotes           String?
  
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  createdBy               String?
  
  // Relations
  baseline                RateCardBaseline        @relation(fields: [baselineId], references: [id])
  rateCardEntry           RateCardEntry?          @relation(fields: [rateCardEntryId], references: [id])
  
  @@index([tenantId])
  @@index([baselineId])
  @@index([rateCardEntryId])
  @@index([status])
  @@index([comparisonDate])
  @@index([variance(sort: Desc)])
  @@index([potentialSavings(sort: Desc)])
  @@map("baseline_comparisons")
}

