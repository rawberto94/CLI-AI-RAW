generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id            String              @id @default(cuid())
  name          String              @unique
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  slug          String              @unique
  status        TenantStatus        @default(ACTIVE)
  auditLogs     AuditLog[]
  contracts     Contract[]
  templates     ContractTemplate[]
  metrics       Metric[]
  configuration TenantConfig?
  subscription  TenantSubscription?
  usage         TenantUsage?
  users         User[]

  @@index([status])
  @@index([createdAt])
}

model TenantConfig {
  id               String   @id @default(cuid())
  tenantId         String   @unique
  aiModels         Json     @default("{}")
  aiCostBudget     Decimal? @db.Decimal(10, 2)
  aiCostAlerts     Boolean  @default(true)
  securitySettings Json     @default("{}")
  integrations     Json     @default("{}")
  workflowSettings Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantSubscription {
  id           String             @id @default(cuid())
  tenantId     String             @unique
  plan         SubscriptionPlan
  status       SubscriptionStatus
  startDate    DateTime
  endDate      DateTime?
  billingCycle BillingCycle
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([endDate])
}

model TenantUsage {
  id                   String   @id @default(cuid())
  tenantId             String   @unique
  contractsProcessed   Int      @default(0)
  aiTokensUsed         BigInt   @default(0)
  storageUsed          BigInt   @default(0)
  apiCallsCount        Int      @default(0)
  monthlyContractLimit Int?
  monthlyTokenLimit    BigInt?
  monthlyStorageLimit  BigInt?
  monthlyApiLimit      Int?
  resetDate            DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([resetDate])
}

model User {
  id                   String                 @id @default(cuid())
  email                String                 @unique
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  avatar               String?
  emailVerified        Boolean                @default(false)
  firstName            String?
  lastLoginAt          DateTime?
  lastName             String?
  passwordHash         String
  status               UserStatus             @default(ACTIVE)
  tenantId             String
  auditLogs            AuditLog[]
  tenant               Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roles                UserRole[]
  sessions             UserSession[]
  preferences          UserPreferences?
  onboardingAnalytics  OnboardingAnalytics[]
  backgroundJobs       BackgroundJob[]
  helpAnalytics        HelpAnalytics[]
  widgetAnalytics      WidgetAnalytics[]

  @@index([email])
  @@index([tenantId])
  @@index([status])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  createdAt   DateTime         @default(now())
  description String?
  isSystem    Boolean          @default(false)
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  users       UserRole[]
}

model Permission {
  id         String           @id @default(cuid())
  action     String
  subject    String
  conditions Json?
  roles      RolePermission[]

  @@unique([action, subject])
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  assignedBy String?
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  assignedAt   DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserSession {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  refreshToken String?  @unique
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model Contract {
  id                 String                   @id @default(cuid())
  tenantId           String
  storagePath        String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  checksum           String?
  mimeType           String                   @map("contentType")
  contractType       String?
  effectiveDate      DateTime?
  expirationDate     DateTime?
  fileName           String                   @map("filename")
  jurisdiction       String?
  lastAnalyzedAt     DateTime?
  originalName       String?
  processedAt        DateTime?
  searchMetadata     Json?                    @default("{}")
  fileSize           BigInt                   @map("size")
  storageProvider    String?                  @default("local")
  uploadedBy         String?
  status             ContractStatus           @default(PROCESSING)
  uploadedAt         DateTime                 @default(now())
  rawText            String?
  startDate          DateTime?
  endDate            DateTime?
  totalValue         Decimal?                 @db.Decimal(15, 2)
  currency           String?
  clientId           String?
  supplierId         String?
  category           String?
  clientName         String?
  contractTitle      String?
  description        String?
  keywords           Json?
  lastViewedAt       DateTime?
  lastViewedBy       String?
  searchableText     String?
  supplierName       String?
  tags               Json?                    @default("[]")
  textVector         Unsupported("tsvector")?
  viewCount          Int                      @default(0)
  artifacts          Artifact[]
  clauses            Clause[]
  client             Party?                   @relation("ClientContracts", fields: [clientId], references: [id])
  supplier           Party?                   @relation("SupplierContracts", fields: [supplierId], references: [id])
  tenant             Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contractArtifacts  ContractArtifact[]
  contractEmbeddings ContractEmbedding[]
  contractMetadata   ContractMetadata?
  versions           ContractVersion[]
  embeddings         Embedding[]
  financialAnalysis  FinancialAnalysis[]
  overviewAnalysis   OverviewAnalysis[]
  processingJobs     ProcessingJob[]
  runs               Run[]
  templateAnalysis   TemplateAnalysis[]

  @@index([tenantId])
  @@index([status])
  @@index([contractType])
  @@index([createdAt])
  @@index([startDate, endDate])
  @@index([clientId])
  @@index([supplierId])
  @@index([clientName])
  @@index([supplierName])
  @@index([category])
  @@index([tenantId, status])
  @@index([tenantId, contractType])
  @@index([tenantId, clientName])
  @@index([tenantId, supplierName])
}

model ContractMetadata {
  id           String   @id @default(cuid())
  contractId   String   @unique
  tenantId     String
  categoryId   String?
  tags         String[]
  systemFields Json     @default("{}")
  customFields Json     @default("{}")
  lastUpdated  DateTime @default(now())
  updatedBy    String
  createdAt    DateTime @default(now())
  contract     Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("contract_metadata")
  @@index([tenantId])
  @@index([categoryId])
  @@index([tags])
}

model TaxonomyCategory {
  id          String             @id @default(cuid())
  tenantId    String
  name        String
  description String?
  parentId    String?
  level       Int                @default(0)
  path        String
  color       String             @default("#3B82F6")
  icon        String             @default("folder")
  isActive    Boolean            @default(true)
  metadata    Json               @default("{}")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  parent      TaxonomyCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    TaxonomyCategory[] @relation("CategoryHierarchy")

  @@map("taxonomy_categories")
  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([parentId])
  @@index([path])
}

model Party {
  id                String     @id @default(cuid())
  name              String
  type              PartyType
  email             String?
  phone             String?
  address           Json?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  clientContracts   Contract[] @relation("ClientContracts")
  supplierContracts Contract[] @relation("SupplierContracts")

  @@unique([name, type])
  @@index([type])
}

model ContractArtifact {
  id         String   @id @default(cuid())
  contractId String
  type       String
  key        String
  value      Json
  confidence Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([contractId, type])
  @@index([type])
}

model ContractEmbedding {
  id         String                 @id @default(cuid())
  contractId String
  chunkIndex Int
  chunkText  String
  embedding  Unsupported("vector")?
  chunkType  String?
  section    String?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  contract   Contract               @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, chunkIndex])
  @@index([contractId])
  @@index([chunkType])
}

model Clause {
  id              String   @id @default(cuid())
  contractId      String
  category        String
  text            String
  riskLevel       String?
  position        Int?
  libraryClauseId String?
  similarity      Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  contract        Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([contractId, category])
  @@index([category])
  @@index([riskLevel])
}

model ProcessingJob {
  id                    String    @id @default(cuid())
  contractId            String
  tenantId              String
  status                JobStatus @default(PENDING)
  progress              Int       @default(0)
  currentStep           String?
  totalStages           Int       @default(5)
  error                 String?
  errorStack            String?
  errorCategory         String?
  retryCount            Int       @default(0)
  maxRetries            Int       @default(3)
  nextRetryAt           DateTime?
  priority              Int       @default(0)
  queuePosition         Int?
  lastCheckpoint        String?
  checkpointData        Json?
  metadata              Json?
  startedAt             DateTime?
  completedAt           DateTime?
  estimatedCompletionAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  contract              Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@index([priority])
  @@index([nextRetryAt])
  @@index([status, priority, createdAt])
}

model ContractVersion {
  id              String    @id @default(cuid())
  contractId      String
  versionNumber   Int
  parentVersionId String?
  changes         Json?
  uploadedBy      String?
  uploadedAt      DateTime  @default(now())
  isActive        Boolean   @default(true)
  supersededAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  contract        Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, versionNumber])
  @@index([contractId])
  @@index([isActive])
}

model Artifact {
  id              String       @id @default(cuid())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  contractId      String
  tenantId        String
  type            ArtifactType
  data            Json
  schemaVersion   String       @default("v1")
  hash            String?
  location        String?
  confidence      Decimal?     @db.Decimal(3, 2)
  processingTime  Int?
  size            Int?
  storageProvider String?      @default("database")
  contract        Contract     @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, type])
  @@index([contractId])
  @@index([tenantId])
  @@index([type])
  @@index([contractId, type])
  @@index([tenantId, type])
}

model TemplateAnalysis {
  id                String   @id @default(cuid())
  contractId        String
  tenantId          String
  detectedTemplates Json
  complianceScore   Decimal? @db.Decimal(3, 2)
  deviations        Json
  recommendations   Json
  processingTime    Int?
  confidence        Decimal? @db.Decimal(3, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  contract          Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([tenantId])
  @@index([complianceScore])
}

model FinancialAnalysis {
  id                String   @id @default(cuid())
  contractId        String
  tenantId          String
  totalValue        Json?
  paymentTerms      Json?
  costBreakdown     Json?
  pricingTables     Json?
  discounts         Json?
  escalationClauses Json?
  financialRisks    Json?
  recommendations   Json?
  processingTime    Int?
  confidence        Decimal? @db.Decimal(3, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  contract          Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([tenantId])
}

model OverviewAnalysis {
  id                 String    @id @default(cuid())
  contractId         String
  tenantId           String
  summary            String?
  parties            Json?
  keyTerms           Json?
  contractType       String?
  jurisdiction       String?
  effectiveDate      DateTime?
  expirationDate     DateTime?
  renewalTerms       Json?
  terminationClauses Json?
  processingTime     Int?
  confidence         Decimal?  @db.Decimal(3, 2)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  contract           Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([tenantId])
  @@index([contractType])
}

model Run {
  id             String    @id @default(cuid())
  runId          String    @unique
  contractId     String?
  tenantId       String
  status         RunStatus @default(PENDING)
  startedAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  completedAt    DateTime?
  summary        String?
  completedSteps Int?      @default(0)
  currentStep    String?
  errorDetails   Json?
  errorMessage   String?
  jobType        String?
  priority       Int       @default(0)
  processingTime Int?
  totalSteps     Int?
  contract       Contract? @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([contractId])
  @@index([tenantId])
  @@index([status])
  @@index([startedAt])
  @@index([tenantId, status])
}

model Embedding {
  id         String   @id @default(cuid())
  contractId String
  tenantId   String
  chunkIndex Int
  text       String
  chunkType  String?
  confidence Decimal? @db.Decimal(3, 2)
  createdAt  DateTime @default(now())
  embedding  Json?
  section    String?
  updatedAt  DateTime @updatedAt
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, chunkIndex])
  @@index([contractId])
  @@index([tenantId])
  @@index([chunkType])
}

model ContractTemplate {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  description String?
  category    String?
  clauses     Json
  structure   Json
  metadata    Json
  version     Int       @default(1)
  isActive    Boolean   @default(true)
  parentId    String?
  usageCount  Int       @default(0)
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String?
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name, version])
  @@index([tenantId])
  @@index([category])
  @@index([isActive])
  @@index([tenantId, category])
}

model AuditLog {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String?
  action       String
  resource     String?
  resourceType String?
  details      Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User?    @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([resourceType])
  @@index([createdAt])
  @@index([tenantId, action])
}

model Metric {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  value     Decimal  @db.Decimal(15, 4)
  unit      String?
  tags      Json?
  timestamp DateTime @default(now())
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([name])
  @@index([tenantId])
  @@index([timestamp])
  @@index([name, timestamp])
  @@index([tenantId, name, timestamp])
}

model ImportJob {
  id                String           @id @default(cuid())
  tenantId          String
  source            ImportSource
  status            ImportStatus     @default(PENDING)
  priority          ImportPriority   @default(NORMAL)
  fileName          String?
  fileSize          BigInt?
  fileType          FileTypeImport
  emailFrom         String?
  emailSubject      String?
  apiSource         String?
  storagePath       String?
  createdAt         DateTime         @default(now())
  startedAt         DateTime?
  completedAt       DateTime?
  processedBy       String?
  rowsProcessed     Int              @default(0)
  rowsSucceeded     Int              @default(0)
  rowsFailed        Int              @default(0)
  errors            Json             @default("[]")
  warnings          Json             @default("[]")
  mappingTemplateId String?
  columnMappings    Json             @default("[]")
  mappingConfidence Decimal          @default(0) @db.Decimal(3, 2)
  extractedData     Json
  normalizedData    Json?
  requiresReview    Boolean          @default(false)
  reviewedBy        String?
  reviewedAt        DateTime?
  reviewNotes       String?
  mappingTemplate   MappingTemplate? @relation(fields: [mappingTemplateId], references: [id])
  rateCards         RateCard[]

  @@index([tenantId])
  @@index([status])
  @@index([source])
  @@index([priority])
  @@index([createdAt])
  @@index([tenantId, status])
  @@index([tenantId, source])
}

model RateCard {
  id               String         @id @default(cuid())
  tenantId         String
  importJobId      String
  supplierId       String
  supplierName     String
  supplierTier     SupplierTier
  contractId       String?
  effectiveDate    DateTime
  expiryDate       DateTime?
  originalCurrency String
  baseCurrency     String         @default("CHF")
  exchangeRate     Decimal?       @db.Decimal(10, 6)
  exchangeRateDate DateTime?
  source           String
  importedAt       DateTime       @default(now())
  importedBy       String
  version          Int            @default(1)
  status           RateCardStatus @default(DRAFT)
  dataQuality      Json
  importJob        ImportJob      @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  roles            RoleRate[]

  @@index([tenantId])
  @@index([supplierId])
  @@index([status])
  @@index([effectiveDate])
  @@index([tenantId, supplierId])
  @@index([tenantId, status])
}

model RoleRate {
  id               String           @id @default(cuid())
  rateCardId       String
  originalRoleName String
  standardizedRole String
  roleCategory     String
  seniorityLevel   SeniorityLevel
  serviceLine      String
  subCategory      String?
  skills           Json             @default("[]")
  certifications   Json             @default("[]")
  originalLocation String
  geography        String
  region           String
  country          String
  city             String?
  originalRate     Decimal          @db.Decimal(10, 2)
  originalPeriod   RatePeriod
  originalCurrency String
  hourlyRate       Decimal          @db.Decimal(10, 2)
  dailyRate        Decimal          @db.Decimal(10, 2)
  monthlyRate      Decimal          @db.Decimal(10, 2)
  annualRate       Decimal          @db.Decimal(10, 2)
  baseCurrency     String
  volumeDiscounts  Json?
  minimumHours     Int?
  minimumDays      Int?
  confidence       Decimal          @db.Decimal(3, 2)
  dataQuality      DataQualityLevel
  issues           Json             @default("[]")
  warnings         Json             @default("[]")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  rateCard         RateCard         @relation(fields: [rateCardId], references: [id], onDelete: Cascade)

  @@index([rateCardId])
  @@index([standardizedRole])
  @@index([seniorityLevel])
  @@index([country])
  @@index([serviceLine])
  @@index([rateCardId, standardizedRole])
}

model MappingTemplate {
  id              String      @id @default(cuid())
  tenantId        String
  name            String
  supplierId      String?
  supplierName    String?
  description     String
  mappings        Json
  requiredFields  Json        @default("[]")
  optionalFields  Json        @default("[]")
  fileNamePattern String?
  headerPatterns  Json        @default("[]")
  usageCount      Int         @default(0)
  successRate     Decimal     @default(0) @db.Decimal(3, 2)
  lastUsed        DateTime?
  version         Int         @default(1)
  createdBy       String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  importJobs      ImportJob[]

  @@unique([tenantId, name, version])
  @@index([tenantId])
  @@index([supplierId])
  @@index([tenantId, supplierId])
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
  DELETED
}

enum SubscriptionPlan {
  FREE
  BASIC
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  EXPIRED
  CANCELLED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

enum PartyType {
  CLIENT
  SUPPLIER
  VENDOR
  PARTNER
}

enum ContractStatus {
  UPLOADED
  PROCESSING
  COMPLETED
  FAILED
  ARCHIVED
  DELETED
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  RETRYING
  CANCELLED
}

enum ProcessingStatus {
  PENDING
  INGESTION
  TEMPLATE_ANALYSIS
  FINANCIAL_ANALYSIS
  OVERVIEW_ANALYSIS
  CLAUSES_ANALYSIS
  COMPLIANCE_ANALYSIS
  RISK_ANALYSIS
  RATES_ANALYSIS
  BENCHMARK_ANALYSIS
  REPORT_GENERATION
  COMPLETED
  FAILED
}

enum ArtifactType {
  INGESTION
  OVERVIEW
  CLAUSES
  RATES
  COMPLIANCE
  BENCHMARK
  RISK
  REPORT
  TEMPLATE
  FINANCIAL
}

enum RunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  TIMEOUT
}

enum ImportSource {
  UPLOAD
  EMAIL
  API
  SCHEDULED
}

enum ImportStatus {
  PENDING
  PROCESSING
  MAPPING
  VALIDATING
  COMPLETED
  FAILED
  REQUIRES_REVIEW
}

enum ImportPriority {
  HIGH
  NORMAL
  LOW
}

enum FileTypeImport {
  XLSX
  XLS
  CSV
  PDF
  JSON
}

enum SupplierTier {
  BIG_4
  TIER_2
  BOUTIQUE
  OFFSHORE
}

enum RateCardStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  ARCHIVED
}

enum SeniorityLevel {
  JUNIOR
  MID
  SENIOR
  PRINCIPAL
  PARTNER
}

enum RatePeriod {
  HOURLY
  DAILY
  MONTHLY
  ANNUAL
}

enum DataQualityLevel {
  HIGH
  MEDIUM
  LOW
}


// ============================================================================
// UX Quick Wins Models
// ============================================================================

model UserPreferences {
  id                    String    @id @default(cuid())
  userId                String    @unique
  role                  String?
  goals                 Json      @default("[]")
  dashboardLayout       Json?
  theme                 String    @default("light")
  notifications         Json      @default("{}")
  onboardingState       Json?
  onboardingCompleted   Boolean   @default(false)
  onboardingSkipped     Boolean   @default(false)
  onboardingCompletedAt DateTime?
  helpToursCompleted    Json      @default("[]")
  customSettings        Json      @default("{}")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OnboardingAnalytics {
  id        String   @id @default(cuid())
  userId    String
  stepId    String
  action    String
  timeSpent Int?
  metadata  Json?
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stepId])
  @@index([timestamp])
}

model ProgressEvent {
  id            String   @id @default(cuid())
  jobId         String
  stage         String
  status        String
  progress      Int
  details       String?
  error         String?
  estimatedTime Int?
  metadata      Json     @default("{}")
  timestamp     DateTime @default(now())

  @@index([jobId])
  @@index([jobId, timestamp])
}

model BackgroundJob {
  id          String    @id @default(cuid())
  userId      String
  type        String
  title       String
  status      String
  progress    Int       @default(0)
  result      Json?
  error       String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  metadata    Json      @default("{}")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([userId, status])
}

model HelpAnalytics {
  id        String   @id @default(cuid())
  userId    String
  tourId    String?
  stepId    String?
  contentId String?
  action    String
  query     String?
  metadata  Json?
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tourId])
  @@index([action])
  @@index([timestamp])
}

model WidgetAnalytics {
  id         String   @id @default(cuid())
  userId     String
  widgetType String
  action     String
  duration   Int?
  metadata   Json?
  timestamp  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([widgetType])
  @@index([timestamp])
}
