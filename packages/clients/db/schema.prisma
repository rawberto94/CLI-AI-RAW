/// API token for outbound REST consumers (warehouse pulls, BI tools,
/// other systems treating Contigo as the contract engine).
/// Token is shown only once at creation; only the bcrypt hash + a short
/// non-secret prefix are persisted.
model ApiToken {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  /// First 8 chars of the raw token, plain text, for UI display
  /// ("ctg_a3f9..."). Lets users identify a token without revealing it.
  prefix      String
  /// bcrypt(rawToken). Never returned by any API.
  tokenHash   String
  /// Comma-separated scopes: "contracts:read", "contracts:write",
  /// "obligations:read", "events:read", "webhooks:read",
  /// "webhooks:write", "*"
  scopes      String    @default("contracts:read")
  createdBy   String?
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  /// Cumulative successful auth count (bumped fire-and-forget per
  /// authenticated request; ~== request count for the lifetime of
  /// the token).
  requestCount Int      @default(0)
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usage       ApiTokenUsageBucket[]

  @@index([tenantId])
  @@index([tenantId, revokedAt])
  @@index([prefix])
  @@map("api_tokens")
}

/// Per-token hourly request bucket. Append-only counter table keyed by
/// (tokenId, hourBucket). Powers "requests in the last 24h / 7d" charts
/// in the API tokens UI without scanning IntegrationEvent or audit logs.
model ApiTokenUsageBucket {
  id         String   @id @default(cuid())
  tokenId    String
  tenantId   String
  /// Hour-aligned UTC timestamp (e.g. 2026-05-07T13:00:00Z).
  hourBucket DateTime
  count      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  token      ApiToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  @@unique([tokenId, hourBucket])
  @@index([tenantId, hourBucket])
  @@index([hourBucket])
  @@map("api_token_usage_buckets")
}

/// Append-only event log for outbound consumers. Every webhook trigger
/// also writes a row here; consumers poll `/api/v1/events?since=<id>`
/// to get a deterministic, replayable stream. Rows are immutable;
/// retention is driven by an external cleanup job (not yet shipped).
model IntegrationEvent {
  /// Monotonic numeric id; cursor pagination uses this column.
  id         BigInt   @id @default(autoincrement())
  tenantId   String
  /// Dot-namespaced event type, matching webhook events
  /// ("contract.created", "contract.processed", ...).
  eventType  String
  /// Optional resource id (contract id, obligation id, etc.) so consumers
  /// can filter by entity without parsing the payload.
  resourceId String?
  /// Free-form JSON payload — same shape as the corresponding webhook.
  payload    Json
  createdAt  DateTime @default(now())

  @@index([tenantId, id])
  @@index([tenantId, eventType, id])
  @@index([tenantId, resourceId, id])
  @@map("integration_events")
}
