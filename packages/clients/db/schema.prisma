// Contract Health & Expiration Tracking Models
// ============================================

model ContractHealthScore {
  id         String @id @default(cuid())
  contractId String @unique @map("contract_id")
  tenantId   String @map("tenant_id")

  // Component Scores (0-100)
  overallScore     Int @default(0) @map("overall_score")
  riskScore        Int @default(0) @map("risk_score")
  complianceScore  Int @default(0) @map("compliance_score")
  financialScore   Int @default(0) @map("financial_score")
  operationalScore Int @default(0) @map("operational_score")
  renewalReadiness Int @default(0) @map("renewal_readiness") // How ready for renewal
  documentQuality  Int @default(0) @map("document_quality") // Quality of contract doc

  // Score Breakdown
  factors       Json @default("[]") // Detailed factor breakdown
  strengths     Json @default("[]") // Contract strengths
  weaknesses    Json @default("[]") // Areas of concern
  opportunities Json @default("[]") // Improvement opportunities

  // Trend Tracking
  previousScore  Int?   @map("previous_score")
  scoreChange    Int    @default(0) @map("score_change")
  trendDirection String @default("stable") @map("trend_direction") // improving, declining, stable
  trendHistory   Json   @default("[]") @map("trend_history") // Last 12 scores

  // Alerts
  alertLevel   String    @default("none") @map("alert_level") // none, low, medium, high, critical
  activeAlerts Json      @default("[]") @map("active_alerts")
  alertCount   Int       @default(0) @map("alert_count")
  lastAlertAt  DateTime? @map("last_alert_at")

  // Benchmarking
  industryAverage Int? @map("industry_average")
  percentileRank  Int? @map("percentile_rank") // Where this contract ranks

  calculatedAt DateTime @default(now()) @map("calculated_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([overallScore(sort: Desc)])
  @@index([alertLevel])
  @@index([calculatedAt])
  @@index([tenantId, overallScore(sort: Desc)])
  @@index([tenantId, alertLevel])
  @@index([trendDirection])
  @@index([riskScore(sort: Desc)])
  @@index([renewalReadiness(sort: Desc)])
  @@map("contract_health_scores")
}

model ContractExpiration {
  id         String @id @default(cuid())
  contractId String @unique @map("contract_id")
  tenantId   String @map("tenant_id")

  // Expiration Details
  expirationDate  DateTime  @map("expiration_date")
  daysUntilExpiry Int       @map("days_until_expiry")
  isExpired       Boolean   @default(false) @map("is_expired")
  expiredAt       DateTime? @map("expired_at")

  // Risk Assessment
  expirationRisk String @default("LOW") @map("expiration_risk") // LOW, MEDIUM, HIGH, CRITICAL, EXPIRED
  riskFactors    Json   @default("[]") @map("risk_factors")
  impactScore    Int    @default(0) @map("impact_score") // Business impact 0-100

  // Value at Risk
  contractValue Decimal? @map("contract_value") @db.Decimal(15, 2)
  annualValue   Decimal? @map("annual_value") @db.Decimal(15, 2)
  valueAtRisk   Decimal? @map("value_at_risk") @db.Decimal(15, 2)

  // Renewal Status
  renewalStatus      String   @default("PENDING") @map("renewal_status") // PENDING, UPCOMING, INITIATED, IN_PROGRESS, COMPLETED, DECLINED, EXPIRED, NOT_RENEWING
  renewalProbability Decimal? @map("renewal_probability") @db.Decimal(5, 2) // AI-predicted probability
  recommendedAction  String?  @map("recommended_action") // RENEW, RENEGOTIATE, TERMINATE, REPLACE

  // Ownership & Assignment
  ownerId    String?   @map("owner_id")
  ownerName  String?   @map("owner_name")
  assignedTo String?   @map("assigned_to")
  assignedAt DateTime? @map("assigned_at")

  // Alert Tracking
  alertsSent    Json      @default("[]") @map("alerts_sent") // { type, sentAt, sentTo }[]
  lastAlertSent DateTime? @map("last_alert_sent")
  nextAlertDue  DateTime? @map("next_alert_due")
  alertsEnabled Boolean   @default(true) @map("alerts_enabled")

  // Notice Period
  noticePeriodDays Int?      @map("notice_period_days")
  noticeDeadline   DateTime? @map("notice_deadline")
  noticeGiven      Boolean   @default(false) @map("notice_given")
  noticeGivenAt    DateTime? @map("notice_given_at")
  noticeGivenBy    String?   @map("notice_given_by")

  // Auto-Renewal
  autoRenewalEnabled Boolean @default(false) @map("auto_renewal_enabled")
  autoRenewalTerms   Json?   @map("auto_renewal_terms")

  // Resolution
  resolution      String? // RENEWED, TERMINATED, REPLACED, ARCHIVED, EXTENDED
  resolutionDate  DateTime? @map("resolution_date")
  resolutionBy    String?   @map("resolution_by")
  resolutionNotes String?   @map("resolution_notes") @db.Text
  newContractId   String?   @map("new_contract_id") // If replaced/renewed

  // Contract Reference
  contractTitle String? @map("contract_title")
  supplierName  String? @map("supplier_name")
  clientName    String? @map("client_name")
  contractType  String? @map("contract_type")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([expirationDate])
  @@index([daysUntilExpiry])
  @@index([isExpired])
  @@index([expirationRisk])
  @@index([renewalStatus])
  @@index([ownerId])
  @@index([assignedTo])
  @@index([resolution])
  @@index([tenantId, isExpired])
  @@index([tenantId, expirationRisk])
  @@index([tenantId, renewalStatus])
  @@index([tenantId, daysUntilExpiry])
  @@index([tenantId, expirationDate])
  @@index([noticePeriodDays])
  @@index([noticeDeadline])
  @@index([nextAlertDue])
  @@index([valueAtRisk(sort: Desc)])
  @@map("contract_expirations")
}

model ExpirationAlert {
  id         String @id @default(cuid())
  contractId String @map("contract_id")
  tenantId   String @map("tenant_id")

  // Alert Details
  alertType String @map("alert_type") // EXPIRATION_30_DAYS, EXPIRATION_60_DAYS, EXPIRATION_90_DAYS, NOTICE_DEADLINE, EXPIRED, CUSTOM
  severity  String @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  title     String
  message   String @db.Text

  // Recipients
  recipients Json @default("[]") // { userId, email, name }[]
  sentTo     Json @default("[]") @map("sent_to") // Actual recipients

  // Delivery Status
  status        String    @default("PENDING") // PENDING, SENT, DELIVERED, FAILED, ACKNOWLEDGED
  sentAt        DateTime? @map("sent_at")
  deliveredAt   DateTime? @map("delivered_at")
  failedAt      DateTime? @map("failed_at")
  failureReason String?   @map("failure_reason")

  // Acknowledgment
  acknowledgedBy     String?   @map("acknowledged_by")
  acknowledgedAt     DateTime? @map("acknowledged_at")
  acknowledgedAction String?   @map("acknowledged_action") // DISMISS, SNOOZE, ASSIGN, TAKE_ACTION
  snoozeUntil        DateTime? @map("snooze_until")

  // Scheduling
  scheduledFor     DateTime @map("scheduled_for")
  daysBeforeExpiry Int      @map("days_before_expiry")

  // Metadata
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([contractId])
  @@index([tenantId])
  @@index([alertType])
  @@index([severity])
  @@index([status])
  @@index([scheduledFor])
  @@index([tenantId, status])
  @@index([tenantId, alertType])
  @@index([acknowledgedAt])
  @@map("expiration_alerts")
}

model RenewalHistory {
  id         String @id @default(cuid())
  contractId String @map("contract_id")
  tenantId   String @map("tenant_id")

  // Renewal Details
  renewalNumber Int    @map("renewal_number") // 1st renewal, 2nd renewal, etc.
  renewalType   String @map("renewal_type") // STANDARD, RENEGOTIATED, EXTENDED, AUTO_RENEWED

  // Previous Terms
  previousStartDate DateTime? @map("previous_start_date")
  previousEndDate   DateTime? @map("previous_end_date")
  previousValue     Decimal?  @map("previous_value") @db.Decimal(15, 2)
  previousTerms     Json?     @map("previous_terms")

  // New Terms
  newStartDate DateTime @map("new_start_date")
  newEndDate   DateTime @map("new_end_date")
  newValue     Decimal? @map("new_value") @db.Decimal(15, 2)
  newTerms     Json?    @map("new_terms")

  // Value Change
  valueChange        Decimal? @map("value_change") @db.Decimal(15, 2)
  valueChangePercent Decimal? @map("value_change_percent") @db.Decimal(5, 2)
  termExtension      Int?     @map("term_extension") // Days extended

  // Negotiation Summary
  negotiationDays   Int?  @map("negotiation_days")
  negotiationRounds Int?  @map("negotiation_rounds")
  keyChanges        Json? @default("[]") @map("key_changes")

  // People
  initiatedBy String?   @map("initiated_by")
  initiatedAt DateTime? @map("initiated_at")
  approvedBy  String?   @map("approved_by")
  approvedAt  DateTime? @map("approved_at")
  completedBy String?   @map("completed_by")
  completedAt DateTime  @map("completed_at")

  // Status
  status String  @default("COMPLETED") // COMPLETED, CANCELLED, SUPERSEDED
  notes  String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  @@index([contractId])
  @@index([tenantId])
  @@index([renewalType])
  @@index([completedAt])
  @@index([tenantId, contractId])
  @@index([valueChange(sort: Desc)])
  @@map("renewal_history")
}

// ==================== AGENTIC AI MODELS ====================

model AgentEvent {
  id          String   @id @default(cuid())
  contractId  String   @map("contract_id")
  tenantId    String   @map("tenant_id")
  agentName   String   @map("agent_name")
  eventType   String   @map("event_type")
  timestamp   DateTime @default(now())
  outcome     String // success, failure, partial, pending
  metadata    Json?    @default("{}")
  reasoning   String?  @db.Text
  confidence  Decimal? @db.Decimal(3, 2)
  duration    Int? // milliseconds
  triggeredBy String?  @map("triggered_by")

  @@index([contractId])
  @@index([tenantId])
  @@index([agentName])
  @@index([eventType])
  @@index([timestamp])
  @@index([outcome])
  @@index([tenantId, agentName])
  @@index([contractId, agentName])
  @@map("agent_events")
}

model AgentRecommendation {
  id              String    @id @default(cuid())
  contractId      String    @map("contract_id")
  tenantId        String    @map("tenant_id")
  agentName       String    @map("agent_name")
  action          String
  description     String    @db.Text
  priority        String // low, medium, high, urgent
  automated       Boolean   @default(false)
  estimatedImpact Json?     @default("{}") @map("estimated_impact")
  potentialValue  Decimal?  @map("potential_value") @db.Decimal(15, 2)
  confidence      Decimal   @db.Decimal(3, 2)
  status          String    @default("pending") // pending, in_progress, completed, dismissed
  reason          String?   @db.Text
  executedAt      DateTime? @map("executed_at")
  executedBy      String?   @map("executed_by")
  result          Json?     @default("{}")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([contractId])
  @@index([tenantId])
  @@index([agentName])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@index([tenantId, status])
  @@index([contractId, status])
  @@map("agent_recommendations")
}

model LearningRecord {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  artifactType   String   @map("artifact_type")
  contractType   String?  @map("contract_type")
  field          String
  aiExtracted    String?  @map("ai_extracted") @db.Text
  userCorrected  String?  @map("user_corrected") @db.Text
  confidence     Decimal? @db.Decimal(3, 2)
  contractLength Int?     @map("contract_length")
  ocrQuality     Decimal? @map("ocr_quality") @db.Decimal(3, 2)
  modelUsed      String?  @map("model_used")
  promptVersion  String?  @map("prompt_version")
  correctionType String?  @map("correction_type") // typo, format, value, missing
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([artifactType])
  @@index([contractType])
  @@index([field])
  @@index([createdAt])
  @@index([tenantId, artifactType, field])
  @@map("learning_records")
}

model OpportunityDiscovery {
  id               String    @id @default(cuid())
  tenantId         String    @map("tenant_id")
  contractId       String?   @map("contract_id")
  opportunityType  String    @map("opportunity_type") // consolidation, renegotiation, optimization, duplicate, autorenewal
  title            String
  description      String    @db.Text
  potentialValue   Decimal   @map("potential_value") @db.Decimal(15, 2)
  confidence       Decimal   @db.Decimal(3, 2)
  effort           String // low, medium, high
  timeframe        String
  relatedContracts Json?     @default("[]") @map("related_contracts")
  actionPlan       Json?     @default("[]") @map("action_plan")
  status           String    @default("new") // new, reviewing, in_progress, completed, dismissed
  reviewedBy       String?   @map("reviewed_by")
  reviewedAt       DateTime? @map("reviewed_at")
  completedAt      DateTime? @map("completed_at")
  actualValue      Decimal?  @map("actual_value") @db.Decimal(15, 2)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([contractId])
  @@index([opportunityType])
  @@index([status])
  @@index([createdAt])
  @@index([potentialValue(sort: Desc)])
  @@index([tenantId, status])
  @@map("opportunity_discoveries")
}
