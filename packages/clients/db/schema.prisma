  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workflow   Workflow                @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  executions WorkflowStepExecution[]

  @@index([workflowId])
  @@index([order])
  @@map("workflow_steps")
}

model WorkflowExecution {
  id          String    @id @default(cuid())
  workflowId  String    @map("workflow_id")
  contractId  String    @map("contract_id")
  tenantId    String?   @map("tenant_id")
  status      String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, FAILED, CANCELLED
  currentStep String?   @map("current_step") // Step ID or number as string
  initiatedBy String?   @map("initiated_by") // Keep backward compatible
  startedBy   String?   @map("started_by")
  dueDate     DateTime? @map("due_date")
  metadata    Json?
  error       String?

  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  workflow       Workflow                @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  contract       Contract                @relation(fields: [contractId], references: [id], onDelete: Cascade)
  stepExecutions WorkflowStepExecution[]

  @@index([workflowId])
  @@index([contractId])
  @@index([tenantId])
  @@index([status])
  @@index([dueDate])
  @@map("workflow_executions")
}

model WorkflowStepExecution {
  id          String  @id @default(cuid())
  executionId String  @map("execution_id")
  stepId      String  @map("step_id")
  stepOrder   Int     @default(0) @map("step_order")
  stepName    String  @default("") @map("step_name")
  status      String  @default("PENDING") // PENDING, WAITING, IN_PROGRESS, COMPLETED, FAILED, SKIPPED, REJECTED
  assignedTo  String? @map("assigned_to")
  completedBy String? @map("completed_by")
  result      Json? // Approval result with comments
  metadata    Json?

  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  execution WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  step      WorkflowStep      @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@index([stepId])
  @@index([status])
  @@index([stepOrder])
  @@map("workflow_step_executions")
}

