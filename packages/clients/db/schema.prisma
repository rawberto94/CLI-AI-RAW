model RateCardAlert {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  userId      String?  @map("user_id")
  
  // Alert Details
  type        String   // rate_increase, market_shift, opportunity, quality_issue, supplier_alert
  severity    String   // low, medium, high, critical
  title       String
  description String
  data        Json     @default("{}")
  
  // Status
  read        Boolean  @default(false)
  
  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")
  
  @@index([tenantId, read, createdAt])
  @@index([userId, read])
  @@index([type])
  @@index([severity])
  @@index([tenantId, type, read])
  @@map("rate_card_alerts")
}

model ScheduledReport {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  userId      String   @map("user_id")
  
  // Report Details
  name        String
  type        String   // executive, detailed, opportunities, suppliers
  frequency   String   // daily, weekly, monthly
  recipients  Json     // Array of email addresses
  filters     Json     @default("{}")
  
  // Schedule
  lastRun     DateTime? @map("last_run")
  nextRun     DateTime  @map("next_run")
  enabled     Boolean   @default(true)
  
  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  @@index([tenantId, enabled, nextRun])
  @@index([userId])
  @@index([type])
  @@index([nextRun])
  @@map("scheduled_reports")
}

