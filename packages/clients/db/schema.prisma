model RateCardSupplier {
  id       String @id @default(cuid())
  tenantId String

  name      String
  legalName String?
  tier      SupplierTier
  country   String
  region    String

  // Performance Metrics
  averageRate          Decimal? @db.Decimal(10, 2)
  competitivenessScore Decimal? @db.Decimal(5, 2)
  reliabilityScore     Decimal? @db.Decimal(5, 2)
  savingsPotential     Decimal? @db.Decimal(10, 2)

  // Statistics
  totalContracts Int @default(0)
  totalRateCards Int @default(0)
  activeRates    Int @default(0)

  // Contract Terms
  typicalPaymentTerms   String?
  typicalContractLength String?
  volumeDiscounts       Json?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rateCards  RateCardEntry[]
  benchmarks SupplierBenchmark[]
  scores     SupplierScore[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([competitivenessScore])
  @@map("rate_card_suppliers")
}

model SupplierScore {
  id         String @id @default(cuid())
  supplierId String
  tenantId   String

  // Overall Score
  overallScore Decimal @db.Decimal(5, 2)

  // Multi-Factor Scores
  priceCompetitiveness Decimal @db.Decimal(5, 2)
  geographicCoverage   Decimal @db.Decimal(5, 2)
  rateStability        Decimal @db.Decimal(5, 2)
  growthTrajectory     Decimal @db.Decimal(5, 2)

  // Ranking
  ranking        Int
  totalSuppliers Int

  // Trend Analysis
  trend         String // improving, declining, stable
  previousScore Decimal? @db.Decimal(5, 2)
  scoreChange   Decimal? @db.Decimal(5, 2)

  // Calculation Metadata
  calculationDate DateTime @default(now())
  dataPointsUsed  Int
  confidenceLevel Decimal  @db.Decimal(5, 2)

  // Timestamps
  createdAt DateTime @default(now())

  // Relations
  supplier RateCardSupplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId, calculationDate])
  @@index([tenantId, overallScore])
  @@index([tenantId, calculationDate])
  @@index([ranking])
  @@map("supplier_scores")
}

model RateCardEntry {
  id       String @id @default(cuid())
  tenantId String

  // Source Information
  source      RateCardSource
  contractId  String?
  importJobId String?
  enteredBy   String?

  // Supplier Information
  supplierId      String
  supplierName    String
  supplierTier    SupplierTier
  supplierCountry String
  supplierRegion  String

  // Role Information
  roleOriginal     String
  roleStandardized String
  roleCategory     String
  seniority        SeniorityLevel
  lineOfService    String
  subCategory      String?
  unit             String?        @default("daily") // Rate unit: hourly, daily, monthly, fixed

  // Rate Information
  dailyRate    Decimal @db.Decimal(10, 2)
  currency     String
  dailyRateUSD Decimal @db.Decimal(10, 2)
  dailyRateCHF Decimal @db.Decimal(10, 2)

  // Geographic Information
  country       String
  region        String
  city          String?
  remoteAllowed Boolean @default(false)

  // Contract Context
  contractType    String?
  effectiveDate   DateTime
  expiryDate      DateTime?
  contractValue   Decimal?  @db.Decimal(15, 2)
  volumeCommitted Int?

  // Benchmarking Fields (Auto-calculated)
  marketRateAverage Decimal? @db.Decimal(10, 2)
  marketRateMedian  Decimal? @db.Decimal(10, 2)
  marketRateP25     Decimal? @db.Decimal(10, 2)
  marketRateP75     Decimal? @db.Decimal(10, 2)
  marketRateP90     Decimal? @db.Decimal(10, 2)

  percentileRank    Int?
  savingsAmount     Decimal? @db.Decimal(10, 2)
  savingsPercentage Decimal? @db.Decimal(5, 2)

  // Client/Tenant Information
  clientName String?
  clientId   String?

  // Baseline & Negotiation Status
  isBaseline       Boolean   @default(false)
  baselineType     String?
  isNegotiated     Boolean   @default(false)
  negotiationDate  DateTime?
  negotiatedBy     String?
  negotiationNotes String?
  msaReference     String?

  // Editability & Audit
  isEditable  Boolean   @default(true)
  editedBy    String?
  editedAt    DateTime?
  editHistory Json?     @default("[]")

  // Quality & Validation
  confidence  Decimal          @db.Decimal(3, 2)
  dataQuality DataQualityLevel
  validatedBy String?
  validatedAt DateTime?

  // Additional Information
  additionalInfo    Json?
  skills            Json? @default("[]")
  certifications    Json? @default("[]")
  minimumCommitment Json?

  // Metadata
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastBenchmarkedAt DateTime?

