// Enhanced Prisma schema for Contract Intelligence System
// Supports production-ready features with proper indexing and constraints

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

// ============================================================================
// TENANT AND USER MANAGEMENT
// ============================================================================

model Tenant {
  id            String            @id @default(cuid())
  name          String            @unique
  slug          String            @unique
  configuration TenantConfig?
  subscription  TenantSubscription?
  usage         TenantUsage?
  status        TenantStatus      @default(ACTIVE)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  // Relations
  contracts         Contract[]
  users            User[]
  templates        ContractTemplate[]
  auditLogs        AuditLog[]
  metrics          Metric[]
  
  @@index([status])
  @@index([createdAt])
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
  DELETED
}

model TenantConfig {
  id                String   @id @default(cuid())
  tenantId          String   @unique
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // AI Configuration
  aiModels          Json     @default("{}")
  aiCostBudget      Decimal? @db.Decimal(10, 2)
  aiCostAlerts      Boolean  @default(true)
  
  // Security Settings
  securitySettings  Json     @default("{}")
  
  // Integration Settings
  integrations      Json     @default("{}")
  
  // Workflow Settings
  workflowSettings  Json     @default("{}")
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model TenantSubscription {
  id            String           @id @default(cuid())
  tenantId      String           @unique
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  plan          SubscriptionPlan
  status        SubscriptionStatus
  startDate     DateTime
  endDate       DateTime?
  billingCycle  BillingCycle
  
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  
  @@index([status])
  @@index([endDate])
}

enum SubscriptionPlan {
  FREE
  BASIC
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  EXPIRED
  CANCELLED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

model TenantUsage {
  id                String   @id @default(cuid())
  tenantId          String   @unique
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  contractsProcessed Int     @default(0)
  aiTokensUsed      BigInt   @default(0)
  storageUsed       BigInt   @default(0) // in bytes
  apiCallsCount     Int      @default(0)
  
  // Monthly limits
  monthlyContractLimit Int?
  monthlyTokenLimit    BigInt?
  monthlyStorageLimit  BigInt?
  monthlyApiLimit      Int?
  
  resetDate         DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([resetDate])
}

model User {
  id            String       @id @default(cuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  email         String       @unique
  passwordHash  String
  firstName     String?
  lastName      String?
  avatar        String?
  
  status        UserStatus   @default(ACTIVE)
  emailVerified Boolean      @default(false)
  lastLoginAt   DateTime?
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  
  // Relations
  roles         UserRole[]
  sessions      UserSession[]
  auditLogs     AuditLog[]
  
  @@index([email])
  @@index([tenantId])
  @@index([status])
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  isSystem    Boolean      @default(false)
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  // Relations
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String @id @default(cuid())
  action      String // e.g., 'create', 'read', 'update', 'delete'
  subject     String // e.g., 'Contract', 'User', 'Template'
  conditions  Json?  // Additional conditions for the permission
  
  // Relations
  roles       RolePermission[]
  
  @@unique([action, subject])
}

model UserRole {
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId      String
  role        Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedAt  DateTime @default(now())
  assignedBy  String?
  
  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  assignedAt   DateTime   @default(now())
  
  @@id([roleId, permissionId])
}

model UserSession {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  token       String    @unique
  refreshToken String?  @unique
  expiresAt   DateTime
  ipAddress   String?
  userAgent   String?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

// ============================================================================
// CONTRACT MANAGEMENT
// ============================================================================

model Contract {
  id            String        @id @default(cuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // File information
  fileName      String
  originalName  String?
  fileSize      BigInt
  mimeType      String
  checksum      String?
  uploadedAt    DateTime      @default(now())
  
  // Storage information
  storagePath   String?
  storageProvider String?     @default("local")
  
  // Content
  rawText       String?       @db.Text
  textVector    Unsupported("tsvector")?
  
  // Contract metadata
  contractType  String?
  status        ContractStatus @default(PROCESSING)
  
  // Parties
  clientId      String?
  client        Party?        @relation("ClientContracts", fields: [clientId], references: [id], onDelete: SetNull)
  supplierId    String?
  supplier      Party?        @relation("SupplierContracts", fields: [supplierId], references: [id], onDelete: SetNull)
  
  // Financial
  totalValue    Decimal?      @db.Decimal(15, 2)
  currency      String?
  
  // Dates
  startDate     DateTime?
  endDate       DateTime?
  effectiveDate DateTime?
  expirationDate DateTime?
  jurisdiction  String?
  
  // Processing metadata
  uploadedBy    String?
  processedAt   DateTime?
  lastAnalyzedAt DateTime?
  
  // Search metadata
  searchMetadata Json?        @default("{}")
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  // Relations
  artifacts     Artifact[]
  contractArtifacts ContractArtifact[]
  contractEmbeddings ContractEmbedding[]
  clauses       Clause[]
  processingJobs ProcessingJob[]
  versions      ContractVersion[]
  runs          Run[]
  embeddings    Embedding[]
  templateAnalysis TemplateAnalysis[]
  financialAnalysis FinancialAnalysis[]
  overviewAnalysis OverviewAnalysis[]
  
  @@index([tenantId])
  @@index([status])
  @@index([contractType])
  @@index([createdAt])
  @@index([startDate, endDate])
  @@index([clientId])
  @@index([supplierId])
  @@index([tenantId, status])
  @@index([tenantId, contractType])
}

model Party {
  id            String     @id @default(cuid())
  name          String
  type          PartyType
  email         String?
  phone         String?
  address       Json?
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  
  // Relations
  clientContracts   Contract[] @relation("ClientContracts")
  supplierContracts Contract[] @relation("SupplierContracts")
  
  @@unique([name, type])
  @@index([type])
}

enum PartyType {
  CLIENT
  SUPPLIER
  VENDOR
  PARTNER
}

enum ContractStatus {
  UPLOADED
  PROCESSING
  COMPLETED
  FAILED
  ARCHIVED
  DELETED
}

// ============================================================================
// CONTRACT REPOSITORY OPTIMIZATION MODELS
// ============================================================================

model ContractArtifact {
  id          String   @id @default(cuid())
  contractId  String
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  
  type        String   // "party", "date", "value", "term", "clause"
  key         String
  value       Json
  confidence  Float
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([contractId])
  @@index([contractId, type])
  @@index([type])
}

model ContractEmbedding {
  id          String   @id @default(cuid())
  contractId  String
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  
  chunkIndex  Int
  chunkText   String   @db.Text
  embedding   Unsupported("vector(1536)")?  // pgvector for OpenAI embeddings
  
  // Metadata
  chunkType   String?  // e.g., 'clause', 'section', 'paragraph'
  section     String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([contractId, chunkIndex])
  @@index([contractId])
  @@index([chunkType])
}

model Clause {
  id          String   @id @default(cuid())
  contractId  String
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  
  category    String   // e.g., 'payment', 'liability', 'termination', 'confidentiality'
  text        String   @db.Text
  riskLevel   String?  // 'low', 'medium', 'high'
  position    Int?     // Position in contract
  
  // Clause library linkage
  libraryClauseId String?
  similarity      Float?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([contractId])
  @@index([contractId, category])
  @@index([category])
  @@index([riskLevel])
}

model ProcessingJob {
  id          String    @id @default(cuid())
  contractId  String
  contract    Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  
  status      JobStatus @default(PENDING)
  progress    Int       @default(0)
  currentStep String?
  
  // Error handling
  error       String?   @db.Text
  errorStack  String?   @db.Text
  retryCount  Int       @default(0)
  maxRetries  Int       @default(3)
  
  // Timing
  startedAt   DateTime?
  completedAt DateTime?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([contractId])
  @@index([status])
  @@index([createdAt])
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  RETRYING
  CANCELLED
}

model ContractVersion {
  id              String   @id @default(cuid())
  contractId      String
  contract        Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  
  versionNumber   Int
  parentVersionId String?
  
  // Version metadata
  changes         Json?
  uploadedBy      String?
  uploadedAt      DateTime @default(now())
  
  // Status
  isActive        Boolean  @default(true)
  supersededAt    DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([contractId, versionNumber])
  @@index([contractId])
  @@index([isActive])
}

// Legacy processing status enum (kept for backward compatibility)
enum ProcessingStatus {
  PENDING
  INGESTION
  TEMPLATE_ANALYSIS
  FINANCIAL_ANALYSIS
  OVERVIEW_ANALYSIS
  CLAUSES_ANALYSIS
  COMPLIANCE_ANALYSIS
  RISK_ANALYSIS
  RATES_ANALYSIS
  BENCHMARK_ANALYSIS
  REPORT_GENERATION
  COMPLETED
  FAILED
}

// ============================================================================
// ANALYSIS ARTIFACTS
// ============================================================================

enum ArtifactType {
  INGESTION
  TEMPLATE
  FINANCIAL
  OVERVIEW
  CLAUSES
  RATES
  COMPLIANCE
  BENCHMARK
  RISK
  REPORT
}

model Artifact {
  id            String       @id @default(cuid())
  contractId    String
  contract      Contract     @relation(fields: [contractId], references: [id], onDelete: Cascade)
  tenantId      String
  
  type          ArtifactType
  data          Json
  schemaVersion String       @default("v1")
  hash          String?
  size          Int?
  
  // Storage information
  location      String?
  storageProvider String?    @default("database")
  
  // Processing metadata
  processingTime Int?       // in milliseconds
  confidence    Decimal?    @db.Decimal(3, 2)
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  @@index([contractId])
  @@index([tenantId])
  @@index([type])
  @@index([contractId, type])
  @@index([tenantId, type])
  @@unique([contractId, type])
}

// ============================================================================
// SPECIALIZED ANALYSIS RESULTS
// ============================================================================

model TemplateAnalysis {
  id            String   @id @default(cuid())
  contractId    String
  contract      Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  tenantId      String
  
  detectedTemplates Json
  complianceScore   Decimal? @db.Decimal(3, 2)
  deviations       Json
  recommendations  Json
  
  processingTime   Int?     // in milliseconds
  confidence       Decimal? @db.Decimal(3, 2)
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  @@index([contractId])
  @@index([tenantId])
  @@index([complianceScore])
}

model FinancialAnalysis {
  id              String   @id @default(cuid())
  contractId      String
  contract        Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  tenantId        String
  
  totalValue      Json?    // { amount, currency, confidence }
  paymentTerms    Json?
  costBreakdown   Json?
  pricingTables   Json?
  discounts       Json?
  escalationClauses Json?
  financialRisks  Json?
  recommendations Json?
  
  processingTime  Int?     // in milliseconds
  confidence      Decimal? @db.Decimal(3, 2)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([contractId])
  @@index([tenantId])
}

model OverviewAnalysis {
  id              String   @id @default(cuid())
  contractId      String
  contract        Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  tenantId        String
  
  summary         String?
  parties         Json?
  keyTerms        Json?
  contractType    String?
  jurisdiction    String?
  effectiveDate   DateTime?
  expirationDate  DateTime?
  renewalTerms    Json?
  terminationClauses Json?
  
  processingTime  Int?     // in milliseconds
  confidence      Decimal? @db.Decimal(3, 2)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([contractId])
  @@index([tenantId])
  @@index([contractType])
}

// ============================================================================
// JOB PROCESSING
// ============================================================================

enum RunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  TIMEOUT
}

model Run {
  id            String    @id @default(cuid())
  runId         String    @unique
  contractId    String?
  contract      Contract? @relation(fields: [contractId], references: [id], onDelete: Cascade)
  tenantId      String
  
  status        RunStatus @default(PENDING)
  jobType       String?   // e.g., 'full_analysis', 'template_only'
  priority      Int       @default(0)
  
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  updatedAt     DateTime  @updatedAt
  
  // Progress tracking
  totalSteps    Int?
  completedSteps Int?     @default(0)
  currentStep   String?
  
  // Results and errors
  summary       String?
  errorMessage  String?
  errorDetails  Json?
  
  // Performance metrics
  processingTime Int?     // in milliseconds
  
  @@index([runId])
  @@index([contractId])
  @@index([tenantId])
  @@index([status])
  @@index([startedAt])
  @@index([tenantId, status])
}

// ============================================================================
// RAG AND EMBEDDINGS
// ============================================================================

model Embedding {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  tenantId   String
  
  chunkIndex Int
  text       String
  embedding  Json?    // Vector embedding as JSON array
  
  // Metadata
  chunkType  String?  // e.g., 'clause', 'section', 'paragraph'
  section    String?
  confidence Decimal? @db.Decimal(3, 2)
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  @@index([contractId])
  @@index([tenantId])
  @@index([chunkType])
  @@unique([contractId, chunkIndex])
}

// ============================================================================
// TEMPLATES
// ============================================================================

model ContractTemplate {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name          String
  description   String?
  category      String?
  
  // Template structure
  clauses       Json
  structure     Json
  metadata      Json
  
  // Versioning
  version       Int      @default(1)
  isActive      Boolean  @default(true)
  parentId      String?  // For template versioning
  
  // Usage statistics
  usageCount    Int      @default(0)
  lastUsedAt    DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdBy     String?
  
  @@unique([tenantId, name, version])
  @@index([tenantId])
  @@index([category])
  @@index([isActive])
  @@index([tenantId, category])
}

// ============================================================================
// AUDIT AND MONITORING
// ============================================================================

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  action      String   // e.g., 'contract.upload', 'user.login'
  resource    String?  // Resource identifier
  resourceType String? // e.g., 'contract', 'user'
  
  details     Json?
  ipAddress   String?
  userAgent   String?
  
  createdAt   DateTime @default(now())
  
  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([resourceType])
  @@index([createdAt])
  @@index([tenantId, action])
}

model Metric {
  id          String   @id @default(cuid())
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name        String
  value       Decimal  @db.Decimal(15, 4)
  unit        String?
  tags        Json?
  
  timestamp   DateTime @default(now())
  
  @@index([name])
  @@index([tenantId])
  @@index([timestamp])
  @@index([name, timestamp])
  @@index([tenantId, name, timestamp])
}

// ============================================================================
// RATE CARD INGESTION
// ============================================================================

enum ImportSource {
  UPLOAD
  EMAIL
  API
  SCHEDULED
}

enum ImportStatus {
  PENDING
  PROCESSING
  MAPPING
  VALIDATING
  COMPLETED
  FAILED
  REQUIRES_REVIEW
}

enum ImportPriority {
  HIGH
  NORMAL
  LOW
}

enum FileTypeImport {
  XLSX
  XLS
  CSV
  PDF
  JSON
}

model ImportJob {
  id            String         @id @default(cuid())
  tenantId      String
  
  source        ImportSource
  status        ImportStatus   @default(PENDING)
  priority      ImportPriority @default(NORMAL)
  
  // Source information
  fileName      String?
  fileSize      BigInt?
  fileType      FileTypeImport
  emailFrom     String?
  emailSubject  String?
  apiSource     String?
  
  // Storage
  storagePath   String?
  
  // Processing metadata
  createdAt     DateTime       @default(now())
  startedAt     DateTime?
  completedAt   DateTime?
  processedBy   String?
  
  // Results
  rowsProcessed Int            @default(0)
  rowsSucceeded Int            @default(0)
  rowsFailed    Int            @default(0)
  errors        Json           @default("[]")
  warnings      Json           @default("[]")
  
  // Mapping
  mappingTemplateId String?
  mappingTemplate   MappingTemplate? @relation(fields: [mappingTemplateId], references: [id], onDelete: SetNull)
  columnMappings    Json           @default("[]")
  mappingConfidence Decimal        @default(0) @db.Decimal(3, 2)
  
  // Extracted data
  extractedData Json
  normalizedData Json?
  
  // Review
  requiresReview Boolean        @default(false)
  reviewedBy     String?
  reviewedAt     DateTime?
  reviewNotes    String?
  
  // Relations
  rateCards     RateCard[]
  
  @@index([tenantId])
  @@index([status])
  @@index([source])
  @@index([priority])
  @@index([createdAt])
  @@index([tenantId, status])
  @@index([tenantId, source])
}

enum SupplierTier {
  BIG_4
  TIER_2
  BOUTIQUE
  OFFSHORE
}

enum RateCardStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  ARCHIVED
}

model RateCard {
  id              String         @id @default(cuid())
  tenantId        String
  importJobId     String
  importJob       ImportJob      @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  
  // Supplier information
  supplierId      String
  supplierName    String
  supplierTier    SupplierTier
  
  // Contract information
  contractId      String?
  effectiveDate   DateTime
  expiryDate      DateTime?
  
  // Currency
  originalCurrency String
  baseCurrency    String         @default("CHF")
  exchangeRate    Decimal?       @db.Decimal(10, 6)
  exchangeRateDate DateTime?
  
  // Metadata
  source          String
  importedAt      DateTime       @default(now())
  importedBy      String
  version         Int            @default(1)
  status          RateCardStatus @default(DRAFT)
  
  // Quality metrics
  dataQuality     Json
  
  // Relations
  roles           RoleRate[]
  
  @@index([tenantId])
  @@index([supplierId])
  @@index([status])
  @@index([effectiveDate])
  @@index([tenantId, supplierId])
  @@index([tenantId, status])
}

enum SeniorityLevel {
  JUNIOR
  MID
  SENIOR
  PRINCIPAL
  PARTNER
}

enum RatePeriod {
  HOURLY
  DAILY
  MONTHLY
  ANNUAL
}

enum DataQualityLevel {
  HIGH
  MEDIUM
  LOW
}

model RoleRate {
  id              String           @id @default(cuid())
  rateCardId      String
  rateCard        RateCard         @relation(fields: [rateCardId], references: [id], onDelete: Cascade)
  
  // Role identification
  originalRoleName String
  standardizedRole String
  roleCategory    String
  seniorityLevel  SeniorityLevel
  
  // Service classification
  serviceLine     String
  subCategory     String?
  skills          Json             @default("[]")
  certifications  Json             @default("[]")
  
  // Geography
  originalLocation String
  geography       String
  region          String
  country         String
  city            String?
  
  // Rate information
  originalRate    Decimal          @db.Decimal(10, 2)
  originalPeriod  RatePeriod
  originalCurrency String
  
  // Normalized rates
  hourlyRate      Decimal          @db.Decimal(10, 2)
  dailyRate       Decimal          @db.Decimal(10, 2)
  monthlyRate     Decimal          @db.Decimal(10, 2)
  annualRate      Decimal          @db.Decimal(10, 2)
  baseCurrency    String
  
  // Volume discounts
  volumeDiscounts Json?
  minimumHours    Int?
  minimumDays     Int?
  
  // Quality indicators
  confidence      Decimal          @db.Decimal(3, 2)
  dataQuality     DataQualityLevel
  issues          Json             @default("[]")
  warnings        Json             @default("[]")
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  @@index([rateCardId])
  @@index([standardizedRole])
  @@index([seniorityLevel])
  @@index([country])
  @@index([serviceLine])
  @@index([rateCardId, standardizedRole])
}

model MappingTemplate {
  id              String   @id @default(cuid())
  tenantId        String
  
  name            String
  supplierId      String?
  supplierName    String?
  description     String
  
  // Template definition
  mappings        Json
  requiredFields  Json     @default("[]")
  optionalFields  Json     @default("[]")
  
  // Pattern matching
  fileNamePattern String?
  headerPatterns  Json     @default("[]")
  
  // Usage stats
  usageCount      Int      @default(0)
  successRate     Decimal  @default(0) @db.Decimal(3, 2)
  lastUsed        DateTime?
  
  // Versioning
  version         Int      @default(1)
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  importJobs      ImportJob[]
  
  @@unique([tenantId, name, version])
  @@index([tenantId])
  @@index([supplierId])
  @@index([tenantId, supplierId])
}
