  description           String?
  icon                  String?
  color                 String?
  
  // Spend Category Classification
  isDirectSpend         Boolean                   @default(false)
  isIndirectSpend       Boolean                   @default(true)
  spendType             SpendType                 @default(INDIRECT)
  
  // Benchmarking Configuration
  enableBenchmarking    Boolean                   @default(true)
  defaultCurrency       String                    @default("USD")
  typicalPricingModel   String?                   // e.g., "per unit", "daily rate", "monthly fee"
  
  // Keywords for auto-classification
  keywords              String[]                  @default([])
  aiClassificationPrompt String?
  
  // Metadata
  isActive              Boolean                   @default(true)
  sortOrder             Int                       @default(0)
  
