/// Contract Relationship - Links related contracts (SOWs to MSAs, Amendments, etc.)
model ContractRelationship {
  id               String @id @default(cuid())
  tenantId         String @map("tenant_id")
  sourceContractId String @map("source_contract_id")
  targetContractId String @map("target_contract_id")
  relationshipType String @map("relationship_type") // SOW_UNDER_MSA, AMENDMENT_TO_ORIGINAL, etc.
  direction        String @default("bidirectional") @map("direction") // parent, child, sibling, bidirectional
  confidence       Float  @default(0.5) @map("confidence") // 0-1
  status           String @default("pending") @map("status") // pending, confirmed, auto_confirmed, rejected
  detectedBy       String @default("manual") @map("detected_by") // ai, pattern, entity_match, manual, hybrid
  evidence         Json?  @map("evidence") // Array of relationship evidence
  metadata         Json?  @map("metadata") // Additional relationship data

  // Confirmation tracking
  confirmedBy String?   @map("confirmed_by")
  confirmedAt DateTime? @map("confirmed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  sourceContract Contract @relation("SourceRelationships", fields: [sourceContractId], references: [id], onDelete: Cascade)
  targetContract Contract @relation("TargetRelationships", fields: [targetContractId], references: [id], onDelete: Cascade)

  @@unique([sourceContractId, targetContractId, relationshipType])
  @@index([tenantId])
  @@index([sourceContractId])
  @@index([targetContractId])
  @@index([relationshipType])
  @@index([status])
  @@index([confidence])
  @@index([tenantId, sourceContractId])
  @@index([tenantId, targetContractId])
  @@map("contract_relationships")
}

