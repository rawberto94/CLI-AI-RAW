/// Standard clause library for contract authoring
model ClauseLibrary {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  name            String // Unique identifier within tenant
  title           String
  category        String // INDEMNIFICATION, CONFIDENTIALITY, LIABILITY, etc.
  content         String    @db.Text
  plainText       String?   @map("plain_text") @db.Text // For search
  riskLevel       String    @default("MEDIUM") @map("risk_level") // LOW, MEDIUM, HIGH
  isStandard      Boolean   @default(false) @map("is_standard")
  isMandatory     Boolean   @default(false) @map("is_mandatory")
  isNegotiable    Boolean   @default(true) @map("is_negotiable")
  tags            Json      @default("[]")
  usageCount      Int       @default(0) @map("usage_count")
  version         Int       @default(1)
  parentId        String?   @map("parent_id") // For version tracking
  jurisdiction    String? // US, EU, GLOBAL
  contractTypes   Json      @default("[]") @map("contract_types") // MSA, NDA, SOW, etc.
  alternativeText String?   @map("alternative_text") @db.Text // Fallback language
  aiEmbedding     Bytes?    @map("ai_embedding") // Vector for semantic search
  createdBy       String    @map("created_by")
  approvedBy      String?   @map("approved_by")
  approvedAt      DateTime? @map("approved_at")
  createdAt       DateTime  @default(now()) @map("created_at")
