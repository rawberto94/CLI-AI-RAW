// Workflow Automation Schema Extension
// Add these models to your main schema.prisma file

model Workflow {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  type        WorkflowType
  triggerType WorkflowTriggerType
  isActive    Boolean  @default(true)
  
  // Configuration
  config      Json?    // Workflow configuration (conditions, rules)
  
  // Metadata
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  steps       WorkflowStep[]
  executions  WorkflowExecution[]
  
  @@index([tenantId])
  @@index([type])
  @@index([isActive])
}

model WorkflowStep {
  id          String   @id @default(cuid())
  workflowId  String
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  
  name        String
  description String?
  order       Int      // Step order in workflow
  stepType    WorkflowStepType
  
  // Assignment
  assigneeType WorkflowAssigneeType
  assigneeId   String?  // User ID, Role ID, or Group ID
  assigneeName String?  // Display name
  
  // Configuration
  config      Json?    // Step-specific config (timeouts, conditions)
  
  // Due date calculation
  dueDays     Int?     // Days from workflow start
  dueHours    Int?     // Additional hours
  
  // Approval settings
  requiresApproval Boolean @default(true)
  allowReject      Boolean @default(true)
  allowDelegate    Boolean @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  executions  StepExecution[]
  
  @@index([workflowId])
  @@index([order])
}

model WorkflowExecution {
  id          String   @id @default(cuid())
  tenantId    String
  workflowId  String
  workflow    Workflow @relation(fields: [workflowId], references: [id])
  
  // Subject
  contractId  String?
  contract    Contract? @relation(fields: [contractId], references: [id])
  
  // Status
  status      WorkflowExecutionStatus
  currentStep Int      @default(0)
  
  // Metadata
  startedAt   DateTime @default(now())
  completedAt DateTime?
  cancelledAt DateTime?
  
  startedBy   String?
  cancelledBy String?
  cancellationReason String?
  
  // Data
  metadata    Json?    // Additional workflow data
  
  // Relations
  steps       StepExecution[]
  comments    WorkflowComment[]
  history     WorkflowHistory[]
  
  @@index([tenantId])
  @@index([workflowId])
  @@index([contractId])
  @@index([status])
}

model StepExecution {
  id          String   @id @default(cuid())
  executionId String
  execution   WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  
  stepId      String
  step        WorkflowStep @relation(fields: [stepId], references: [id])
  
  // Assignment
  assignedTo  String?  // User ID
  assignedAt  DateTime?
  
  // Status
  status      StepExecutionStatus
  
  // Actions
  actionedBy  String?
  actionedAt  DateTime?
  action      StepAction?
  
  // Delegation
  delegatedTo String?
  delegatedBy String?
  delegatedAt DateTime?
  
  // Timing
  dueAt       DateTime?
  
  // Result
  decision    String?  // APPROVED, REJECTED, etc.
  comment     String?
  attachments Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([executionId])
  @@index([stepId])
  @@index([assignedTo])
  @@index([status])
}

model WorkflowComment {
  id          String   @id @default(cuid())
  executionId String
  execution   WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  
  userId      String
  userName    String?
  userEmail   String?
  
  comment     String
  isInternal  Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([executionId])
  @@index([userId])
}

model WorkflowHistory {
  id          String   @id @default(cuid())
  executionId String
  execution   WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  
  action      String   // STARTED, APPROVED, REJECTED, DELEGATED, CANCELLED
  description String
  
  userId      String?
  userName    String?
  
  fromStep    Int?
  toStep      Int?
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  
  @@index([executionId])
  @@index([action])
}

// Enums
enum WorkflowType {
  CONTRACT_APPROVAL
  CONTRACT_REVIEW
  RENEWAL_APPROVAL
  AMENDMENT_APPROVAL
  TERMINATION_APPROVAL
  CUSTOM
}

enum WorkflowTriggerType {
  MANUAL
  ON_UPLOAD
  ON_STATUS_CHANGE
  ON_VALUE_THRESHOLD
  ON_DATE
  SCHEDULED
}

enum WorkflowStepType {
  APPROVAL
  REVIEW
  NOTIFICATION
  TASK
  CONDITION
  INTEGRATION
}

enum WorkflowAssigneeType {
  USER
  ROLE
  GROUP
  DEPARTMENT
  DYNAMIC
}

enum WorkflowExecutionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
  CANCELLED
  EXPIRED
}

enum StepExecutionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
  EXPIRED
}

enum StepAction {
  APPROVED
  REJECTED
  DELEGATED
  SKIPPED
  ESCALATED
}
