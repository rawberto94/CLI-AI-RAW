{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "scripts/**/*.{js,mjs,ts}",
        "turbo.json",
        "eslint.config.js"
      ],
      "ignore": [
        "tmp/**",
        "**/*.d.ts"
      ]
    },
    "apps/web": {
      "entry": [
        "app/**/{page,layout,loading,error,route,middleware}.{js,ts,tsx}",
        "app/globals.css",
        "next.config.mjs",
        "tailwind.config.ts",
        "playwright.config.ts"
      ],
      "ignore": [
        "playwright-report/**",
        "test-results/**",
        "tmp/**"
      ]
    },
    "apps/api": {
      "entry": [
        "index.ts",
        "apps/*/index.ts"
      ],
      "ignore": [
        "tmp/**",
        "test/**"
      ]
    },
    "apps/workers": {
      "entry": [
        "*.worker.ts",
        "index.ts"
      ],
      "ignore": [
        "tmp/**"
      ]
    },
    "packages/*": {
      "entry": [
        "src/index.ts",
        "index.ts"
      ]
    }
  },
  "ignoreBinaries": [
    "tsx",
    "turbo"
  ],
  "ignoreDependencies": [
    "concurrently",
    "dotenv-cli",
    "rimraf",
    "prettier"
  ]
}