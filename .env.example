# ============================================
# Production Fixes - Environment Configuration
# ============================================
# Copy this file to .env and update with your values

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection with connection pooling
# Format: postgresql://user:password@host:port/database?connection_limit=10&pool_timeout=20
DATABASE_URL="postgresql://user:password@localhost:5432/contract_intelligence?connection_limit=10&pool_timeout=20"

# ============================================
# Application Configuration
# ============================================
# Environment: development, staging, production
NODE_ENV="production"

# Log level: debug, info, warn, error
LOG_LEVEL="info"

# Application port
PORT=3000

# ============================================
# AI Service Configuration
# ============================================
# OpenAI API key for AI-powered features
OPENAI_API_KEY="sk-your-openai-api-key-here"

# OpenAI model to use (optional, defaults to gpt-4)
OPENAI_MODEL="gpt-4"

# RAG Embedding Model (optional)
# text-embedding-3-small (1536 dims, faster, cheaper)
# text-embedding-3-large (3072 dims, more accurate - recommended for production)
RAG_EMBED_MODEL="text-embedding-3-large"

# RAG Embedding Dimensions (for text-embedding-3-large with reduced dims)
# Using 1024 dimensions provides good balance of accuracy and performance
RAG_EMBED_DIMENSIONS="1024"

# ============================================
# Email Configuration (SendGrid)
# ============================================
# SendGrid API key for sending emails
# Sign up at https://sendgrid.com/pricing (Free tier: 100 emails/day)
SENDGRID_API_KEY="SG.your-sendgrid-api-key-here"

# Email sender address (must be verified in SendGrid)
EMAIL_FROM="notifications@contigo.ch"

# Admin email for critical alerts
ADMIN_EMAIL="admin@contigo.ch"

# ============================================
# Security Configuration
# ============================================
# JWT secret for authentication (generate a strong random string)
JWT_SECRET="your-jwt-secret-here-generate-a-strong-random-string"

# Session secret (generate a strong random string)
SESSION_SECRET="your-session-secret-here-generate-a-strong-random-string"

# Service API token (optional)
# Allows programmatic access (CLI/integrations) to:
# - POST /api/contracts/upload
# - GET  /api/contracts/:id and /api/contracts/:id/*
# without a browser session.
#
# Required request headers when using this:
# - Authorization: Bearer <SERVICE_API_TOKEN>
# - x-tenant-id: <tenantId>
SERVICE_API_TOKEN="your-strong-service-token-here"

# ============================================
# Monitoring & Observability (Optional)
# ============================================
# Sentry DSN for error tracking
# SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"

# Application Insights connection string (Azure)
# APPINSIGHTS_CONNECTION_STRING="InstrumentationKey=your-key"

# ============================================
# File Storage Configuration
# ============================================
# Upload directory (relative to project root)
UPLOAD_DIR="./uploads"

# Maximum file size in bytes (100MB default)
MAX_FILE_SIZE=104857600

# Storage retention mode: 'full', 'retention', or 'minimal'
# - full: Keep documents indefinitely
# - retention: Keep for STORAGE_RETENTION_DAYS, then auto-delete
# - minimal: Delete immediately after processing (metadata only)
STORAGE_MODE="retention"

# Days to retain original documents (only used in 'retention' mode)
STORAGE_RETENTION_DAYS=90

# Keep thumbnail previews even after deleting original (recommended)
STORAGE_KEEP_THUMBNAILS=true

# Keep extracted text for search (recommended)
STORAGE_KEEP_TEXT=true

# Fetch from client source by default when viewing originals
# Set to 'true' for interface-only mode (don't store documents)
FETCH_FROM_CLIENT_SOURCE=false

# ============================================
# Feature Flags (Optional)
# ============================================
# Enable/disable AI features
ENABLE_AI_FEATURES=true

# Enable/disable health checks
ENABLE_HEALTH_CHECKS=true

# Enable/disable tenant isolation warnings
ENABLE_TENANT_WARNINGS=true

# ============================================
# Performance Configuration (Optional)
# ============================================
# Slow query threshold in milliseconds
SLOW_QUERY_THRESHOLD=1000

# Circuit breaker threshold (number of failures before opening)
CIRCUIT_BREAKER_THRESHOLD=5

# Circuit breaker reset timeout in milliseconds
CIRCUIT_BREAKER_RESET_TIMEOUT=60000

# ============================================
# Development Configuration (Optional)
# ============================================
# Enable pretty logging in development
PRETTY_LOGS=true

# Enable query logging in development
ENABLE_QUERY_LOGGING=false

# ============================================
# Authentication Configuration
# ============================================
# NextAuth secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-nextauth-secret-here"

# NextAuth URL (your app URL)
NEXTAUTH_URL="http://localhost:3000"

# Require authentication (set to true in production)
REQUIRE_AUTH=true

# ============================================
# SSO Configuration (Optional)
# ============================================
# Enable SSO providers by setting their credentials
# Leave empty to disable a provider

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Microsoft Entra ID / Azure AD (https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps/ApplicationsListBlade)
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Auto-provision users on first SSO login (set to true to auto-create accounts)
SSO_AUTO_PROVISION=false

# ============================================
# Notes
# ============================================
# 1. Never commit .env file to version control
# 2. Use strong, unique values for secrets
# 3. Update DATABASE_URL with your actual database credentials
# 4. Get OpenAI API key from https://platform.openai.com/api-keys
# 5. For SSO setup, configure redirect URIs in your OAuth provider:
#    - Google: {NEXTAUTH_URL}/api/auth/callback/google
#    - Microsoft: {NEXTAUTH_URL}/api/auth/callback/azure-ad
#    - GitHub: {NEXTAUTH_URL}/api/auth/callback/github
# 5. For production, use environment-specific values

# ============================================
# RAG Integration Configuration
# ============================================
# Enable/disable RAG integration
RAG_INTEGRATION_ENABLED=true

# Auto-index contracts on upload
RAG_AUTO_INDEX=true

# Maximum retry attempts for failed indexing
RAG_MAX_RETRIES=3

# Delay between retries (milliseconds)
RAG_RETRY_DELAY_MS=5000

# Timeout for RAG operations (milliseconds)
RAG_TIMEOUT_MS=30000

# Fail silently without breaking upload flow
RAG_FAIL_SILENTLY=true

# ============================================
# Vector Database Configuration (Chroma)
# ============================================
# Chroma DB URL for vector storage
CHROMA_URL=http://localhost:8000


# ============================================
# Unified Orchestration Configuration
# ============================================
# Enable/disable individual integrations

# Analytical Intelligence Sync
ENABLE_ANALYTICAL_SYNC=true

# Rate Card Benchmarking Sync
ENABLE_RATE_CARD_SYNC=true

# Data Standardization
ENABLE_DATA_STANDARDIZATION=true

# Savings Detection
ENABLE_SAVINGS_DETECTION=true

# Taxonomy Enrichment
ENABLE_TAXONOMY_ENRICHMENT=true

# Workflow Automation
ENABLE_WORKFLOW_AUTOMATION=true

# Intelligence Engine
ENABLE_INTELLIGENCE_ENGINE=true

# ============================================
# WebSocket & Real-Time Collaboration
# ============================================
# WebSocket server port (separate from main app)
WEBSOCKET_PORT=3001

# WebSocket URL for client connections
WEBSOCKET_URL="ws://localhost:3001"

# CORS origin for WebSocket connections
CORS_ORIGIN="http://localhost:3000,http://localhost:3005"

# ============================================
# Redis Configuration
# ============================================
# Redis URL for rate limiting, sessions, and pub/sub
# Format: redis://[username:password@]host:port[/database]
REDIS_URL="redis://localhost:6379"

# Redis TLS settings (for production)
# REDIS_TLS=true

# ============================================
# Encryption & Security
# ============================================
# 32-byte encryption key for AES-256-GCM (generate with: openssl rand -hex 32)
ENCRYPTION_KEY="your-32-byte-encryption-key-here-generate-with-openssl"

# API key salt for hashing (generate with: openssl rand -hex 16)
API_KEY_SALT="your-api-key-salt-here"

# ============================================
# Rate Limiting Configuration
# ============================================
# Rate limit for general API calls (requests per minute)
RATE_LIMIT_API=100

# Rate limit for authentication attempts (per 5 minutes)
RATE_LIMIT_AUTH=5

# Rate limit for file uploads (per minute)
RATE_LIMIT_UPLOAD=10

# Rate limit for AI/LLM calls (per minute)
RATE_LIMIT_AI=20

# ============================================
# OAuth2 Provider Credentials
# ============================================

# DocuSign OAuth
DOCUSIGN_CLIENT_ID=""
DOCUSIGN_CLIENT_SECRET=""
DOCUSIGN_REDIRECT_URI="http://localhost:3000/api/auth/callback/docusign"

# SAP Ariba OAuth
SAP_ARIBA_CLIENT_ID=""
SAP_ARIBA_CLIENT_SECRET=""
SAP_ARIBA_REDIRECT_URI="http://localhost:3000/api/auth/callback/sap-ariba"

# Coupa OAuth
COUPA_CLIENT_ID=""
COUPA_CLIENT_SECRET=""
COUPA_REDIRECT_URI="http://localhost:3000/api/auth/callback/coupa"
# Your Coupa instance subdomain
COUPA_INSTANCE=""

# Adobe Sign OAuth
ADOBE_SIGN_CLIENT_ID=""
ADOBE_SIGN_CLIENT_SECRET=""
ADOBE_SIGN_REDIRECT_URI="http://localhost:3000/api/auth/callback/adobe-sign"

# HelloSign (Dropbox Sign) OAuth
HELLOSIGN_CLIENT_ID=""
HELLOSIGN_CLIENT_SECRET=""
HELLOSIGN_REDIRECT_URI="http://localhost:3000/api/auth/callback/hellosign"

# ============================================
# NextAuth Configuration
# ============================================
# NextAuth secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-nextauth-secret-here"

# NextAuth URL (your app's base URL)
NEXTAUTH_URL="http://localhost:3000"

# ============================================
# UI & Frontend Configuration
# ============================================
# Toast notification duration (milliseconds)
NEXT_PUBLIC_TOAST_DURATION=5000

# Maximum number of toasts to show
NEXT_PUBLIC_MAX_TOASTS=5

# Debounce delay for inputs (milliseconds)
NEXT_PUBLIC_DEBOUNCE_DELAY=300

# Search debounce delay (milliseconds)
NEXT_PUBLIC_SEARCH_DEBOUNCE=500

# Dashboard refresh interval (milliseconds)
NEXT_PUBLIC_DASHBOARD_REFRESH=30000

# Contracts list refresh interval (milliseconds)
NEXT_PUBLIC_CONTRACTS_REFRESH=60000

# Notifications refresh interval (milliseconds)
NEXT_PUBLIC_NOTIFICATIONS_REFRESH=15000

# Processing poll interval (milliseconds)
NEXT_PUBLIC_PROCESSING_POLL=2000

# AI input debounce delay (milliseconds)
NEXT_PUBLIC_AI_DEBOUNCE=500

# ============================================
# Feature Flags (Client-side)
# ============================================
# Enable AI chat features
NEXT_PUBLIC_ENABLE_AI_CHAT=true

# Enable file upload
NEXT_PUBLIC_ENABLE_FILE_UPLOAD=true

# Enable batch operations
NEXT_PUBLIC_ENABLE_BATCH_OPS=true

# Enable export functionality
NEXT_PUBLIC_ENABLE_EXPORT=true

# Enable collaboration features
NEXT_PUBLIC_ENABLE_COLLABORATION=true

# Enable signature workflows
NEXT_PUBLIC_ENABLE_SIGNATURES=true

# Enable approval workflows
NEXT_PUBLIC_ENABLE_APPROVALS=true

# Enable redlining/compare features
NEXT_PUBLIC_ENABLE_REDLINING=true

# ============================================
# Cache TTL Configuration (Server-side)
# ============================================
# Contracts cache TTL (seconds)
CONTRACTS_CACHE_TTL=300

# Rate cards cache TTL (seconds)
RATE_CARDS_CACHE_TTL=300

# Dashboard cache TTL (seconds)
DASHBOARD_CACHE_TTL=60

# Search results cache TTL (seconds)
SEARCH_CACHE_TTL=120

# ============================================
# AI Configuration (Server-side)
# ============================================
# AI conversation history limit
AI_CONVERSATION_HISTORY_LIMIT=10

# AI max tokens per request
AI_MAX_TOKENS=4000

# ============================================
# Email Service Configuration
# ============================================
# Email provider: resend, sendgrid, ses, smtp, console
EMAIL_PROVIDER="console"

# Sender email address
EMAIL_FROM="ConTigo <noreply@contigo.ai>"

# Reply-to email address
EMAIL_REPLY_TO="support@contigo.ai"

# Resend API key (https://resend.com)
RESEND_API_KEY=""

# SendGrid API key (https://sendgrid.com)
SENDGRID_API_KEY=""

# SMTP settings (alternative to API-based providers)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""

# ============================================
# Push Notifications Configuration
# ============================================
# VAPID keys for web push (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# ============================================
# Cron Job Authentication
# ============================================
# Secret for authenticating cron job requests
CRON_SECRET=""
