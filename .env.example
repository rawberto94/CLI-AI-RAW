# ============================================
# Production Fixes - Environment Configuration
# ============================================
# Copy this file to .env and update with your values

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection with connection pooling
# Format: postgresql://user:password@host:port/database?connection_limit=10&pool_timeout=20
DATABASE_URL="postgresql://user:password@localhost:5432/contract_intelligence?connection_limit=10&pool_timeout=20"

# ============================================
# Application Configuration
# ============================================
# Environment: development, staging, production
NODE_ENV="production"

# Log level: debug, info, warn, error
LOG_LEVEL="info"

# Application port
PORT=3000

# ============================================
# AI Service Configuration
# ============================================
# OpenAI API key for AI-powered features
OPENAI_API_KEY="sk-your-openai-api-key-here"

# OpenAI model to use (optional, defaults to gpt-4)
OPENAI_MODEL="gpt-4"

# ============================================
# Security Configuration
# ============================================
# JWT secret for authentication (generate a strong random string)
JWT_SECRET="your-jwt-secret-here-generate-a-strong-random-string"

# Session secret (generate a strong random string)
SESSION_SECRET="your-session-secret-here-generate-a-strong-random-string"

# ============================================
# Monitoring & Observability (Optional)
# ============================================
# Sentry DSN for error tracking
# SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"

# Application Insights connection string (Azure)
# APPINSIGHTS_CONNECTION_STRING="InstrumentationKey=your-key"

# ============================================
# File Storage Configuration
# ============================================
# Upload directory (relative to project root)
UPLOAD_DIR="./uploads"

# Maximum file size in bytes (100MB default)
MAX_FILE_SIZE=104857600

# ============================================
# Feature Flags (Optional)
# ============================================
# Enable/disable AI features
ENABLE_AI_FEATURES=true

# Enable/disable health checks
ENABLE_HEALTH_CHECKS=true

# Enable/disable tenant isolation warnings
ENABLE_TENANT_WARNINGS=true

# ============================================
# Performance Configuration (Optional)
# ============================================
# Slow query threshold in milliseconds
SLOW_QUERY_THRESHOLD=1000

# Circuit breaker threshold (number of failures before opening)
CIRCUIT_BREAKER_THRESHOLD=5

# Circuit breaker reset timeout in milliseconds
CIRCUIT_BREAKER_RESET_TIMEOUT=60000

# ============================================
# Development Configuration (Optional)
# ============================================
# Enable pretty logging in development
PRETTY_LOGS=true

# Enable query logging in development
ENABLE_QUERY_LOGGING=false

# ============================================
# Notes
# ============================================
# 1. Never commit .env file to version control
# 2. Use strong, unique values for secrets
# 3. Update DATABASE_URL with your actual database credentials
# 4. Get OpenAI API key from https://platform.openai.com/api-keys
# 5. For production, use environment-specific values

# ============================================
# RAG Integration Configuration
# ============================================
# Enable/disable RAG integration
RAG_INTEGRATION_ENABLED=true

# Auto-index contracts on upload
RAG_AUTO_INDEX=true

# Maximum retry attempts for failed indexing
RAG_MAX_RETRIES=3

# Delay between retries (milliseconds)
RAG_RETRY_DELAY_MS=5000

# Timeout for RAG operations (milliseconds)
RAG_TIMEOUT_MS=30000

# Fail silently without breaking upload flow
RAG_FAIL_SILENTLY=true

# ============================================
# Vector Database Configuration (Chroma)
# ============================================
# Chroma DB URL for vector storage
CHROMA_URL=http://localhost:8000


# ============================================
# Unified Orchestration Configuration
# ============================================
# Enable/disable individual integrations

# Analytical Intelligence Sync
ENABLE_ANALYTICAL_SYNC=true

# Rate Card Benchmarking Sync
ENABLE_RATE_CARD_SYNC=true

# Data Standardization
ENABLE_DATA_STANDARDIZATION=true

# Savings Detection
ENABLE_SAVINGS_DETECTION=true

# Taxonomy Enrichment
ENABLE_TAXONOMY_ENRICHMENT=true

# Workflow Automation
ENABLE_WORKFLOW_AUTOMATION=true

# Intelligence Engine
ENABLE_INTELLIGENCE_ENGINE=true
