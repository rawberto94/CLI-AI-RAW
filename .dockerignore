# Build artifacts
node_modules
dist
build
.next
.turbo
**/.next
**/.turbo

# Environment files (never commit secrets!)
.env
.env.local
.env.*.local
*.key
*.pem

# Test coverage
coverage
*.lcov

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/extensions.json
.idea

# Temporary files
tmp
temp
*.tmp
*.swp
*.swo
*~

# Uploads (don't include in image)
uploads/**
!uploads/.gitkeep

# Source control
.git

# Documentation & non-runtime files
docs/
*.md
!README.md
LICENSE
SECURITY.md
CONTRIBUTING.md
CHANGELOG.md
FEATURES.md
QUICK_START.md

# Tests
tests/
**/*.test.*
**/*.spec.*
**/__tests__/

# CI/CD & scripts not needed at runtime
.github/
scripts/
helm/
infrastructure/
data/

# Docker files (avoid recursive COPY)
docker-compose*.yml
Dockerfile*
