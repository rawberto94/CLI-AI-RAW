# ============================================
# CONTRACT INTELLIGENCE PLATFORM
# Complete Environment Configuration Reference
# ============================================
# This file contains ALL possible environment variables
# Copy relevant sections to your .env file
# Last Updated: 2024
# Version: 2.0.0

# ============================================
# CORE CONFIGURATION
# ============================================

## Environment
NODE_ENV=production                    # Options: development, production, test
LOG_LEVEL=info                         # Options: debug, info, warn, error
HOSTNAME=0.0.0.0                       # Server hostname
PORT=3000                              # Server port

## Database
DATABASE_URL=postgresql://user:password@host:5432/dbname?connection_limit=10&pool_timeout=20
TEST_DATABASE_URL=postgresql://user:password@host:5432/dbname_test

## Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# AI & ML SERVICES
# ============================================

## OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini               # Options: gpt-4o-mini, gpt-4-turbo-preview, gpt-3.5-turbo

## Chroma Vector Database
CHROMA_URL=http://localhost:8000

# ============================================
# RAG SYSTEM
# ============================================

## RAG Integration
RAG_INTEGRATION_ENABLED=true           # Enable/disable RAG system
RAG_AUTO_INDEX=true                    # Auto-index contracts on upload
RAG_MAX_RETRIES=3                      # Max retry attempts for failed indexing
RAG_RETRY_DELAY_MS=5000                # Delay between retries (ms)
RAG_TIMEOUT_MS=30000                   # Timeout for RAG operations (ms)
RAG_FAIL_SILENTLY=true                 # Don't break upload flow on RAG failure

# ============================================
# UNIFIED ORCHESTRATION
# ============================================

## Integration Toggles
ENABLE_ANALYTICAL_SYNC=true            # Sync contracts to analytical database
ENABLE_RATE_CARD_SYNC=true             # Sync rate cards with contracts
ENABLE_DATA_STANDARDIZATION=true       # Standardize data automatically
ENABLE_SAVINGS_DETECTION=true          # Detect savings opportunities
ENABLE_TAXONOMY_ENRICHMENT=true        # Auto-tag and categorize
ENABLE_WORKFLOW_AUTOMATION=true        # Trigger workflows automatically
ENABLE_INTELLIGENCE_ENGINE=true        # Pattern and anomaly detection

# ============================================
# FILE STORAGE
# ============================================

## Local Storage
UPLOAD_DIR=./uploads                   # Local upload directory
ARTIFACT_STORAGE_THRESHOLD=10485760    # 10MB - files larger go to cloud
ARTIFACT_COMPRESSION=true              # Compress artifacts

## AWS S3
AWS_S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

## Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=your-connection-string
AZURE_CONTAINER_NAME=artifacts

# ============================================
# APPLICATION URLS
# ============================================

NEXT_PUBLIC_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000
WEB_URL=http://localhost:3000
API_URL=http://localhost:3000          # For scripts

# ============================================
# SECURITY
# ============================================

## Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
SESSION_SECRET=your-super-secret-session-key-min-32-chars

## CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

## Rate Limiting
API_RATE_LIMIT=100                     # Requests per minute
UPLOAD_RATE_LIMIT=50                   # Uploads per hour

# ============================================
# TENANT CONFIGURATION
# ============================================

TENANT_ID=demo                         # Default tenant for testing
TEST_TENANT_ID=test-tenant             # Tenant for automated tests

# ============================================
# EMAIL & NOTIFICATIONS
# ============================================

## SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourcompany.com

## Webhooks
WEBHOOK_URL=https://your-webhook-url.com/notify
WEBHOOK_SECRET=your-webhook-secret

# ============================================
# MONITORING & OBSERVABILITY
# ============================================

## Performance Monitoring
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_ERROR_TRACKING=true

## Sentry
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

## Analytics
ENABLE_ANALYTICS=true
GA_TRACKING_ID=G-XXXXXXXXXX

# ============================================
# PROCESSING CONFIGURATION
# ============================================

## Limits
MAX_FILE_SIZE=104857600                # 100MB max upload size
MAX_CONCURRENT_JOBS=5                  # Max parallel processing jobs
JOB_TIMEOUT=300000                     # 5 minutes job timeout (ms)

## Cache
CACHE_TTL=3600                         # Cache time-to-live (seconds)
ENABLE_CACHE=true

# ============================================
# BACKUP & RECOVERY
# ============================================

ENABLE_AUTO_BACKUP=true
BACKUP_SCHEDULE=0 2 * * *              # Daily at 2 AM (cron format)
BACKUP_RETENTION_DAYS=30

# ============================================
# FEATURE FLAGS
# ============================================

ENABLE_EXPERIMENTAL_FEATURES=false
DEBUG_MODE=false
VERBOSE_LOGGING=false
SKIP_ENV_VALIDATION=false              # NEVER set to true in production!

# ============================================
# DEVELOPMENT TOOLS
# ============================================

## Hot Reload
HOT_RELOAD=true                        # Development only

## Test Data
RAG_DOC_ID=test-doc-123                # For RAG testing scripts

# ============================================
# CODESPACES / DEV CONTAINER
# ============================================
# These are automatically set by the environment
# CODESPACES=true
# CODESPACE_NAME=your-codespace
# GITHUB_CODESPACES_PORT_FORWARDING_DOMAIN=app.github.dev
# DEVCONTAINER=true

# ============================================
# VARIABLE REFERENCE
# ============================================

## REQUIRED (Must be set):
# - DATABASE_URL
# - OPENAI_API_KEY
# - JWT_SECRET
# - SESSION_SECRET

## HIGHLY RECOMMENDED:
# - REDIS_URL
# - CHROMA_URL
# - CORS_ORIGINS

## OPTIONAL (Enhance functionality):
# - AWS_S3_BUCKET (cloud storage)
# - SMTP_* (email notifications)
# - SENTRY_DSN (error tracking)
# - WEBHOOK_URL (integrations)

## DEVELOPMENT ONLY:
# - HOT_RELOAD
# - DEBUG_MODE
# - VERBOSE_LOGGING
# - TEST_DATABASE_URL

# ============================================
# SECURITY BEST PRACTICES
# ============================================

# 1. Never commit .env files to version control
# 2. Use strong, unique secrets (min 32 characters)
# 3. Rotate secrets regularly (every 90 days)
# 4. Use different secrets for each environment
# 5. Enable all security features in production
# 6. Monitor logs for suspicious activity
# 7. Use environment-specific database credentials
# 8. Enable SSL/TLS for all connections
# 9. Restrict CORS origins to known domains
# 10. Use read-only database users where possible

# ============================================
# PERFORMANCE TUNING
# ============================================

# Database Connection Pool:
# - connection_limit=10 (adjust based on load)
# - pool_timeout=20 (seconds)

# Redis:
# - Use Redis for caching to reduce database load
# - Configure maxmemory and eviction policy

# File Storage:
# - Use cloud storage (S3/Azure) for production
# - Enable compression for large artifacts
# - Set appropriate threshold for cloud uploads

# Processing:
# - Adjust MAX_CONCURRENT_JOBS based on server resources
# - Monitor job queue length
# - Set appropriate timeouts

# ============================================
# TROUBLESHOOTING
# ============================================

# Database connection issues:
# - Check DATABASE_URL format
# - Verify database is running
# - Check firewall rules
# - Test connection: psql $DATABASE_URL

# Redis connection issues:
# - Check REDIS_URL format
# - Verify Redis is running
# - Test connection: redis-cli ping

# RAG system issues:
# - Check CHROMA_URL is accessible
# - Verify OpenAI API key is valid
# - Check RAG_INTEGRATION_ENABLED=true
# - Monitor /api/rag/integration/status

# Orchestration issues:
# - Check /api/orchestration/status
# - Verify all ENABLE_* flags
# - Check logs for errors
# - Test individual integrations

# ============================================
# QUICK START GUIDE
# ============================================

# 1. Copy this file:
#    cp .env.complete .env

# 2. Set required variables:
#    - DATABASE_URL
#    - OPENAI_API_KEY
#    - JWT_SECRET (generate: openssl rand -base64 32)
#    - SESSION_SECRET (generate: openssl rand -base64 32)

# 3. Configure services:
#    - Start PostgreSQL
#    - Start Redis
#    - Start Chroma DB (docker run -p 8000:8000 chromadb/chroma)

# 4. Test configuration:
#    npm run test:env

# 5. Start application:
#    npm run dev

# 6. Verify integrations:
#    curl http://localhost:3000/api/health
#    curl http://localhost:3000/api/orchestration/status
#    curl http://localhost:3000/api/rag/integration?action=health

# ============================================
# DEPLOYMENT CHECKLIST
# ============================================

# Before deploying to production:
# [ ] All required variables are set
# [ ] Secrets are strong and unique
# [ ] Database backups are configured
# [ ] Monitoring is enabled
# [ ] Error tracking is configured
# [ ] CORS origins are restricted
# [ ] SSL/TLS is enabled
# [ ] Rate limiting is configured
# [ ] File upload limits are set
# [ ] Cloud storage is configured
# [ ] Email notifications work
# [ ] Webhooks are tested
# [ ] Health checks pass
# [ ] Load testing completed
# [ ] Disaster recovery plan exists

