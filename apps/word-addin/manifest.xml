<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
           xsi:type="TaskPaneApp">

  <!-- Basic Info -->
  <Id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>ConTigo CLM</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="ConTigo Contract Generator"/>
  <Description DefaultValue="Generate contracts from templates with AI-powered clause suggestions and variable management."/>
  <IconUrl DefaultValue="https://contigo.app/icons/addin-icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://contigo.app/icons/addin-icon-128.png"/>
  <SupportUrl DefaultValue="https://contigo.app/support"/>

  <!-- Supported Office Hosts -->
  <Hosts>
    <Host Name="Document"/>
  </Hosts>

  <!-- Requirements -->
  <Requirements>
    <Sets>
      <Set Name="WordApi" MinVersion="1.3"/>
    </Sets>
  </Requirements>

  <!-- Default Settings -->
  <DefaultSettings>
    <SourceLocation DefaultValue="https://contigo.app/word-addin/taskpane.html"/>
  </DefaultSettings>

  <!-- Permissions -->
  <Permissions>ReadWriteDocument</Permissions>

  <!-- Version Overrides for Office 2016+ -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">

    <!-- SSO: Web Application Info for Microsoft Identity -->
    <WebApplicationInfo>
      <!-- Replace with your Azure AD Application (client) ID -->
      <Id>$AZURE_AD_CLIENT_ID</Id>
      <!-- Application ID URI registered in Azure AD: api://{addin-domain}/{client-id} -->
      <Resource>api://localhost:3006/$AZURE_AD_CLIENT_ID</Resource>
      <Scopes>
        <Scope>openid</Scope>
        <Scope>profile</Scope>
        <Scope>email</Scope>
        <Scope>User.Read</Scope>
      </Scopes>
    </WebApplicationInfo>

    <Hosts>
      <Host xsi:type="Document">
        <DesktopFormFactor>
          <!-- Function File for Ribbon Commands -->
          <FunctionFile resid="Commands.Url"/>

          <!-- Ribbon Button Group -->
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="ConTigo.Group">
                <Label resid="GroupLabel"/>
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16"/>
                  <bt:Image size="32" resid="Icon.32x32"/>
                  <bt:Image size="80" resid="Icon.80x80"/>
                </Icon>

                <!-- Generate Contract Button -->
                <Control xsi:type="Button" id="ConTigo.GenerateButton">
                  <Label resid="GenerateButton.Label"/>
                  <Supertip>
                    <Title resid="GenerateButton.Label"/>
                    <Description resid="GenerateButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ConTigo.TaskpaneMain</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>

                <!-- Insert Clause Button -->
                <Control xsi:type="Button" id="ConTigo.ClauseButton">
                  <Label resid="ClauseButton.Label"/>
                  <Supertip>
                    <Title resid="ClauseButton.Label"/>
                    <Description resid="ClauseButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Clause.16x16"/>
                    <bt:Image size="32" resid="Clause.32x32"/>
                    <bt:Image size="80" resid="Clause.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ConTigo.TaskpaneClauses</TaskpaneId>
                    <SourceLocation resid="Clauses.Url"/>
                  </Action>
                </Control>

                <!-- AI Assist Button -->
                <Control xsi:type="Button" id="ConTigo.AIButton">
                  <Label resid="AIButton.Label"/>
                  <Supertip>
                    <Title resid="AIButton.Label"/>
                    <Description resid="AIButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="AI.16x16"/>
                    <bt:Image size="32" resid="AI.32x32"/>
                    <bt:Image size="80" resid="AI.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ConTigo.TaskpaneAI</TaskpaneId>
                    <SourceLocation resid="AI.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <!-- Resources -->
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://contigo.app/icons/addin-icon-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://contigo.app/icons/addin-icon-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://contigo.app/icons/addin-icon-80.png"/>
        <bt:Image id="Clause.16x16" DefaultValue="https://contigo.app/icons/clause-icon-16.png"/>
        <bt:Image id="Clause.32x32" DefaultValue="https://contigo.app/icons/clause-icon-32.png"/>
        <bt:Image id="Clause.80x80" DefaultValue="https://contigo.app/icons/clause-icon-80.png"/>
        <bt:Image id="AI.16x16" DefaultValue="https://contigo.app/icons/ai-icon-16.png"/>
        <bt:Image id="AI.32x32" DefaultValue="https://contigo.app/icons/ai-icon-32.png"/>
        <bt:Image id="AI.80x80" DefaultValue="https://contigo.app/icons/ai-icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://contigo.app/word-addin/commands.html"/>
        <bt:Url id="Taskpane.Url" DefaultValue="https://contigo.app/word-addin/taskpane.html"/>
        <bt:Url id="Clauses.Url" DefaultValue="https://contigo.app/word-addin/clauses.html"/>
        <bt:Url id="AI.Url" DefaultValue="https://contigo.app/word-addin/ai-assist.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="ConTigo"/>
        <bt:String id="GenerateButton.Label" DefaultValue="Generate Contract"/>
        <bt:String id="ClauseButton.Label" DefaultValue="Insert Clause"/>
        <bt:String id="AIButton.Label" DefaultValue="AI Assist"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="GenerateButton.Tooltip" DefaultValue="Generate a new contract from ConTigo templates"/>
        <bt:String id="ClauseButton.Tooltip" DefaultValue="Insert a pre-approved clause from the clause library"/>
        <bt:String id="AIButton.Tooltip" DefaultValue="Get AI-powered suggestions for your contract content"/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
