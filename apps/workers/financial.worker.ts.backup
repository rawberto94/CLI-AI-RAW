  }

  /**
   * Helper methods
   */
  private normalizeCurrency(currency: string): string {
    const currencyMap: Record<string, string> = {
      'dollar': 'USD',
      'dollars': 'USD',
      '$': 'USD',
      'usd': 'USD',
      'euro': 'EUR',
      'euros': 'EUR',
      '€': 'EUR',
      'eur': 'EUR',
      'pound': 'GBP',
      'pounds': 'GBP',
      '£': 'GBP',
      'gbp': 'GBP',
      'yen': 'JPY',
      '¥': 'JPY',
      'jpy': 'JPY'
    };

    const normalized = currency?.toLowerCase().trim();
    return currencyMap[normalized] || currency?.toUpperCase() || 'USD';
  }

  private generateFinancialSummary(data: FinancialData): string {
    const parts = [];
    
    if (data.totalValue) {
      parts.push(`Total contract value: ${data.totalValue.amount} ${data.totalValue.currency}`);
    }
    
    if (data.costs?.length) {
      const totalCosts = data.costs.reduce((sum, cost) => sum + cost.amount, 0);
      parts.push(`${data.costs.length} cost items totaling approximately ${totalCosts} in various currencies`);
    }
    
    if (data.fees?.length) {
      parts.push(`${data.fees.length} fees specified`);
    }
    
    if (data.paymentTerms) {
      parts.push(`Payment terms: ${data.paymentTerms.schedule} ${data.paymentTerms.frequency}`);
    }
    
    if (data.currencies?.length) {
      parts.push(`Currencies involved: ${data.currencies.join(', ')}`);
    }

    // Add best practices summary if available
    if (data.bestPractices) {
      const criticalRecommendations = [
        ...data.bestPractices.paymentOptimization.slice(0, 1),
        ...data.bestPractices.riskMitigation.slice(0, 1)
      ];
      if (criticalRecommendations.length > 0) {
        parts.push(`Key recommendations: ${criticalRecommendations.join('; ')}`);
      }
    }

    return parts.join('. ') + '.';
  }

  private _calculateTotalCosts(data: FinancialData): number {
    return (data.costs?.reduce((sum, cost) => sum + cost.amount, 0) || 0) +
           (data.fees?.reduce((sum, fee) => sum + fee.amount, 0) || 0);
  }

  private calculateFinancialRisk(data: FinancialData): number {
    let riskScore = 0;
    
    // High value contracts are riskier
    if (data.totalValue?.amount && data.totalValue.amount > 1000000) {
      riskScore += 0.3;
    }
    
    // Multiple currencies add complexity
    if (data.currencies && data.currencies.length > 1) {
      riskScore += 0.2;
    }
    
    // Many fees indicate complexity
    if (data.fees && data.fees.length > 5) {
      riskScore += 0.2;
    }
    
    // Escalation clauses add risk
    if (data.escalations && data.escalations.length > 0) {
      riskScore += 0.2;
    }
    
    // Late penalties suggest risk awareness
    if (data.paymentTerms?.latePenalty) {
      riskScore += 0.1;
    }

    return Math.min(riskScore, 1.0);
  }

  private _getOverallRiskLevel(data: FinancialData): 'low' | 'medium' | 'high' {
    const riskScore = this.calculateFinancialRisk(data);
    if (riskScore < 0.3) return 'low';
    if (riskScore < 0.7) return 'medium';
    return 'high';
  }

  private _calculateOverallConfidence(data: FinancialData): number {
    let confidence = 0.8; // Base confidence
    
    if (data.totalValue?.confidence) {
      confidence = (confidence + data.totalValue.confidence) / 2;
    }
    
    // Reduce confidence if many empty sections
    const sections = [data.costs, data.fees, data.paymentTerms, data.currencies];
    const emptySections = sections.filter(section => !section || (Array.isArray(section) && section.length === 0)).length;
    
    confidence -= (emptySections / sections.length) * 0.2;
    
    return Math.max(0.1, Math.min(1.0, confidence));
  }

  /**
   * Generate financial best practices and expert recommendations
   */
  private async generateFinancialBestPractices(
    content: string,
    financialData: FinancialData,
    metadata?: any
  ): Promise<FinancialBestPractices> {
    
    const prompt = `As a senior financial analyst and contract specialist, analyze this contract's financial terms and provide expert recommendations:

FINANCIAL DATA EXTRACTED:
${JSON.stringify(financialData, null, 2)}

CONTRACT CONTENT (FIRST 3000 CHARS):
${content.substring(0, 3000)}...

CONTEXT:
- Contract Type: ${metadata?.contractType || 'General Business Contract'}
- Industry: ${metadata?.industry || 'Not Specified'}
- Contract Value: ${financialData.totalValue ? `${financialData.totalValue.amount} ${financialData.totalValue.currency}` : 'Not Specified'}

Provide specific, actionable recommendations in these categories:

1. PAYMENT OPTIMIZATION: How to improve payment terms, cash flow, and collection processes
2. COST STRUCTURE RECOMMENDATIONS: Ways to optimize cost allocations, reduce expenses, and improve value
3. RISK MITIGATION: Financial risk reduction strategies and protective measures
4. INDUSTRY BENCHMARKS: How these terms compare to industry standards and best practices
5. NEGOTIATION TIPS: Strategic advice for improving financial terms in future negotiations
6. COMPLIANCE CONSIDERATIONS: Financial compliance, regulatory, and reporting requirements

Focus on actionable insights that go beyond what's in the document. Provide industry expertise and strategic financial guidance.

Return your response as a JSON object with the following structure:
{
  "paymentOptimization": ["recommendation 1", "recommendation 2", ...],
  "costStructureRecommendations": ["recommendation 1", "recommendation 2", ...],
  "riskMitigation": ["recommendation 1", "recommendation 2", ...],
  "industryBenchmarks": ["benchmark 1", "benchmark 2", ...],
  "negotiationTips": ["tip 1", "tip 2", ...],
  "complianceConsiderations": ["consideration 1", "consideration 2", ...]
}`;

    try {
      const response = await this.openai.chat.completions.create({
        model: 'gpt-4-1106-preview',
        messages: [
          {
            role: 'system',
            content: 'You are a senior financial analyst and contract specialist with 20+ years of experience in optimizing payment terms, cost structures, and financial risk management across various industries. Provide expert-level recommendations that add significant value beyond basic contract analysis.'
          },
          {
            role: 'user',
            content: prompt
          }
        ],
        temperature: 0.2,
        max_tokens: 2000,
        response_format: { type: 'json_object' }
      });

      const result = JSON.parse(response.choices[0]?.message?.content || '{}');
      
      // Validate and ensure all required fields exist
      return {
        paymentOptimization: result.paymentOptimization || [
          'Consider implementing early payment discounts to improve cash flow',
          'Evaluate payment milestones to align with deliverable completion'
        ],
        costStructureRecommendations: result.costStructureRecommendations || [
          'Review cost allocation methods for transparency and fairness',
          'Consider fixed-price vs. time-and-materials trade-offs'
        ],
        riskMitigation: result.riskMitigation || [
          'Implement payment guarantees or bonds for large contracts',
          'Consider currency hedging for international agreements'
        ],
        industryBenchmarks: result.industryBenchmarks || [
          'Compare payment terms against industry standard practices',
          'Benchmark pricing models against market rates'
        ],
        negotiationTips: result.negotiationTips || [
          'Focus on total cost of ownership rather than just unit prices',
          'Leverage volume commitments for better pricing terms'
        ],
        complianceConsiderations: result.complianceConsiderations || [
          'Ensure financial reporting meets regulatory requirements',
          'Review tax implications of payment and pricing structures'
        ]
      };

    } catch (error) {
      console.error('Error generating financial best practices:', error);
      
      // Return fallback recommendations
      return {
        paymentOptimization: [
          'Review payment terms to ensure they align with cash flow requirements',
          'Consider implementing early payment incentives to improve collections',
          'Evaluate the use of automated payment systems to reduce processing delays'
        ],
        costStructureRecommendations: [
          'Analyze cost breakdown to identify potential optimization opportunities',
          'Consider implementing cost-plus vs fixed-price models based on project uncertainty',
          'Review expense categories to ensure comprehensive cost coverage'
        ],
        riskMitigation: [
          'Implement payment milestones tied to deliverable completion',
          'Consider requiring performance bonds or guarantees for high-value contracts',
          'Evaluate currency exposure and consider hedging strategies for international contracts'
        ],
        industryBenchmarks: [
          'Payment terms appear to align with standard industry practices',
          'Cost structure should be compared against industry benchmarks',
          'Pricing models should reflect current market conditions'
        ],
        negotiationTips: [
          'Focus on total value proposition rather than individual line items',
          'Consider long-term relationship benefits when evaluating pricing',
          'Leverage volume commitments for improved pricing terms'
        ],
        complianceConsiderations: [
          'Ensure all financial terms comply with applicable regulations',
          'Review tax implications of the chosen payment and pricing structure',
          'Consider audit and reporting requirements for financial tracking'
        ]
      };
    }
  }
}

export const financialWorker = new FinancialWorker();