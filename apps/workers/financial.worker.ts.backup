/**
 * Financial Analysis Worker
 * Extracts and analyzes financial information from contracts
 */

import { Job } from 'bullmq';
import { OpenAI } from 'openai';
// import { db } from 'clients-db';
// import { storageClient } from 'clients-storage';

interface FinancialData {
  totalValue?: {
    amount: number;
    currency: string;
    confidence: number;
  };
  paymentTerms: {
    schedule: string;
    frequency: string;
    dueDate?: string;
    latePenalty?: {
      amount: number;
      type: 'fixed' | 'percentage';
      currency?: string;
    };
  };
  costs: {
    type: string;
    amount: number;
    currency: string;
    description: string;
    recurring: boolean;
    frequency?: string;
  }[];
  fees: {
    name: string;
    amount: number;
    currency: string;
    trigger: string;
    optional: boolean;
  }[];
  discounts: {
    description: string;
    amount: number;
    type: 'fixed' | 'percentage';
    conditions: string;
  }[];
  escalations: {
    trigger: string;
    increase: number;
    type: 'fixed' | 'percentage';
    frequency: string;
  }[];
  financialTables: {
    title: string;
    headers: string[];
    rows: string[][];
    totalRow?: string[];
    currency?: string;
  }[];
  currencies: string[];
  insights: string[];
  riskFactors: string[];
  bestPractices: FinancialBestPractices;
}

interface FinancialBestPractices {
  paymentOptimization: string[];
  costStructureRecommendations: string[];
  riskMitigation: string[];
  industryBenchmarks: string[];
  negotiationTips: string[];
  complianceConsiderations: string[];
}

interface FinancialWorkerData {
  documentId: string;
  tenantId: string;
  content: string;
  title?: string;
  metadata?: any;
}

export class FinancialWorker {
  private openai: OpenAI;

  constructor() {
    this.openai = new OpenAI({
      apiKey: process.env['OPENAI_API_KEY']
    });
  }

  async process(job: Job<FinancialWorkerData>): Promise<void> {
    const { documentId, tenantId, content, title, metadata } = job.data;
    
    try {
      console.log(`🏦 Starting financial analysis for document ${documentId}`);
      
      // Update job progress
      await job.updateProgress(10);

      // Extract financial information using LLM
      const financialData = await this.extractFinancialData(content, title);
      await job.updateProgress(60);

      // Validate and enhance the data
      const validatedData = await this.validateFinancialData(financialData);
      await job.updateProgress(70);

      // Generate best practices and recommendations
      const bestPractices = await this.generateFinancialBestPractices(content, validatedData, metadata);
      await job.updateProgress(85);

      // Store the analysis results
      const enhancedData = { ...validatedData, bestPractices };
      await this.storeFinancialAnalysis(documentId, tenantId, enhancedData);
      await job.updateProgress(90);

      // Create searchable artifacts for RAG
      await this.createFinancialArtifacts(documentId, tenantId, enhancedData);
      await job.updateProgress(100);

      console.log(`✅ Financial analysis completed for document ${documentId}`);
      
    } catch (error) {
      console.error(`❌ Financial analysis failed for document ${documentId}:`, error);
      throw error;
    }
  }

  /**
   * Extract financial data using LLM
   */
  private async extractFinancialData(content: string, title?: string): Promise<FinancialData> {
    const systemPrompt = `You are a financial analysis expert specializing in contract analysis. 
    Extract comprehensive financial information from contracts including costs, fees, payment terms, and pricing structures.
    
    Focus on:
    - All monetary amounts with currencies
    - Payment schedules and terms
    - Fee structures and penalties
    - Pricing tables and rate cards
    - Discounts and escalations
    - Financial risk factors
    
    Handle variations in contract formats and be thorough in extraction.
    Provide confidence scores for ambiguous amounts.
    Return valid JSON only.`;

    const userPrompt = `Analyze this contract for financial information:
    
    Title: ${title || 'Contract Document'}
    
    Content:
    ${content}
    
    Extract all financial data and return as JSON with the following structure:
    {
      "totalValue": {
        "amount": number,
        "currency": "string",
        "confidence": number (0-1)
      },
      "paymentTerms": {
        "schedule": "string",
        "frequency": "string", 
        "dueDate": "string",
        "latePenalty": {
          "amount": number,
          "type": "fixed|percentage",
          "currency": "string"
        }
      },
      "costs": [
        {
          "type": "string",
          "amount": number,
          "currency": "string", 
          "description": "string",
          "recurring": boolean,
          "frequency": "string"
        }
      ],
      "fees": [
        {
          "name": "string",
          "amount": number,
          "currency": "string",
          "trigger": "string",
          "optional": boolean
        }
      ],
      "discounts": [
        {
          "description": "string",
          "amount": number,
          "type": "fixed|percentage",
          "conditions": "string"
        }
      ],
      "escalations": [
        {
          "trigger": "string",
          "increase": number,
          "type": "fixed|percentage", 
          "frequency": "string"
        }
      ],
      "financialTables": [
        {
          "title": "string",
          "headers": ["string"],
          "rows": [["string"]],
          "totalRow": ["string"],
          "currency": "string"
        }
      ],
      "currencies": ["string"],
      "riskFactors": [
        {
          "factor": "string",
          "impact": "low|medium|high",
          "description": "string"
        }
      ]
    }`;

    const response = await this.openai.chat.completions.create({
      model: 'gpt-4-1106-preview',
      messages: [
        { role: 'system', content: systemPrompt },
        { role: 'user', content: userPrompt }
      ],
      temperature: 0.1,
      max_tokens: 4000,
      response_format: { type: 'json_object' }
    });

    const content_text = response.choices[0]?.message?.content;
    if (!content_text) {
      throw new Error('No response from OpenAI');
    }

    try {
      return JSON.parse(content_text) as FinancialData;
    } catch (error) {
      console.error('Failed to parse financial analysis JSON:', content_text);
      throw new Error('Invalid JSON response from financial analysis');
    }
  }

  /**
   * Validate and enhance financial data
   */
  private async validateFinancialData(data: FinancialData): Promise<FinancialData> {
    // Normalize currencies to standard codes
    data.currencies = data.currencies?.map(curr => this.normalizeCurrency(curr)) || [];
    
    // Validate amounts are positive numbers
    if (data.totalValue?.amount && data.totalValue.amount < 0) {
      data.totalValue.amount = Math.abs(data.totalValue.amount);
    }

    data.costs = data.costs?.map(cost => ({
      ...cost,
      amount: Math.abs(cost.amount),
      currency: this.normalizeCurrency(cost.currency)
    })) || [];

    data.fees = data.fees?.map(fee => ({
      ...fee,
      amount: Math.abs(fee.amount),
      currency: this.normalizeCurrency(fee.currency)
    })) || [];

    // Enhance with calculated insights
    const enhancedData = {
      ...data,
      summary: this.generateFinancialSummary(data),
      riskScore: this.calculateFinancialRisk(data)
    };

    return enhancedData as FinancialData;
  }

