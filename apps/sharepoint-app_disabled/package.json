{
  "name": "@contract-intelligence/sharepoint-app",
  "version": "1.0.0",
  "description": "SharePoint App Package for Contract Intelligence Platform",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "gulp bundle --ship && gulp package-solution --ship",
    "clean": "gulp clean",
    "test": "gulp test",
    "serve": "gulp bundle --custom-serve && gulp serve --nobrowser",
    "package": "gulp package-solution",
    "deploy": "npm run build && npm run upload-app-catalog"
  },
  "dependencies": {
    "@microsoft/sp-core-library": "1.12.1",
    "@microsoft/sp-property-pane": "1.12.1", 
    "@microsoft/sp-webpart-base": "1.12.1",
    "@microsoft/sp-lodash-subset": "1.12.1",
    "@microsoft/sp-office-ui-fabric-core": "1.12.1",
    "@microsoft/sp-http": "1.12.1",
    "@microsoft/sp-application-base": "1.12.1",
    "@fluentui/react": "^8.110.10",
    "@fluentui/react-icons": "^2.0.220",
    "react": "17.0.1",
    "react-dom": "17.0.1",
    "recharts": "^2.8.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@microsoft/sp-build-web": "1.12.1",
    "@microsoft/sp-tslint-rules": "1.12.1",
    "@microsoft/sp-module-interfaces": "1.12.1",
    "@microsoft/sp-webpart-workbench": "1.12.1",
    "@microsoft/rush-stack-compiler-4.5": "0.4.0",
    "@types/react": "17.0.45",
    "@types/react-dom": "17.0.17",
    "@types/webpack-env": "~1.15.2",
    "gulp": "^4.0.2",
    "typescript": "~4.7.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rawberto94/contract-intelligence.git"
  },
  "keywords": [
    "sharepoint",
    "spfx",
    "contract-intelligence",
    "office365",
    "microsoft365"
  ],
  "author": "Contract Intelligence Team",
  "license": "MIT"
}