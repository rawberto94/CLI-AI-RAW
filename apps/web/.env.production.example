# ============================================
# ConTigo Production Environment Template
# ============================================
# IMPORTANT: copy to a secret store or runtime environment and fill real values.
# Never commit an actual .env.production file.

# ============================================
# Application
# ============================================
NODE_ENV="production"
LOG_LEVEL="info"
PORT="3000"
NEXT_TELEMETRY_DISABLED="1"

# Public HTTPS origin. This must exactly match the browser URL used for login.
NEXTAUTH_URL="https://your-domain.com"
NEXT_PUBLIC_APP_URL="https://your-domain.com"
NEXT_PUBLIC_WS_URL="wss://your-domain.com/ws"
AUTH_TRUST_HOST="true"
REQUIRE_AUTH="true"

# ============================================
# Security (required)
# ============================================
# Generate each with: openssl rand -base64 32
AUTH_SECRET=""
NEXTAUTH_SECRET=""
JWT_SECRET=""
SESSION_SECRET=""

# ============================================
# Database: Azure Database for PostgreSQL Flexible Server
# ============================================
# DATABASE_URL may point to a pooler. DIRECT_DATABASE_URL must bypass poolers for migrations.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/contigo?sslmode=require&connection_limit=20&pool_timeout=10"
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/contigo?sslmode=require"

# Required PostgreSQL extensions before migrations/RAG indexing:
# vector, uuid-ossp, pg_trgm, btree_gin, pgcrypto

# ============================================
# Redis: Azure Cache for Redis
# ============================================
REDIS_URL="rediss://:PASSWORD@HOST.redis.cache.windows.net:6380"
REDIS_HOST="HOST.redis.cache.windows.net"
REDIS_PORT="6380"
REDIS_PASSWORD=""
REDIS_TLS="true"

# ============================================
# Azure OpenAI
# ============================================
AZURE_OPENAI_ENDPOINT="https://your-openai-resource.openai.azure.com"
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_DEPLOYMENT="gpt-4o"
AZURE_OPENAI_EMBEDDING_DEPLOYMENT="text-embedding-3-small"
AZURE_OPENAI_API_VERSION="2024-02-01"

# Standard OpenAI fallback. Leave empty when Azure OpenAI is configured.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Optional alternate providers.
MISTRAL_API_KEY=""
ANTHROPIC_API_KEY=""

# ============================================
# Azure Document Intelligence
# ============================================
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT="https://your-document-intelligence-resource.cognitiveservices.azure.com/"
AZURE_DOCUMENT_INTELLIGENCE_KEY=""
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT_EU=""
AZURE_DOCUMENT_INTELLIGENCE_KEY_EU=""
AZURE_DI_DEFAULT_MODEL="layout"
AZURE_DI_FEATURES="keyValuePairs"

# ============================================
# RAG / pgvector
# ============================================
# Keep this aligned with ContractEmbedding.embedding vector dimensions and init SQL.
RAG_INTEGRATION_ENABLED="true"
RAG_AUTO_INDEX="true"
RAG_EMBED_MODEL="text-embedding-3-small"
RAG_EMBED_DIMENSIONS="1024"
RAG_RETRIEVAL_K="8"
RAG_MIN_SCORE="0.3"
RAG_RERANK="true"
RAG_EXPAND_QUERY="true"
RAG_HYBRID_ALPHA="0.7"

# ============================================
# Object Storage
# ============================================
# Recommended first go-live path: keep MinIO/S3-compatible storage because workers
# still require MinIO/S3 variables for OCR file retrieval in production.
STORAGE_PROVIDER="minio"
MINIO_ENDPOINT="minio"
MINIO_PORT="9000"
MINIO_ACCESS_KEY=""
MINIO_SECRET_KEY=""
MINIO_BUCKET="contracts"
MINIO_USE_SSL="false"

# S3-compatible aliases used by some app paths.
S3_ENDPOINT=""
S3_PORT="9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="contracts"
S3_USE_SSL="false"

# Azure Blob option. Only switch STORAGE_PROVIDER=azure after worker storage parity is verified.
AZURE_STORAGE_ACCOUNT_NAME=""
AZURE_STORAGE_ACCOUNT_KEY=""
AZURE_STORAGE_CONTAINER="contracts"
AZURE_STORAGE_CONTAINER_NAME="contracts"
AZURE_STORAGE_REGION="switzerlandnorth"

# ============================================
# Feature Flags
# ============================================
ENABLE_AI_FEATURES="true"
ENABLE_HEALTH_CHECKS="true"

# ============================================
# Monitoring & Observability
# ============================================
SENTRY_DSN=""

# ============================================
# Performance
# ============================================
SLOW_QUERY_THRESHOLD="1000"
CIRCUIT_BREAKER_THRESHOLD="5"
CIRCUIT_BREAKER_RESET_TIMEOUT="60000"
