# ============================================
# Production Environment Configuration Template
# ============================================
# IMPORTANT: Copy this to .env.production and fill in real values
# Never commit the actual .env.production file!

# ============================================
# Database Configuration
# ============================================
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?connection_limit=20&pool_timeout=10"

# ============================================
# Application Configuration
# ============================================
NODE_ENV="production"
LOG_LEVEL="info"
PORT=3000

# Public URL for callbacks and webhooks
NEXTAUTH_URL="https://your-domain.com"
AUTH_TRUST_HOST="true"

# ============================================
# Security Configuration (REQUIRED)
# ============================================
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
JWT_SECRET=""
SESSION_SECRET=""

# Require authentication for all API routes
REQUIRE_AUTH="true"

# ============================================
# AI Service Configuration
# ============================================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Get from: https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=""

# ============================================
# Monitoring & Observability (RECOMMENDED)
# ============================================
# Sentry DSN for error tracking
# Get from: https://sentry.io/settings/projects/
SENTRY_DSN=""

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST="your-redis-host"
REDIS_PORT=6379
REDIS_PASSWORD=""

# ============================================
# Object Storage (S3/MinIO)
# ============================================
# For AWS S3:
S3_ENDPOINT="s3.amazonaws.com"
S3_REGION="us-east-1"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="your-bucket-name"
S3_USE_SSL="true"

# ============================================
# Vector Database (ChromaDB/Pinecone)
# ============================================
CHROMA_URL="https://your-chroma-instance.com"

# ============================================
# Feature Flags
# ============================================
ENABLE_AI_FEATURES="true"
ENABLE_HEALTH_CHECKS="true"
RAG_INTEGRATION_ENABLED="true"
RAG_AUTO_INDEX="true"

# ============================================
# Performance Configuration
# ============================================
SLOW_QUERY_THRESHOLD=1000
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RESET_TIMEOUT=60000
