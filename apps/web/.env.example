# ===========================================
# ENVIRONMENT VARIABLES TEMPLATE
# ===========================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to git
# ===========================================

# Database (Required)
# For local: Can use local PostgreSQL or Neon dev branch
# For Azure: Set via az containerapp update --set-env-vars
DATABASE_URL=postgresql://user:password@localhost:5432/contigo?schema=public

# NextAuth Configuration (Required)
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
# Local: http://localhost:3000
# Azure: https://your-app.azurecontainerapps.io
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# OpenAI (Optional - for AI features)
OPENAI_API_KEY=sk-...

# Redis (Optional - for caching)
REDIS_URL=redis://localhost:6379

# MinIO/S3 Storage (Optional)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# JWT/Session (Required)
JWT_SECRET=your-jwt-secret
SESSION_SECRET=your-session-secret

# Sentry (Optional - error tracking)
SENTRY_DSN=

# Node environment
NODE_ENV=development
