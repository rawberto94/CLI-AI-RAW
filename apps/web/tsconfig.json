{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "strict": false,
    "noUncheckedIndexedAccess": false,
    "noImplicitOverride": false,
    "noEmit": true,
    "incremental": true,
    "tsBuildInfoFile": "./.next/cache/.tsbuildinfo",
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "disableSourceOfProjectReferenceRedirect": true,
    "disableSolutionSearching": true,
    "preserveWatchOutput": true,
    "assumeChangesOnlyAffectDirectDependencies": true,
    "disableReferencedProjectLoad": true,
    "maxNodeModuleJsDepth": 0,
    "types": ["react", "react-dom"],
    "plugins": [{ "name": "next" }],
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@/apps/*": ["../../apps/*"],
      "@/core": ["../../apps/core"],
      "@/core/*": ["../../apps/core/*"],
      "@/packages/*": ["../../packages/*"],
      "@/packages/clients/*": ["../../packages/clients/*"],
      "@/packages/clients/db": ["../../packages/clients/db"],
      "@/packages/clients/db/*": ["../../packages/clients/db/*"],
      "@repo/utils": ["../../packages/utils/src"],
      "@repo/utils/*": ["../../packages/utils/src/*"],
      "@repo/db": ["../../packages/clients/db"],
      "@repo/db/*": ["../../packages/clients/db/*"],
      "@repo/workers": ["../../packages/workers/src"],
      "@repo/workers/*": ["../../packages/workers/src/*"],
      "@repo/agents": ["../../packages/agents/src"],
      "@repo/agents/*": ["../../packages/agents/src/*"],
      "@repo/data-orchestration": ["../../packages/data-orchestration/src"],
      "@repo/data-orchestration/*": ["../../packages/data-orchestration/src/*"],
      "data-orchestration": ["../../packages/data-orchestration/src"],
      "data-orchestration/*": ["../../packages/data-orchestration/src/*"],
      "utils": ["../../packages/utils/src"],
      "utils/*": ["../../packages/utils/src/*"],
      "schemas": ["../../packages/schemas/src"],
      "schemas/*": ["../../packages/schemas/src/*"],
      "clients-rag": ["../../packages/clients/rag"],
      "clients-rag/*": ["../../packages/clients/rag/*"],
      "clients-openai": ["../../packages/clients/openai"],
      "clients-openai/*": ["../../packages/clients/openai/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules",
    "../sharepoint-app_disabled",
    "../../packages/utils/src/queue/**",
    "../../packages/workers/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/__tests__/**",
    ".next/**",
    "out/**",
    "dist/**",
    "build/**",
    "coverage/**",
    ".turbo/**",
    "**/node_modules/**",
    "**/.next/**",
    "**/playwright-report/**",
    "**/test-results/**",
    "**/.git/**",
    "**/dist/**",
    "**/build/**",
    "**/.cache/**",
    "**/tmp/**",
    "**/temp/**",
    "lib/transaction-service.ts",
    "lib/test-utils.ts",
    "lib/sievo-integration.ts",
    "lib/mistral-client.ts",
    "lib/negotiation-prep/**",
    "app/api/contracts/[id]/versions/**",
    "app/api/contracts/[id]/workflows/**",
    "app/api/workflows/**",
    "app/api/deadlines/**",
    "app/upload/page.old.tsx"
  ],
  "ts-node": {
    "transpileOnly": true,
    "compilerOptions": {
      "module": "commonjs"
    }
  }
}

