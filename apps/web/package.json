{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS=\"--max-old-space-size=8192 --max-http-header-size=80000\" NEXT_TELEMETRY_DISABLED=1 WATCHPACK_POLLING=false next dev -H 0.0.0.0 -p 3005",
    "dev:turbo": "NODE_OPTIONS=\"--max-old-space-size=8192 --max-http-header-size=80000\" NEXT_TELEMETRY_DISABLED=1 WATCHPACK_POLLING=false next dev -H 0.0.0.0 -p 3005 --turbo",
    "dev:stable": "NODE_OPTIONS=\"--max-old-space-size=8192 --max-http-header-size=80000\" NEXT_TELEMETRY_DISABLED=1 next dev -H 0.0.0.0 -p 3005",
    "dev:custom": "NODE_OPTIONS=\"--expose-gc --max-old-space-size=8192 --max-http-header-size=80000\" node dev-server.js",
    "dev:memory": "NODE_OPTIONS=\"--max-old-space-size=8192 --max-http-header-size=80000\" NEXT_TELEMETRY_DISABLED=1 next dev -H 0.0.0.0 -p 3005",
    "dev:next": "next dev -H 0.0.0.0 -p 3005",
    "ws:server": "npx ts-node --esm server/start-websocket.ts",
    "ws:dev": "WEBSOCKET_PORT=3001 npx ts-node --esm server/start-websocket.ts",
    "build": "NODE_OPTIONS=\"--max-old-space-size=8192\" NEXT_BUILD=true LOG_LEVEL=silent next build",
    "build:analyze": "NODE_OPTIONS=\"--max-old-space-size=8192\" NEXT_BUILD=true LOG_LEVEL=silent ANALYZE=true next build",
    "start": "NODE_ENV=production node server.js",
    "start:next": "next start",
    "start:3002": "next start -p 3002",
    "lint": "next lint",
    "test": "playwright test --reporter=html",
    "test:headless": "playwright test --reporter=list",
    "test:ci": "CI=true playwright test --reporter=list --workers=1",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:wait": "node scripts/wait-for-server.js && playwright test --reporter=list",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit --pretty false",
    "type-check:strict:core": "tsc --noEmit -p tsconfig.strict-core.json || echo 'Run from root: pnpm type-check:web:strict:core'"
  },
