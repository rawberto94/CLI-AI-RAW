    "@opentelemetry/resources": "^1.28.0",
    "@opentelemetry/sdk-node": "^0.54.2",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-avatar": "^1.1.2",
