"use client";

import { useEffect, useState, useMemo, useCallback, lazy, Suspense, memo } from "react";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Badge } from "@/components/ui/badge";
import {
  FileText,
  Upload,
  Eye,
  Download,
  Clock,
  CheckCircle,
  AlertTriangle,
  Loader2,
  Calendar,
  DollarSign,
  Shield,
  Users,
  RefreshCw,
  Save,
  Table,
  Grid,
  Settings,
  Sparkles,
} from "lucide-react";
import Link from "next/link";
import { useRouter } from "next/navigation";
import { ContractListSkeleton } from "@/components/ui/skeletons";
import { NoContractsEmptyState, NoFilterResultsEmptyState } from "@/components/ui/empty-states";
import {
  getStatusDisplay,
  formatFileSize,
  formatCurrency,
  formatDateTime,
  getContractSummary,
  type Contract,
} from "@/lib/contracts/contracts-data-service";
import {
  filterContracts,
  sortContracts,
  getDefaultFilters,
  extractPartiesFromContracts,
  type SortOption,
} from "@/lib/contracts/filter-utils";
import { useDataMode } from "@/contexts/DataModeContext";
import { getContractTags, getTagById, getTagColor } from "@/lib/contracts/tags";
import { getDefaultFilter } from "@/lib/contracts/saved-filters";
import {
  DEFAULT_COLUMNS,
  type TableColumn,
} from "@/lib/contracts/table-config";
import {
  loadViewPreferences,
  saveViewPreferences,
  type ViewMode,
} from "@/lib/contracts/view-preferences";
import { useRealTimeEvents } from "@/contexts/RealTimeContext";
import { ErrorBoundary } from "@/components/ui/error-boundary";

// Lazy load heavy components to reduce initial bundle size
const ContractFiltersPanel = lazy(() => import("@/components/contracts/ContractFiltersPanel").then(m => ({ default: m.ContractFiltersPanel })));
const BulkActionsToolbar = lazy(() => import("@/components/contracts/BulkActionsToolbar").then(m => ({ default: m.BulkActionsToolbar })));
const SavedFiltersPanel = lazy(() => import("@/components/contracts/SavedFiltersPanel").then(m => ({ default: m.SavedFiltersPanel })));
const TableView = lazy(() => import("@/components/contracts/TableView").then(m => ({ default: m.TableView })));
const ColumnCustomizer = lazy(() => import("@/components/contracts/ColumnCustomizer").then(m => ({ default: m.ColumnCustomizer })));
const ComparisonSelector = lazy(() => import("@/components/contracts/ComparisonSelector").then(m => ({ default: m.ComparisonSelector })));
const ComparisonView = lazy(() => import("@/components/contracts/ComparisonView").then(m => ({ default: m.ComparisonView })));

// Define types locally to avoid heavy imports
type FilterOptions = any;

function ContractsPageContent() {
  const router = useRouter();
  const { dataMode } = useDataMode();
  const [contracts, setContracts] = useState<Contract[]>([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);
  
  // Use lazy initialization for complex state
  const [filters, setFilters] = useState<FilterOptions>(() => getDefaultFilters());
  const [sortBy, setSortBy] = useState<SortOption>("date-desc");
  const [showFilters, setShowFilters] = useState(false);

  // Step 1: Bulk selection state
  const [selectedIds, setSelectedIds] = useState<Set<string>>(() => new Set());
  const [showSavedFilters, setShowSavedFilters] = useState(false);

  // Step 2: Table view state - Use lazy initialization
  const [viewMode, setViewMode] = useState<ViewMode>(() => {
    if (typeof window !== 'undefined') {
      const prefs = loadViewPreferences();
      return prefs.viewMode;
    }
    return "card";
  });
  const [columns, setColumns] = useState<TableColumn[]>(() => {
    if (typeof window !== 'undefined') {
      const prefs = loadViewPreferences();
      return prefs.columns;
    }
    return DEFAULT_COLUMNS;
  });
  const [showColumnCustomizer, setShowColumnCustomizer] = useState(false);
  const [tableSortBy, setTableSortBy] = useState<string>("date");
  const [tableSortDirection, setTableSortDirection] = useState<"asc" | "desc">("desc");

  // Step 3: Comparison state
  const [showComparisonSelector, setShowComparisonSelector] = useState(false);
  const [showComparisonView, setShowComparisonView] = useState(false);
  const [comparisonContracts, setComparisonContracts] = useState<Contract[]>([]);

  // Extract unique clients and suppliers - Optimize with dependency array
  const { clients: availableClients, suppliers: availableSuppliers } = useMemo(() => {
    if (contracts.length === 0) return { clients: [], suppliers: [] };
    return extractPartiesFromContracts(contracts);
  }, [contracts]);

  // Filtered and sorted contracts - Optimize memoization
  const filteredContracts = useMemo(() => {
    const filtered = filterContracts(contracts, filters);
    return sortContracts(filtered, sortBy);
  }, [contracts, filters, sortBy]);

  // Step 1: Selection handlers
  const toggleSelection = (id: string) => {
    const newSelection = new Set(selectedIds);
    if (newSelection.has(id)) {
      newSelection.delete(id);
    } else {
      newSelection.add(id);
    }
    setSelectedIds(newSelection);
  };

  const selectAll = () => {
    setSelectedIds(new Set(filteredContracts.map((c) => c.id)));
  };

  const clearSelection = () => {
    setSelectedIds(new Set());
  };

  const isSelected = (id: string) => selectedIds.has(id);

  const fetchContracts = useCallback(async () => {
    try {
      setLoading(true);
      setError(null);

      const response = await fetch("/api/contracts/list", {
        headers: {
          'x-data-mode': dataMode,
        },
      });

      if (!response.ok) {
        throw new Error(
          `Failed to fetch contracts: ${response.status} ${response.statusText}`
        );
      }

      const data = await response.json();

      if (data.success) {
        setContracts(data.data?.contracts || []);
      } else {
        throw new Error(data.error || "Failed to load contracts");
      }
    } catch (err) {
      console.error("Error fetching contracts:", err);
      setError(err instanceof Error ? err.message : "Failed to load contracts");
    } finally {
      setLoading(false);
    }
  }, [dataMode]);

  useEffect(() => {
    fetchContracts();
  }, [fetchContracts]);

  // Real-time updates for contracts - Optimize with stable references
  const eventHandlers = useMemo(() => ({
    'contract:created': (data: any) => {
      console.log('[Contracts] New contract created:', data);
      fetchContracts(); // Refresh the list
    },
    'contract:updated': (data: any) => {
      console.log('[Contracts] Contract updated:', data);
      // Update specific contract in the list
      setContracts(prev => prev.map(c => 
        c.id === data.contractId ? { ...c, ...data.updates } : c
      ));
    },
    'contract:completed': (data: any) => {
      console.log('[Contracts] Contract processing completed:', data);
      // Update contract status
      setContracts(prev => prev.map(c => 
        c.id === data.contractId ? { ...c, status: 'completed' } : c
      ));
    },
  }), [fetchContracts]);

  useRealTimeEvents(eventHandlers);

  // Step 1: Load default filter on mount - Only if not already initialized
  useEffect(() => {
    const defaultFilter = getDefaultFilter();
    if (defaultFilter && Object.keys(filters).length === Object.keys(getDefaultFilters()).length) {
      setFilters(defaultFilter.filters);
    }
  }, []); // Remove dependency to prevent re-runs

  // Keyboard shortcuts - Optimize to prevent recreation on every render
  useEffect(() => {
    const handleKeyDown = (e: KeyboardEvent) => {
      // Select all
      if ((e.ctrlKey || e.metaKey) && e.key === "a") {
        e.preventDefault();
        if (filteredContracts.length > 0) {
          setSelectedIds(new Set(filteredContracts.map((c) => c.id)));
        }
      }
      // Clear selection
      if (e.key === "Escape") {
        setSelectedIds(new Set());
      }
    };

    window.addEventListener("keydown", handleKeyDown);
    return () => window.removeEventListener("keydown", handleKeyDown);
  }, [filteredContracts.length]); // Only depend on length, not the full array

  // Memoize stats calculations to avoid re-computing on every render
  const contractStats = useMemo(() => {
    const total = contracts.length;
    const completed = contracts.filter((c) => c.status === "completed").length;
    const processing = contracts.filter((c) => c.status === "processing").length;
    const failed = contracts.filter((c) => c.status === "failed").length;
    return { total, completed, processing, failed };
  }, [contracts]);

  const handleResetFilters = useCallback(() => {
    setFilters(getDefaultFilters());
  }, []);

  // Step 2: View mode handlers - Optimize with useCallback
  const handleViewModeChange = useCallback((mode: ViewMode) => {
    setViewMode(mode);
    saveViewPreferences({ viewMode: mode, columns });
  }, [columns]);

  const handleColumnsChange = useCallback((newColumns: TableColumn[]) => {
    setColumns(newColumns);
    saveViewPreferences({ viewMode, columns: newColumns });
  }, [viewMode]);

  const handleTableSort = useCallback((columnId: string) => {
    if (tableSortBy === columnId) {
      setTableSortDirection(tableSortDirection === "asc" ? "desc" : "asc");
    } else {
      setTableSortBy(columnId);
      setTableSortDirection("desc");
    }
  }, [tableSortBy, tableSortDirection]);

  // Step 3: Comparison handlers - Optimize with useCallback
  const handleCompareClick = useCallback(() => {
    if (selectedIds.size < 2) {
      alert("Please select at least 2 contracts to compare");
      return;
    }
    if (selectedIds.size > 4) {
      alert("You can compare up to 4 contracts at once");
      return;
    }
    setShowComparisonSelector(true);
  }, [selectedIds.size]);

  const handleCompare = useCallback((contractIds: string[]) => {
    const contractsToCompare = contracts.filter((c) =>
      contractIds.includes(c.id)
    );
    setComparisonContracts(contractsToCompare);
    setShowComparisonSelector(false);
    setShowComparisonView(true);
  }, [contracts]);

  const handleCloseComparison = useCallback(() => {
    setShowComparisonView(false);
    setComparisonContracts([]);
  }, []);

  if (loading) {
    return (
      <div className="min-h-screen bg-gradient-to-br from-gray-50 to-blue-50/30">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-6">
          <ContractListSkeleton count={5} />
        </div>
      </div>
    );
  }

  if (error) {
    return (
      <div className="min-h-screen bg-gradient-to-br from-gray-50 to-blue-50/30 flex items-center justify-center">
        <Card className="max-w-md">
          <CardContent className="p-8 text-center">
            <AlertTriangle className="w-12 h-12 text-red-600 mx-auto mb-4" />
            <h3 className="text-xl font-semibold text-gray-900 mb-2">
              Error Loading Contracts
            </h3>
            <p className="text-gray-600 mb-4">{error}</p>
            <div className="flex gap-3 justify-center">
              <Button onClick={fetchContracts} variant="outline">
                <RefreshCw className="w-4 h-4 mr-2" />
                Retry
              </Button>
              <Link href="/contracts/upload">
                <Button>
                  <Upload className="w-4 h-4 mr-2" />
                  Upload Contract
                </Button>
              </Link>
            </div>
          </CardContent>
        </Card>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-gradient-to-br from-slate-50 via-blue-50/20 to-indigo-50/30">
      <div className="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8 py-6 space-y-6">
        {/* Modern Header with Glass Morphism */}
        <div className="relative overflow-hidden rounded-2xl bg-gradient-to-r from-blue-600 via-indigo-600 to-purple-600 p-8 shadow-2xl">
          <div className="absolute inset-0 bg-grid-white/10 [mask-image:linear-gradient(0deg,transparent,black)]" />
          <div className="relative flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
            <div className="flex items-start gap-4">
              <div className="p-3 bg-white/20 backdrop-blur-xl rounded-2xl border border-white/30 shadow-lg">
                <FileText className="w-10 h-10 text-white" />
              </div>
              <div>
                <h1 className="text-4xl lg:text-5xl font-bold text-white mb-2 tracking-tight">
                  Contract Intelligence
                </h1>
                <p className="text-blue-100 text-lg max-w-2xl">
                  AI-powered portfolio management with real-time insights and analytics
                </p>
                <div className="flex items-center gap-4 mt-3">
                  <div className="flex items-center gap-2 px-3 py-1.5 bg-white/20 backdrop-blur-sm rounded-full">
                    <div className="w-2 h-2 bg-green-400 rounded-full animate-pulse" />
                    <span className="text-sm text-white font-medium">Live Analysis Active</span>
                  </div>
                  <div className="flex items-center gap-2 px-3 py-1.5 bg-white/20 backdrop-blur-sm rounded-full">
                    <Sparkles className="w-4 h-4 text-yellow-300" />
                    <span className="text-sm text-white font-medium">AI Enhanced</span>
                  </div>
                </div>
              </div>
            </div>
            <Link href="/contracts/upload">
              <Button
                size="lg"
                className="bg-white text-blue-600 hover:bg-blue-50 shadow-xl hover:shadow-2xl transition-all duration-300 hover:scale-105 font-semibold text-base px-8 py-6 rounded-xl"
              >
                <Upload className="w-5 h-5 mr-2" />
                Upload Contract
              </Button>
            </Link>
          </div>
        </div>

        {/* Modern Stats Cards with Gradient Borders */}
        <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          <div className="group relative">
            <div className="absolute -inset-0.5 bg-gradient-to-r from-blue-500 to-indigo-500 rounded-2xl opacity-75 group-hover:opacity-100 transition-opacity blur"></div>
            <Card className="relative bg-white shadow-xl border-0">
              <CardContent className="p-6">
                <div className="flex items-center justify-between">
                  <div>
                    <p className="text-sm font-medium text-gray-600 uppercase tracking-wide">Total Portfolio</p>
                    <p className="text-4xl font-bold text-gray-900 mt-2">
                      {contractStats.total}
                    </p>
                    {filteredContracts.length !== contractStats.total && (
                      <p className="text-sm text-blue-600 mt-1 font-medium">
                        {filteredContracts.length} in view
                      </p>
                    )}
                  </div>
                  <div className="p-4 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-xl shadow-lg">
                    <FileText className="w-8 h-8 text-white" />
                  </div>
                </div>
              </CardContent>
            </Card>
          </div>

          <div className="group relative">
            <div className="absolute -inset-0.5 bg-gradient-to-r from-green-500 to-emerald-500 rounded-2xl opacity-75 group-hover:opacity-100 transition-opacity blur"></div>
            <Card className="relative bg-white shadow-xl border-0">
              <CardContent className="p-6">
                <div className="flex items-center justify-between">
                  <div>
                    <p className="text-sm font-medium text-gray-600 uppercase tracking-wide">Completed</p>
                    <p className="text-4xl font-bold text-green-600 mt-2">
                      {contractStats.completed}
                    </p>
                    <p className="text-sm text-gray-500 mt-1">
                      {contractStats.total > 0 ? Math.round((contractStats.completed / contractStats.total) * 100) : 0}% completion rate
                    </p>
                  </div>
                  <div className="p-4 bg-gradient-to-br from-green-500 to-emerald-600 rounded-xl shadow-lg">
                    <CheckCircle className="w-8 h-8 text-white" />
                  </div>
                </div>
              </CardContent>
            </Card>
          </div>

          <div className="group relative">
            <div className="absolute -inset-0.5 bg-gradient-to-r from-amber-500 to-orange-500 rounded-2xl opacity-75 group-hover:opacity-100 transition-opacity blur"></div>
            <Card className="relative bg-white shadow-xl border-0">
              <CardContent className="p-6">
                <div className="flex items-center justify-between">
                  <div>
                    <p className="text-sm font-medium text-gray-600 uppercase tracking-wide">Processing</p>
                    <p className="text-4xl font-bold text-amber-600 mt-2">
                      {contractStats.processing}
                    </p>
                    <p className="text-sm text-gray-500 mt-1">
                      AI analysis in progress
                    </p>
                  </div>
                  <div className="p-4 bg-gradient-to-br from-amber-500 to-orange-600 rounded-xl shadow-lg">
                    <Loader2 className="w-8 h-8 text-white animate-spin" />
                  </div>
                </div>
              </CardContent>
            </Card>
          </div>

          <div className="group relative">
            <div className="absolute -inset-0.5 bg-gradient-to-r from-red-500 to-pink-500 rounded-2xl opacity-75 group-hover:opacity-100 transition-opacity blur"></div>
            <Card className="relative bg-white shadow-xl border-0">
              <CardContent className="p-6">
                <div className="flex items-center justify-between">
                  <div>
                    <p className="text-sm font-medium text-gray-600 uppercase tracking-wide">Needs Attention</p>
                    <p className="text-4xl font-bold text-red-600 mt-2">
                      {contractStats.failed}
                    </p>
                    <p className="text-sm text-gray-500 mt-1">
                      Requires review
                    </p>
                  </div>
                  <div className="p-4 bg-gradient-to-br from-red-500 to-pink-600 rounded-xl shadow-lg">
                    <AlertTriangle className="w-8 h-8 text-white" />
                  </div>
                </div>
              </CardContent>
            </Card>
          </div>
        </div>

        {/* Step 1: Saved Filters Panel */}
        {showSavedFilters && (
          <Suspense fallback={<div className="h-32 flex items-center justify-center"><Loader2 className="w-6 h-6 animate-spin" /></div>}>
            <SavedFiltersPanel
              currentFilters={filters}
              onApply={(newFilters) => {
                setFilters(newFilters);
                setShowSavedFilters(false);
              }}
              onClose={() => setShowSavedFilters(false)}
            />
          </Suspense>
        )}

        {/* Filters */}
        {showFilters && (
          <Suspense fallback={<div className="h-48 flex items-center justify-center"><Loader2 className="w-6 h-6 animate-spin" /></div>}>
            <ContractFiltersPanel
              filters={filters}
              onFiltersChange={setFilters}
              onReset={handleResetFilters}
              availableClients={availableClients}
              availableSuppliers={availableSuppliers}
            />
          </Suspense>
        )}

        {/* Modern Contracts List with Enhanced UI */}
        <Card className="shadow-2xl border-0 bg-white/80 backdrop-blur-sm">
          <CardHeader className="border-b border-gray-100 bg-gradient-to-r from-slate-50 via-blue-50/30 to-indigo-50/30 px-6 py-5">
            <div className="flex items-center justify-between flex-wrap gap-4">
              <div className="flex items-center gap-4">
                <CardTitle className="text-2xl font-bold bg-gradient-to-r from-gray-900 to-gray-700 bg-clip-text text-transparent">
                  {filteredContracts.length === contracts.length
                    ? "Contract Portfolio"
                    : `Filtered View`}
                </CardTitle>
                {filteredContracts.length !== contracts.length && (
                  <Badge className="bg-blue-100 text-blue-700 px-3 py-1 text-sm font-semibold">
                    {filteredContracts.length} of {contracts.length}
                  </Badge>
                )}
              </div>
              <div className="flex items-center gap-2 flex-wrap">
                {/* Modern View Mode Toggle */}
                <div className="flex items-center gap-1 bg-gray-100/80 backdrop-blur-sm rounded-xl p-1 shadow-inner">
                  <Button
                    variant={viewMode === "card" ? "default" : "ghost"}
                    size="sm"
                    onClick={() => handleViewModeChange("card")}
                    className={`h-9 px-4 rounded-lg transition-all ${
                      viewMode === "card" 
                        ? "bg-white shadow-md hover:bg-white" 
                        : "hover:bg-white/50"
                    }`}
                  >
                    <Grid className="w-4 h-4 mr-2" />
                    <span className="hidden sm:inline">Cards</span>
                  </Button>
                  <Button
                    variant={viewMode === "table" ? "default" : "ghost"}
                    size="sm"
                    onClick={() => handleViewModeChange("table")}
                    className={`h-9 px-4 rounded-lg transition-all ${
                      viewMode === "table" 
                        ? "bg-white shadow-md hover:bg-white" 
                        : "hover:bg-white/50"
                    }`}
                  >
                    <Table className="w-4 h-4 mr-2" />
                    <span className="hidden sm:inline">Table</span>
                  </Button>
                </div>

                {/* Enhanced Action Buttons */}
                {viewMode === "table" && (
                  <Button
                    variant="outline"
                    size="sm"
                    onClick={() => setShowColumnCustomizer(true)}
                    className="h-9 border-gray-300 hover:border-blue-400 hover:bg-blue-50 transition-all"
                  >
                    <Settings className="w-4 h-4 mr-2" />
                    <span className="hidden sm:inline">Customize</span>
                  </Button>
                )}

                <Button
                  variant="outline"
                  size="sm"
                  onClick={() => setShowSavedFilters(!showSavedFilters)}
                  className="h-9 border-gray-300 hover:border-purple-400 hover:bg-purple-50 transition-all"
                >
                  <Save className="w-4 h-4 mr-2" />
                  <span className="hidden sm:inline">Saved</span>
                </Button>
                <Button
                  variant={showFilters ? "default" : "outline"}
                  size="sm"
                  onClick={() => setShowFilters(!showFilters)}
                  className={`h-9 transition-all ${
                    showFilters 
                      ? "bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700" 
                      : "border-gray-300 hover:border-blue-400 hover:bg-blue-50"
                  }`}
                >
                  {showFilters ? "Hide Filters" : "Filters"}
                </Button>

                {/* Modern Sort Dropdown for Card View */}
                {viewMode === "card" && (
                  <select
                    value={sortBy}
                    onChange={(e) => setSortBy(e.target.value as SortOption)}
                    className="h-9 px-4 border border-gray-300 rounded-lg text-sm font-medium bg-white hover:border-blue-400 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition-all cursor-pointer"
                  >
                    <option value="date-desc">📅 Newest First</option>
                    <option value="date-asc">📅 Oldest First</option>
                    <option value="value-desc">💰 Highest Value</option>
                    <option value="value-asc">💰 Lowest Value</option>
                    <option value="name-asc">🔤 Name A-Z</option>
                    <option value="name-desc">🔤 Name Z-A</option>
                    <option value="risk-desc">⚠️ Highest Risk</option>
                    <option value="risk-asc">✅ Lowest Risk</option>
                  </select>
                )}
              </div>
            </div>
          </CardHeader>
          <CardContent className="p-6 bg-gradient-to-br from-gray-50/50 to-blue-50/20">
            {contracts.length === 0 ? (
              <NoContractsEmptyState
                onUpload={() => router.push('/contracts/upload')}
              />
            ) : filteredContracts.length === 0 ? (
              <NoFilterResultsEmptyState
                onClearFilters={handleResetFilters}
              />
            ) : viewMode === "table" ? (
              /* Step 2: Table View */
              <Suspense fallback={<div className="h-64 flex items-center justify-center"><Loader2 className="w-6 h-6 animate-spin" /></div>}>
                <TableView
                  contracts={filteredContracts}
                  columns={columns}
                  selectedIds={selectedIds}
                  onToggleSelection={toggleSelection}
                  onSelectAll={selectAll}
                  onClearSelection={clearSelection}
                  onSort={handleTableSort}
                  sortBy={tableSortBy}
                  sortDirection={tableSortDirection}
                />
              </Suspense>
            ) : (
              /* Card View */
              <div className="space-y-4">
                {filteredContracts.map((contract) => (
                  <ContractCard
                    key={contract.id}
                    contract={contract}
                    isSelected={isSelected(contract.id)}
                    onToggleSelection={toggleSelection}
                  />
                ))}
              </div>
            )}
          </CardContent>
        </Card>
      </div>

      {/* Step 1: Bulk Actions Toolbar */}
      <Suspense fallback={<div className="fixed bottom-4 right-4 p-2 bg-white rounded shadow"><Loader2 className="w-4 h-4 animate-spin" /></div>}>
        <BulkActionsToolbar
          selectedCount={selectedIds.size}
          selectedIds={Array.from(selectedIds)}
          onClearSelection={clearSelection}
          onActionComplete={() => {
            fetchContracts();
            clearSelection();
          }}
          onCompare={handleCompareClick}
        />
      </Suspense>

      {/* Step 2: Column Customizer Modal */}
      {showColumnCustomizer && (
        <Suspense fallback={<div className="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center"><Loader2 className="w-8 h-8 animate-spin text-white" /></div>}>
          <ColumnCustomizer
            columns={columns}
            onColumnsChange={handleColumnsChange}
            onClose={() => setShowColumnCustomizer(false)}
          />
        </Suspense>
      )}

      {/* Step 3: Comparison Selector Modal */}
      {showComparisonSelector && (
        <Suspense fallback={<div className="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center"><Loader2 className="w-8 h-8 animate-spin text-white" /></div>}>
          <ComparisonSelector
            contracts={contracts}
            preselectedIds={Array.from(selectedIds)}
            onCompare={handleCompare}
            onClose={() => setShowComparisonSelector(false)}
          />
        </Suspense>
      )}

      {/* Step 3: Comparison View */}
      {showComparisonView && comparisonContracts.length > 0 && (
        <Suspense fallback={<div className="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center"><Loader2 className="w-8 h-8 animate-spin text-white" /></div>}>
          <ComparisonView
            contracts={comparisonContracts}
            onClose={handleCloseComparison}
          />
        </Suspense>
      )}
    </div>
  );
}

// Contract Card Component with Step 1 features - Memoized for performance
interface ContractCardProps {
  contract: Contract;
  isSelected?: boolean;
  onToggleSelection?: (id: string) => void;
}

const ContractCard = memo(function ContractCard({
  contract,
  isSelected,
  onToggleSelection,
}: ContractCardProps) {
  const router = useRouter();
  const statusDisplay = getStatusDisplay(contract.status);
  const summary = getContractSummary(contract);
  const contractTags = getContractTags(contract.id);

  const getStatusIcon = () => {
    switch (contract.status) {
      case "completed":
        return <CheckCircle className="w-5 h-5 text-green-500" />;
      case "processing":
        return <Loader2 className="w-5 h-5 text-blue-500 animate-spin" />;
      case "failed":
        return <AlertTriangle className="w-5 h-5 text-red-500" />;
      default:
        return <Clock className="w-5 h-5 text-gray-500" />;
    }
  };

  const handleCardClick = (e: React.MouseEvent) => {
    // Don't navigate if clicking checkbox, buttons, or links
    const target = e.target as HTMLElement;
    if (
      target.tagName === 'INPUT' ||
      target.tagName === 'BUTTON' ||
      target.closest('button') ||
      target.closest('a')
    ) {
      return;
    }
    router.push(`/contracts/${contract.id}?tab=artifacts`);
  };

  return (
    <div 
      className="group relative overflow-hidden border-0 rounded-2xl hover:shadow-2xl transition-all duration-300 cursor-pointer bg-white"
      onClick={handleCardClick}
    >
      {/* Gradient Border Effect */}
      <div className="absolute inset-0 bg-gradient-to-r from-blue-500/20 via-indigo-500/20 to-purple-500/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-2xl" />
      
      {/* Main Content */}
      <div className="relative bg-white rounded-2xl border border-gray-200 group-hover:border-transparent transition-all p-6 shadow-md group-hover:shadow-xl">
        <div className="flex items-start gap-4">
          {/* Checkbox with Modern Styling */}
          {onToggleSelection && (
            <div className="relative mt-1">
              <input
                type="checkbox"
                checked={isSelected}
                onChange={() => onToggleSelection(contract.id)}
                className="w-5 h-5 text-blue-600 bg-white border-2 border-gray-300 rounded-md cursor-pointer transition-all hover:border-blue-500 focus:ring-2 focus:ring-blue-200 checked:bg-blue-600 checked:border-blue-600"
                onClick={(e) => e.stopPropagation()}
              />
            </div>
          )}

          {/* Contract Info */}
          <div className="flex-1 min-w-0">
            <div className="flex items-center gap-3 mb-4 flex-wrap">
              {/* Status Icon with Glow Effect */}
              <div className={`p-2 rounded-lg ${
                contract.status === "completed" ? "bg-green-50" :
                contract.status === "processing" ? "bg-blue-50" :
                contract.status === "failed" ? "bg-red-50" : "bg-gray-50"
              }`}>
                {getStatusIcon()}
              </div>
              
              {/* Title with Gradient Hover */}
              <h3 className="text-xl font-bold text-gray-900 group-hover:bg-gradient-to-r group-hover:from-blue-600 group-hover:to-indigo-600 group-hover:bg-clip-text group-hover:text-transparent transition-all truncate flex-1">
                {contract.filename ||
                  contract.originalName ||
                  "Untitled Contract"}
              </h3>
              
              {/* Modern Status Badge */}
              <Badge
                className={`
                  px-3 py-1.5 rounded-full font-semibold text-xs shadow-sm border
                  ${
                    statusDisplay.color === "green"
                      ? "bg-gradient-to-r from-green-50 to-emerald-50 text-green-700 border-green-200"
                      : ""
                  }
                  ${
                    statusDisplay.color === "blue"
                      ? "bg-gradient-to-r from-blue-50 to-indigo-50 text-blue-700 border-blue-200"
                      : ""
                  }
                  ${
                    statusDisplay.color === "red" 
                      ? "bg-gradient-to-r from-red-50 to-pink-50 text-red-700 border-red-200" 
                      : ""
                  }
                  ${
                    statusDisplay.color === "yellow"
                      ? "bg-gradient-to-r from-yellow-50 to-amber-50 text-yellow-700 border-yellow-200"
                      : ""
                  }
                  ${
                    statusDisplay.color === "gray"
                      ? "bg-gradient-to-r from-gray-50 to-slate-50 text-gray-700 border-gray-200"
                      : ""
                  }
                `}
              >
                {statusDisplay.label}
              </Badge>

            {/* Modern Tags Display */}
            {contractTags.map((tagId) => {
              const tag = getTagById(tagId);
              if (!tag) return null;
              return (
                <Badge
                  key={tagId}
                  className={getTagColor(tag.color) + " text-xs border-0 shadow-sm px-3 py-1 rounded-full font-medium"}
                >
                  {tag.name}
                </Badge>
              );
            })}
          </div>

          {/* Enhanced Contract Details Grid */}
          <div className="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-4">
            <div className="flex items-center gap-3 p-3 bg-gradient-to-br from-gray-50 to-slate-50 rounded-xl border border-gray-100">
              <div className="p-2 bg-white rounded-lg shadow-sm">
                <Calendar className="w-4 h-4 text-blue-600" />
              </div>
              <div>
                <p className="text-xs text-gray-500 font-medium">Uploaded</p>
                <p className="text-sm font-semibold text-gray-900">{formatDateTime(contract.uploadDate)}</p>
              </div>
            </div>

            <div className="flex items-center gap-3 p-3 bg-gradient-to-br from-gray-50 to-slate-50 rounded-xl border border-gray-100">
              <div className="p-2 bg-white rounded-lg shadow-sm">
                <FileText className="w-4 h-4 text-indigo-600" />
              </div>
              <div>
                <p className="text-xs text-gray-500 font-medium">Size</p>
                <p className="text-sm font-semibold text-gray-900">{formatFileSize(contract.fileSize)}</p>
              </div>
            </div>

            {summary.parties && summary.parties.length > 0 && (
              <div className="flex items-center gap-3 p-3 bg-gradient-to-br from-gray-50 to-slate-50 rounded-xl border border-gray-100">
                <div className="p-2 bg-white rounded-lg shadow-sm">
                  <Users className="w-4 h-4 text-purple-600" />
                </div>
                <div>
                  <p className="text-xs text-gray-500 font-medium">Parties</p>
                  <p className="text-sm font-semibold text-gray-900 truncate">
                    {summary.parties.length} involved
                  </p>
                </div>
              </div>
            )}

            {summary.totalValue && (
              <div className="flex items-center gap-3 p-3 bg-gradient-to-br from-green-50 to-emerald-50 rounded-xl border border-green-100">
                <div className="p-2 bg-white rounded-lg shadow-sm">
                  <DollarSign className="w-4 h-4 text-green-600" />
                </div>
                <div>
                  <p className="text-xs text-green-600 font-medium">Value</p>
                  <p className="text-sm font-bold text-green-700">
                    {formatCurrency(summary.totalValue, summary.currency)}
                  </p>
                </div>
              </div>
            )}
          </div>

          {/* Enhanced Metrics Display */}
          {contract.status === "completed" && (
            <>
              <div className="grid grid-cols-2 gap-3 mb-4">
                {summary.riskScore !== undefined && (
                  <div className="p-4 bg-gradient-to-br from-red-50 to-orange-50 rounded-xl border border-red-100">
                    <div className="flex items-center justify-between mb-2">
                      <div className="flex items-center gap-2">
                        <div className="p-1.5 bg-white rounded-lg shadow-sm">
                          <Shield className="w-4 h-4 text-red-600" />
                        </div>
                        <span className="text-sm font-semibold text-gray-700">Risk Score</span>
                      </div>
                      <span
                        className={`text-2xl font-bold ${
                          summary.riskScore >= 80
                            ? "text-red-600"
                            : summary.riskScore >= 50
                            ? "text-yellow-600"
                            : "text-green-600"
                        }`}
                      >
                        {summary.riskScore}
                      </span>
                    </div>
                    <div className="w-full bg-white/50 rounded-full h-2 overflow-hidden">
                      <div
                        className={`h-full rounded-full transition-all ${
                          summary.riskScore >= 80
                            ? "bg-gradient-to-r from-red-500 to-red-600"
                            : summary.riskScore >= 50
                            ? "bg-gradient-to-r from-yellow-500 to-orange-500"
                            : "bg-gradient-to-r from-green-500 to-emerald-500"
                        }`}
                        style={{ width: `${summary.riskScore}%` }}
                      />
                    </div>
                  </div>
                )}
                {summary.complianceScore !== undefined && (
                  <div className="p-4 bg-gradient-to-br from-blue-50 to-indigo-50 rounded-xl border border-blue-100">
                    <div className="flex items-center justify-between mb-2">
                      <div className="flex items-center gap-2">
                        <div className="p-1.5 bg-white rounded-lg shadow-sm">
                          <CheckCircle className="w-4 h-4 text-blue-600" />
                        </div>
                        <span className="text-sm font-semibold text-gray-700">Compliance</span>
                      </div>
                      <span
                        className={`text-2xl font-bold ${
                          summary.complianceScore >= 90
                            ? "text-green-600"
                            : summary.complianceScore >= 70
                            ? "text-blue-600"
                            : summary.complianceScore >= 50
                            ? "text-yellow-600"
                            : "text-red-600"
                        }`}
                      >
                        {summary.complianceScore}
                      </span>
                    </div>
                    <div className="w-full bg-white/50 rounded-full h-2 overflow-hidden">
                      <div
                        className={`h-full rounded-full transition-all ${
                          summary.complianceScore >= 90
                            ? "bg-gradient-to-r from-green-500 to-emerald-500"
                            : summary.complianceScore >= 70
                            ? "bg-gradient-to-r from-blue-500 to-indigo-500"
                            : summary.complianceScore >= 50
                            ? "bg-gradient-to-r from-yellow-500 to-orange-500"
                            : "bg-gradient-to-r from-red-500 to-pink-500"
                        }`}
                        style={{ width: `${summary.complianceScore}%` }}
                      />
                    </div>
                  </div>
                )}
              </div>
              
              {/* Modern Quick Access Pills */}
              <div className="flex items-center gap-2 flex-wrap pt-2 border-t border-gray-100">
                <span className="text-sm font-semibold text-gray-600">Quick Actions:</span>
                <Link 
                  href={`/contracts/${contract.id}?tab=artifacts`}
                  onClick={(e) => e.stopPropagation()}
                >
                  <div className="group/pill flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-blue-50 to-indigo-50 hover:from-blue-100 hover:to-indigo-100 rounded-full border border-blue-200 transition-all cursor-pointer shadow-sm hover:shadow-md">
                    <FileText className="w-4 h-4 text-blue-600 group-hover/pill:scale-110 transition-transform" />
                    <span className="text-sm font-medium text-blue-700">Artifacts</span>
                  </div>
                </Link>
                <Link 
                  href={`/contracts/${contract.id}?tab=financial`}
                  onClick={(e) => e.stopPropagation()}
                >
                  <div className="group/pill flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-green-50 to-emerald-50 hover:from-green-100 hover:to-emerald-100 rounded-full border border-green-200 transition-all cursor-pointer shadow-sm hover:shadow-md">
                    <DollarSign className="w-4 h-4 text-green-600 group-hover/pill:scale-110 transition-transform" />
                    <span className="text-sm font-medium text-green-700">Financial</span>
                  </div>
                </Link>
                <Link 
                  href={`/contracts/${contract.id}?tab=insights`}
                  onClick={(e) => e.stopPropagation()}
                >
                  <div className="group/pill flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-amber-50 to-orange-50 hover:from-amber-100 hover:to-orange-100 rounded-full border border-amber-200 transition-all cursor-pointer shadow-sm hover:shadow-md">
                    <Sparkles className="w-4 h-4 text-amber-600 group-hover/pill:scale-110 transition-transform" />
                    <span className="text-sm font-medium text-amber-700">AI Insights</span>
                  </div>
                </Link>
              </div>
            </>
          )}

          {/* Enhanced Processing Progress */}
          {contract.status === "processing" && contract.processing && (
            <div className="p-4 bg-gradient-to-r from-blue-50 to-indigo-50 rounded-xl border border-blue-200">
              <div className="flex items-center justify-between mb-3">
                <div className="flex items-center gap-2">
                  <Loader2 className="w-4 h-4 text-blue-600 animate-spin" />
                  <span className="text-sm font-semibold text-gray-700">{contract.processing.currentStage}</span>
                </div>
                <span className="text-lg font-bold text-blue-600">{contract.processing.progress}%</span>
              </div>
              <div className="relative w-full bg-blue-100 rounded-full h-3 overflow-hidden shadow-inner">
                <div
                  className="absolute inset-0 bg-gradient-to-r from-blue-500 via-indigo-500 to-purple-500 rounded-full transition-all duration-300 shadow-md"
                  style={{ width: `${contract.processing.progress}%` }}
                >
                  <div className="absolute inset-0 bg-gradient-to-r from-transparent via-white/30 to-transparent animate-shimmer" />
                </div>
              </div>
            </div>
          )}

          {/* Modern Error Message */}
          {contract.status === "failed" && contract.error && (
            <div className="p-4 bg-gradient-to-r from-red-50 to-pink-50 rounded-xl border-l-4 border-red-500 shadow-sm">
              <div className="flex items-start gap-3">
                <AlertTriangle className="w-5 h-5 text-red-600 flex-shrink-0 mt-0.5" />
                <div>
                  <p className="text-sm font-semibold text-red-900 mb-1">Processing Failed</p>
                  <p className="text-sm text-red-700">{contract.error}</p>
                </div>
              </div>
            </div>
          )}
        </div>

        {/* Modern Action Buttons */}
        <div className="flex flex-col gap-2 ml-4">
          <Link href={`/contracts/${contract.id}`}>
            <Button 
              size="sm" 
              className="w-full bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white shadow-md hover:shadow-lg transition-all"
            >
              <Eye className="w-4 h-4 mr-2" />
              View Details
            </Button>
          </Link>
          {contract.status === "completed" && (
            <Button 
              size="sm" 
              variant="outline" 
              className="w-full border-gray-300 hover:bg-gray-50 hover:border-gray-400 transition-all"
            >
              <Download className="w-4 h-4 mr-2" />
              Export
            </Button>
          )}
        </div>
      </div>
      </div>
    </div>
  );
});

export default function ContractsPageWithErrorBoundary() {
  return (
    <ErrorBoundary>
      <ContractsPageContent />
    </ErrorBoundary>
  );
}
