  /**
   * Network share document listing
   */
  private async listNetworkShareDocuments(config: RepositoryConfig): Promise<RepositoryDocument[]> {
    const documents: RepositoryDocument[] = [];
    const { path } = config.credentials;
    
    try {
      const fs = require('fs').promises;
      const entries = await fs.readdir(path, { withFileTypes: true });
      
      for (const entry of entries) {
        if (entry.isFile()) {
          const filePath = require('path').join(path, entry.name);
          const stats = await fs.stat(filePath);
          
          documents.push({
            externalId: filePath,
            filename: entry.name,
            path: filePath,
            size: stats.size,
            mimetype: this.getMimeType(entry.name),
            lastModified: stats.mtime,
            repository: config.id
          });
        }
      }
    } catch (error) {
      throw new AppError(500, `Failed to list network share documents: ${error instanceof Error ? error.message : 'Unknown error'}`);
    }
    
    return documents;
  }

  /**
   * Check if document should be processed
   */
  private shouldProcessDocument(doc: RepositoryDocument, config: RepositoryConfig): boolean {
    // Check file size
    if (doc.size > config.settings.maxFileSize) {
      return false;
    }

    // Check supported types
    if (!config.settings.supportedTypes.includes(doc.mimetype)) {
      return false;
    }

    // Check include patterns
    if (config.settings.includePatterns.length > 0) {
      const matches = config.settings.includePatterns.some(pattern =>
        new RegExp(pattern).test(doc.filename)
      );
      if (!matches) return false;
    }

    // Check exclude patterns
    if (config.settings.excludePatterns.length > 0) {
      const matches = config.settings.excludePatterns.some(pattern =>
        new RegExp(pattern).test(doc.filename)
      );
      if (matches) return false;
    }

    return true;
  }

  /**
