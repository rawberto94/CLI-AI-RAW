  private async downloadDocument(doc: RepositoryDocument, config: RepositoryConfig): Promise<Buffer> {
    switch (config.type) {
      case 'sharepoint':
        return await this.downloadSharePointDocument(doc, config);
      case 'googledrive':
        return await this.downloadGoogleDriveDocument(doc, config);
      case 'network-share':
        return await this.downloadNetworkShareDocument(doc, config);
      default:
        throw new AppError(400, `Unsupported repository type: ${config.type}`);
    }
  }

  /**
