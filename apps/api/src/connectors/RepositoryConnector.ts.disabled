  private async testGoogleDriveConnection(config: RepositoryConfig): Promise<boolean> {
    const { apiKey, accessToken } = config.credentials;
    
    try {
      const auth = accessToken ? `Bearer ${accessToken}` : `key=${apiKey}`;
      const response = await fetch(`https://www.googleapis.com/drive/v3/about?fields=user`, {
        headers: {
          'Authorization': auth
        }
      });
      
      return response.ok;
    } catch {
      return false;
    }
  }

  /**
   * Network share connection test
   */
  private async testNetworkShareConnection(config: RepositoryConfig): Promise<boolean> {
    const { path } = config.credentials;
    
    try {
      const fs = require('fs').promises;
      await fs.access(path);
      return true;
    } catch {
      return false;
    }
  }

  /**
   * List documents from external repository
   */
  private async listDocuments(config: RepositoryConfig): Promise<RepositoryDocument[]> {
    switch (config.type) {
      case 'sharepoint':
        return await this.listSharePointDocuments(config);
      case 'googledrive':
        return await this.listGoogleDriveDocuments(config);
      case 'network-share':
        return await this.listNetworkShareDocuments(config);
      default:
        throw new AppError(400, `Unsupported repository type: ${config.type}`);
    }
  }

  /**
