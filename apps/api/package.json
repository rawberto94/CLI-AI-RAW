{
  "name": "api",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
  "dev": "tsup src/server.ts --format cjs --external tsconfig-paths/register --target node18 --sourcemap --watch --onSuccess \"pnpm exec dotenv -e .env -- node dist/server.js\"",
  "build": "rimraf dist && tsup src/server.ts --format cjs --external tsconfig-paths/register --target node18 --sourcemap --out-dir dist --external utils,clients-db,clients-queue,clients-storage,agents,schemas,openai,pdf-parse",
    "start": "node dist/server.js",
    "test": "vitest run",
    "lint": "eslint . --ext .ts"
  },
  "dependencies": {
    "@fastify/compress": "^8.1.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/multipart": "^7.7.3",
    "@fastify/swagger": "^8.9.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.64.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.205.0",
    "@opentelemetry/resources": "^2.1.0",
    "@opentelemetry/sdk-node": "^0.205.0",
    "@opentelemetry/semantic-conventions": "^1.37.0",
    "agents": "workspace:*",
    "ajv": "^8.12.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^4.12.3",
    "clients-db": "workspace:*",
    "clients-openai": "workspace:*",
    "clients-queue": "workspace:*",
    "clients-rag": "workspace:*",
    "clients-storage": "workspace:*",
    "dotenv": "^16.3.1",
    "fastify": "^4.23.2",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.10.0",
    "pdf-parse": "^1.1.1",
    "pino": "^8.15.1",
    "pino-pretty": "^13.1.1",
    "schemas": "workspace:*",
    "utils": "workspace:*",
    "zod": "^3.22.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.38.1",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.6.2",
    "rimraf": "^5.0.5",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "tsup": "^8.5.0",
    "typescript": "^5.2.2",
    "vitest": "^0.34.4"
  }
}
